# Secrets - leave empty for local dev unless testing payments
LEMONSQUEEZY_API_KEY=ASK_YOUR_BACKEND_TEAM
LEMONSQUEEZY_SIGNING_SECRET=ASK_YOUR_BACKEND_TEAM

# Test mode — always true in dev (see docs/core/local-payment-testing.md). Override to false in .env.local only if needed.
LEMONSQUEEZY_TEST_MODE=true

# Test-mode signing secret (from the ngrok webhook configured in LemonSqueezy dashboard)
LEMONSQUEEZY_SIGNING_SECRET_TEST=ASK_YOUR_BACKEND_TEAM

