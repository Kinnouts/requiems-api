# PostgreSQL
POSTGRES_USER=requiem
POSTGRES_PASSWORD=requiem
POSTGRES_DB=requiem
DATABASE_URL=postgres://requiem:requiem@db:5432/requiem?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379

# Go API
PORT=8080

# Rails
RAILS_ENV=development
SECRET_KEY_BASE=development_secret_key_base_change_in_production
INTERNAL_API_URL=http://api:8080

# Shared secret (gateway ↔ backend, 32+ chars)
BACKEND_URL=http://api:8080
BACKEND_SECRET=dev_secret_min_32_chars_long_for_development_only

# API Management
API_MANAGEMENT_API_KEY=dev_api_mgmt_key_for_local_dev_only
API_MANAGEMENT_URL=http://api-management:5544
SWAGGER_USERNAME=local
SWAGGER_PASSWORD=password

# Wrangler
WRANGLER_SEND_METRICS=false

# Notifications
OBSERVER_EMAILS=eliaz@bobadilla.tech
MAILER_FROM=noreply@requiems.xyz

# LemonSqueezy (store ID and variant IDs are public - visible in checkout URLs)
LEMONSQUEEZY_STORE_SLUG=ultirequiem
LEMONSQUEEZY_STORE_ID=241998
LEMONSQUEEZY_DEVELOPER_MONTHLY_VARIANT_ID=822585
LEMONSQUEEZY_DEVELOPER_YEARLY_VARIANT_ID=822595
LEMONSQUEEZY_BUSINESS_MONTHLY_VARIANT_ID=822596
LEMONSQUEEZY_BUSINESS_YEARLY_VARIANT_ID=822601
LEMONSQUEEZY_PROFESSIONAL_MONTHLY_VARIANT_ID=822603
LEMONSQUEEZY_PROFESSIONAL_YEARLY_VARIANT_ID=822604
