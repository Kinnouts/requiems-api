# Requiem API - Production Environment Variables

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_USER=requiem
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
POSTGRES_DB=requiem

DATABASE_URL=postgres://requiem:CHANGE_THIS_TO_STRONG_PASSWORD@db:5432/requiem?sslmode=disable

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# Rails Security
# ============================================
SECRET_KEY_BASE=

# Get from: cat ../../apps/dashboard/config/master.key
RAILS_MASTER_KEY=

# ============================================
# Backend Secret (32+ characters)
# ============================================
# Must match Cloudflare Worker BACKEND_SECRET
BACKEND_SECRET=

# ============================================
# API Management Service
# ============================================
# Internal API key for Rails to communicate with api-management worker
API_MANAGEMENT_API_KEY=
API_MANAGEMENT_URL=https://api-management.requiems.xyz

# ============================================
# Cloudflare Integration
# ============================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_API_TOKEN=

# ============================================
# LemonSqueezy Payment Configuration
# ============================================
LEMONSQUEEZY_STORE_SLUG=your_store_slug
LEMONSQUEEZY_STORE_ID=your_store_id

# Get from: Settings → API → Create API Key
LEMONSQUEEZY_API_KEY=

# Get from: Settings → Webhooks → Signing Secret
LEMONSQUEEZY_SIGNING_SECRET=

# LemonSqueezy Variant IDs - Developer Plan
LEMONSQUEEZY_DEVELOPER_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_DEVELOPER_YEARLY_VARIANT_ID=

# LemonSqueezy Variant IDs - Business Plan
LEMONSQUEEZY_BUSINESS_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_BUSINESS_YEARLY_VARIANT_ID=

# LemonSqueezy Variant IDs - Professional Plan
LEMONSQUEEZY_PROFESSIONAL_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PROFESSIONAL_YEARLY_VARIANT_ID=

# ============================================
# Email / SMTP Configuration
# ============================================
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=mail.example.com
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@example.com
MAILER_HOST=example.com

# Form Notifications (comma-separated for multiple emails)
OBSERVER_EMAILS=eliaz@bobadilla.tech
MAILER_FROM=noreply@requiems.xyz