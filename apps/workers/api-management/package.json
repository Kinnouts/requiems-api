{
  "name": "@requiem/api-management",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "typecheck": "cd ../shared && pnpm install --frozen-lockfile && cd - && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "db:migrate": "wrangler d1 execute requiem-usage --local --yes --file=../auth-gateway/schema.sql",
    "db:migrate:prod": "wrangler d1 execute requiem-usage --env production --remote --file=../auth-gateway/schema.sql"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "hono": "^4.12.4",
    "@hono/swagger-ui": "^0.6.0",
    "nanoid": "^5.1.6",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@edge-runtime/vm": "^5.0.0",
    "@types/node": "^25.0.2",
    "@vitest/coverage-v8": "^1.2.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "wrangler": "^4.66.0"
  }
}
