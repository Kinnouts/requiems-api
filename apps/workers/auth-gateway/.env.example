# Cloudflare Account & Resources
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Backend Configuration (set via wrangler secret put)
# BACKEND_URL=https://api.example.com
# BACKEND_SECRET=your_secure_32_char_secret_here

# Environment (set in wrangler.toml vars)
# ENVIRONMENT=development
