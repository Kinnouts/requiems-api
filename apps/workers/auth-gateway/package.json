{
  "name": "@requiem/auth-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "typecheck": "cd ../shared && bun install --frozen-lockfile && cd - && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "db:migrate": "wrangler d1 execute requiem-usage --file=schema.sql",
    "db:migrate:prod": "wrangler d1 execute requiem-usage --file=schema.sql --env production",
    "kv:seed": "node scripts/seed-kv.ts"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.11.1",
    "hono": "^4.11.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.5.3",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@edge-runtime/vm": "^5.0.0",
    "@types/node": "^25.0.2",
    "@vitest/coverage-v8": "^1.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "wrangler": "^4.66.0"
  }
}
