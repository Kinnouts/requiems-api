<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="text-center">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">
          Example Projects & Tutorials
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Learn how to integrate Requiems APIs into your projects with these practical examples and step-by-step tutorials.
        </p>
      </div>

      <!-- Category Filter -->
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <%= link_to examples_path, class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{@selected_category.nil? ? 'bg-blue-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-50 border border-gray-200'}" do %>
          All Examples
        <% end %>

        <% @categories.each do |category| %>
          <%= link_to examples_path(category: category["name"]), class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{@selected_category == category['name'] ? 'bg-blue-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-50 border border-gray-200'}" do %>
            <%= category["icon"] %> <%= category["name"] %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Examples Grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <% if @examples.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @examples.each do |example| %>
          <%= render "partials/examples_index/example_card", example: example %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No examples found</h3>
        <p class="mt-1 text-sm text-gray-500">Try selecting a different category.</p>
      </div>
    <% end %>

    <!-- Call to Action -->
    <div class="mt-16 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-lg p-8 text-center text-white">
      <h2 class="text-2xl font-bold mb-4">Want to Contribute an Example?</h2>
      <p class="text-lg mb-6 text-blue-100">
        Share your project with the community! We welcome contributions of all kinds.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="https://github.com/bobadilla-tech/requiems-examples" target="_blank" rel="noopener" class="inline-flex items-center px-6 py-3 bg-white text-blue-600 font-medium rounded-lg hover:bg-blue-50 transition-colors">
          <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          Submit an Example
        </a>
        <a href="mailto:examples@requiems.xyz" class="inline-flex items-center px-6 py-3 bg-blue-500 text-white font-medium rounded-lg hover:bg-blue-400 transition-colors">
          <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Contact Us
        </a>
      </div>
    </div>
  </div>
</div>
