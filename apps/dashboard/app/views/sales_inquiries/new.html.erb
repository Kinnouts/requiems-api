<% content_for :title, "Talk to Sales - Requiems API" %>

<div class="min-h-screen bg-gray-50 py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-lg shadow-lg p-8 md:p-12">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Talk to Sales</h1>
        <p class="text-xl text-gray-600">
          We're here to help you with your API needs. Please fill out the form and we'll get back to you as soon as possible!
        </p>
      </div>

      <!-- Enterprise Features -->
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <!-- Enterprise-scale APIs -->
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-200 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <h3 class="ml-3 text-lg font-bold text-gray-900">Enterprise-scale APIs</h3>
          </div>
          <p class="text-gray-700 text-sm">
            Scale your operations with high-volume API access, custom rate limits, and dedicated infrastructure designed for enterprise workloads.
          </p>
        </div>

        <!-- Enterprise security -->
        <div class="bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <h3 class="ml-3 text-lg font-bold text-gray-900">Enterprise security, privacy and compliance</h3>
          </div>
          <p class="text-gray-700 text-sm">
            Meet your compliance requirements with SOC 2 certification, GDPR compliance, security documentation, and enterprise-grade data protection.
          </p>
        </div>

        <!-- Enterprise support -->
        <div class="bg-gradient-to-br from-purple-50 to-pink-50 border border-purple-200 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </div>
            <h3 class="ml-3 text-lg font-bold text-gray-900">Enterprise dedicated support</h3>
          </div>
          <p class="text-gray-700 text-sm">
            Get dedicated support with guaranteed response times, direct access to our engineering team, and priority assistance for your critical needs.
          </p>
        </div>
      </div>

      <!-- Flash Messages -->
      <% if flash[:alert] %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
          <div class="flex items-start">
            <svg class="h-5 w-5 text-red-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm text-red-800"><%= flash[:alert] %></p>
          </div>
        </div>
      <% end %>

      <!-- Form Section -->
      <div class="bg-gray-50 rounded-lg p-8 mb-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Get in Touch with Our Sales Team</h2>
        <p class="text-gray-600 mb-6">Fill out the form below and our sales team will reach out to discuss your API needs.</p>

        <%= form_with url: talk_to_sales_path, method: :post, local: true, data: { turbo: false } do |f| %>
          <div class="grid md:grid-cols-2 gap-6">
            <!-- Name -->
            <div>
              <%= label_tag "inquiry[name]", "Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= text_field_tag "inquiry[name]", params.dig(:inquiry, :name),
                placeholder: "John Doe",
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white",
                required: true,
                autofocus: true %>
            </div>

            <!-- Email -->
            <div>
              <%= label_tag "inquiry[email]", "Email", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= email_field_tag "inquiry[email]", params.dig(:inquiry, :email),
                placeholder: "john@company.com",
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white",
                required: true %>
            </div>
          </div>

          <!-- Company -->
          <div class="mt-6">
            <%= label_tag "inquiry[company]", "Company", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= text_field_tag "inquiry[company]", params.dig(:inquiry, :company),
              placeholder: "Acme Corporation",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white",
              required: true %>
          </div>

          <!-- Message -->
          <div class="mt-6">
            <%= label_tag "inquiry[message]", "Anything specific you want to share", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= text_area_tag "inquiry[message]", params.dig(:inquiry, :message),
              placeholder: "Tell us about your API needs, expected volume, specific requirements, or any questions you have...",
              rows: 5,
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none bg-white" %>
            <p class="mt-1 text-xs text-gray-500">Optional - Share any details that will help us assist you better.</p>
          </div>

          <!-- Response Time Notice -->
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-6 mb-6">
            <div class="flex items-start">
              <svg class="h-5 w-5 text-blue-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <p class="text-sm text-blue-800">We usually reply within 24 hours.</p>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex items-center justify-end space-x-4">
            <%= link_to "Cancel", root_path, class: "px-6 py-3 text-gray-700 font-medium hover:text-gray-900 transition-colors" %>
            <%= submit_tag "Get Started",
              class: "px-8 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors shadow-sm hover:shadow-md",
              data: { disable_with: "Sending..." } %>
          </div>
        <% end %>
      </div>

      <!-- Additional Info -->
      <div class="text-center text-gray-600 text-sm">
        <p class="mb-2">
          <svg class="inline h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          Your information is secure and will only be used to contact you about your inquiry.
        </p>
        <p>
          Have general questions? Check out our <%= link_to "FAQ", faq_path, class: "text-blue-600 hover:text-blue-700 underline" %> or <%= link_to "contact support", contact_path, class: "text-blue-600 hover:text-blue-700 underline" %>.
        </p>
      </div>
    </div>
  </div>
</div>
