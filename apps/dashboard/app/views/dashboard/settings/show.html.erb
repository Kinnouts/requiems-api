<% content_for :title, "Settings" %>

<!-- Header -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Settings</h1>
  <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Manage your account preferences and security settings</p>
</div>

<%= form_with model: current_user, url: dashboard_settings_path, method: :patch, local: true do |f| %>
  <!-- Error Messages -->
  <% if current_user.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-6">
      <div class="flex items-start">
        <svg class="h-5 w-5 text-red-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <h3 class="text-sm font-medium text-red-800 dark:text-red-300 mb-1">
            <%= pluralize(current_user.errors.count, "error") %> prohibited these settings from being saved:
          </h3>
          <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
            <% current_user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Account Information -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Account Information</h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Update your account details and email address</p>
    </div>

    <div class="p-6 space-y-6">
      <!-- Email -->
      <div>
        <%= f.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.email_field :email,
          class: "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent",
          required: true %>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
          This is your login email and where we'll send important notifications.
        </p>
      </div>

      <!-- Name -->
      <div>
        <%= f.label :name, "Full Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.text_field :name,
          placeholder: "Your full name",
          class: "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Optional - helps us personalize your experience</p>
      </div>

      <!-- Company -->
      <div>
        <%= f.label :company, "Company Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.text_field :company,
          placeholder: "Your company or organization",
          class: "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Optional - displayed on invoices</p>
      </div>

      <!-- Profile Picture -->
      <div class="pt-6 border-t border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <img src="<%= gravatar_url(current_user.email, size: 48) %>" alt="Profile picture" class="h-12 w-12 rounded-full">
            <div>
              <h3 class="text-sm font-medium text-gray-900 dark:text-gray-100">Profile Picture</h3>
              <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">
                Your avatar is provided by
                <%= link_to "Gravatar", "https://gravatar.com", target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:text-blue-700 font-medium" %>,
                based on your email address. Update it there to change it here.
              </p>
            </div>
          </div>
          <%= link_to "https://gravatar.com", target: "_blank", rel: "noopener noreferrer", class: "text-sm text-blue-600 hover:text-blue-700 font-medium shrink-0" do %>
            Update on Gravatar →
          <% end %>
        </div>
      </div>

      <!-- Change Password Link -->
      <div class="pt-6 border-t border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-medium text-gray-900 dark:text-gray-100">Password</h3>
            <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">••••••••••••</p>
          </div>
          <%= link_to edit_user_registration_path, class: "text-sm text-blue-600 hover:text-blue-700 font-medium" do %>
            Change Password →
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Email Preferences -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Email Preferences</h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Control what emails you receive from us</p>
    </div>

    <div class="p-6 space-y-4">
      <!-- Email Notifications -->
      <label class="flex items-start cursor-pointer">
        <%= f.check_box :email_notifications,
          class: "mt-1 mr-3 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100">Email Notifications</div>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">Receive emails about account activity, API key changes, and important updates</p>
        </div>
      </label>

      <!-- Usage Alerts -->
      <label class="flex items-start cursor-pointer">
        <%= f.check_box :usage_alerts,
          class: "mt-1 mr-3 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100">Usage Alerts</div>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">Get notified when you reach 75% and 90% of your monthly quota</p>
        </div>
      </label>

      <!-- Weekly Reports -->
      <label class="flex items-start cursor-pointer">
        <%= f.check_box :weekly_reports,
          class: "mt-1 mr-3 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100">Weekly Usage Reports</div>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">Receive a weekly summary of your API usage and performance</p>
        </div>
      </label>
    </div>
  </div>

  <!-- Save Button -->
  <div class="flex items-center justify-end mb-8">
    <%= f.submit "Save Changes",
      class: "px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors",
      data: { disable_with: "Saving..." } %>
  </div>
<% end %>

<%= render "partials/shared/danger_zone",
  form_url: request_deletion_dashboard_settings_path %>
