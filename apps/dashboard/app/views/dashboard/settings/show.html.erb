<% content_for :title, t("dashboard.settings.title") %>

<!-- Header -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= t("dashboard.settings.title") %></h1>
  <p class="mt-2 text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.settings.subtitle") %></p>
</div>

<%= form_with model: current_user, url: dashboard_settings_path, method: :patch, local: true do |f| %>
  <!-- Error Messages -->
  <% if current_user.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-6">
      <div class="flex items-start">
        <svg class="h-5 w-5 text-red-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <h3 class="text-sm font-medium text-red-800 dark:text-red-300 mb-1">
            <%= t("dashboard.settings.errors", count: current_user.errors.count) %>
          </h3>
          <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
            <% current_user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Account Information -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.settings.account_info.heading") %></h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.settings.account_info.subheading") %></p>
    </div>

    <div class="p-6 space-y-6">
      <!-- Email -->
      <div>
        <%= f.label :email, t("dashboard.settings.account_info.email_label"), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.email_field :email,
          class: "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent",
          required: true %>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
          <%= t("dashboard.settings.account_info.email_hint") %>
        </p>
      </div>

      <!-- Name -->
      <div>
        <%= f.label :name, t("dashboard.settings.account_info.name_label"), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.text_field :name,
          placeholder: t("dashboard.settings.account_info.name_placeholder"),
          class: "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400"><%= t("dashboard.settings.account_info.name_hint") %></p>
      </div>

      <!-- Company -->
      <div>
        <%= f.label :company, t("dashboard.settings.account_info.company_label"), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.text_field :company,
          placeholder: t("dashboard.settings.account_info.company_placeholder"),
          class: "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400"><%= t("dashboard.settings.account_info.company_hint") %></p>
      </div>

      <!-- Profile Picture -->
      <div class="pt-6 border-t border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <img src="<%= gravatar_url(current_user.email, size: 48) %>" alt="Profile picture" class="h-12 w-12 rounded-full">
            <div>
              <h3 class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= t("dashboard.settings.account_info.avatar_heading") %></h3>
              <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">
                <%= t("dashboard.settings.account_info.avatar_body",
                  gravatar_link: link_to(t("dashboard.settings.account_info.gravatar_link_text"), "https://gravatar.com", target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:text-blue-700 font-medium")).html_safe %>
              </p>
            </div>
          </div>
          <%= link_to "https://gravatar.com", target: "_blank", rel: "noopener noreferrer", class: "text-sm text-blue-600 hover:text-blue-700 font-medium shrink-0" do %>
            <%= t("dashboard.settings.account_info.update_gravatar") %>
          <% end %>
        </div>
      </div>

      <!-- Change Password Link -->
      <div class="pt-6 border-t border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= t("dashboard.settings.account_info.password_heading") %></h3>
            <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">••••••••••••</p>
          </div>
          <%= link_to edit_user_registration_path, class: "text-sm text-blue-600 hover:text-blue-700 font-medium" do %>
            <%= t("dashboard.settings.account_info.change_password") %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Language Preference -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.settings.language.heading") %></h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.settings.language.subheading") %></p>
    </div>
    <div class="p-6">
      <div class="flex flex-wrap gap-3" data-controller="locale-selector">
        <% I18n.available_locales.each do |locale| %>
          <% selected = (current_user.locale.present? ? current_user.locale.to_sym : I18n.locale) == locale %>
          <%= f.label :locale, value: locale,
            class: "flex items-center gap-2 px-4 py-2 rounded-lg border cursor-pointer transition-colors #{selected ? 'border-blue-500 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300' : 'border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:border-gray-400 dark:hover:border-gray-500'}",
            data: { locale_selector_target: "option", action: "click->locale-selector#select" } do %>
            <%= f.radio_button :locale, locale, checked: selected, class: "sr-only" %>
            <span class="text-sm font-medium"><%= locale_name(locale) %></span>
          <% end %>
        <% end %>
        <% auto_selected = current_user.locale.blank? %>
        <%= f.label :locale, value: "",
          class: "flex items-center gap-2 px-4 py-2 rounded-lg border cursor-pointer transition-colors #{auto_selected ? 'border-blue-500 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300' : 'border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:border-gray-400 dark:hover:border-gray-500'}",
          data: { locale_selector_target: "option", action: "click->locale-selector#select" } do %>
          <%= f.radio_button :locale, "", checked: auto_selected, class: "sr-only" %>
          <span class="text-sm font-medium"><%= t("dashboard.settings.language.auto_detect") %></span>
        <% end %>
      </div>
      <p class="mt-3 text-xs text-gray-500 dark:text-gray-400"><%= t("dashboard.settings.language.auto_detect_hint") %></p>
    </div>
  </div>

  <!-- Email Preferences -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.settings.email_prefs.heading") %></h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.settings.email_prefs.subheading") %></p>
    </div>

    <div class="p-6 space-y-4">
      <!-- Email Notifications -->
      <label class="flex items-start cursor-pointer">
        <%= f.check_box :email_notifications,
          class: "mt-1 mr-3 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= t("dashboard.settings.email_prefs.notifications_label") %></div>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.settings.email_prefs.notifications_hint") %></p>
        </div>
      </label>

      <!-- Usage Alerts -->
      <label class="flex items-start cursor-pointer">
        <%= f.check_box :usage_alerts,
          class: "mt-1 mr-3 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= t("dashboard.settings.email_prefs.usage_alerts_label") %></div>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.settings.email_prefs.usage_alerts_hint") %></p>
        </div>
      </label>

      <!-- Weekly Reports -->
      <label class="flex items-start cursor-pointer">
        <%= f.check_box :weekly_reports,
          class: "mt-1 mr-3 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= t("dashboard.settings.email_prefs.weekly_reports_label") %></div>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.settings.email_prefs.weekly_reports_hint") %></p>
        </div>
      </label>
    </div>
  </div>

  <!-- Save Button -->
  <div class="flex items-center justify-end mb-8">
    <%= f.submit t("dashboard.settings.save_btn"),
      class: "px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors",
      data: { disable_with: t("dashboard.settings.saving") } %>
  </div>
<% end %>

<%= render "partials/shared/danger_zone",
  form_url: request_deletion_dashboard_settings_path %>
