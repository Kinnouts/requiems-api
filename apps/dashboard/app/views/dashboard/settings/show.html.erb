<% content_for :title, "Settings" %>

<!-- Header -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Settings</h1>
  <p class="mt-2 text-sm text-gray-600">Manage your account preferences and security settings</p>
</div>

<%= form_with model: current_user, url: dashboard_settings_path, method: :patch, local: true do |f| %>
  <!-- Error Messages -->
  <% if current_user.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <div class="flex items-start">
        <svg class="h-5 w-5 text-red-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <h3 class="text-sm font-medium text-red-800 mb-1">
            <%= pluralize(current_user.errors.count, "error") %> prohibited these settings from being saved:
          </h3>
          <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
            <% current_user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Account Information -->
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Account Information</h2>
      <p class="text-sm text-gray-600 mt-1">Update your account details and email address</p>
    </div>

    <div class="p-6 space-y-6">
      <!-- Email -->
      <div>
        <%= f.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.email_field :email,
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent",
          required: true %>
        <p class="mt-1 text-xs text-gray-500">
          This is your login email and where we'll send important notifications.
        </p>
      </div>

      <!-- Name -->
      <div>
        <%= f.label :name, "Full Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :name,
          placeholder: "Your full name",
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        <p class="mt-1 text-xs text-gray-500">Optional - helps us personalize your experience</p>
      </div>

      <!-- Company -->
      <div>
        <%= f.label :company, "Company Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :company,
          placeholder: "Your company or organization",
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        <p class="mt-1 text-xs text-gray-500">Optional - displayed on invoices</p>
      </div>

      <!-- Change Password Link -->
      <div class="pt-6 border-t border-gray-200">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-medium text-gray-900">Password</h3>
            <p class="text-xs text-gray-600 mt-1">••••••••••••</p>
          </div>
          <%= link_to edit_user_registration_path, class: "text-sm text-blue-600 hover:text-blue-700 font-medium" do %>
            Change Password →
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Email Preferences -->
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Email Preferences</h2>
      <p class="text-sm text-gray-600 mt-1">Control what emails you receive from us</p>
    </div>

    <div class="p-6 space-y-4">
      <!-- Email Notifications -->
      <label class="flex items-start cursor-pointer">
        <%= f.check_box :email_notifications,
          class: "mt-1 mr-3 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900">Email Notifications</div>
          <p class="text-xs text-gray-600 mt-1">Receive emails about account activity, API key changes, and important updates</p>
        </div>
      </label>

      <!-- Usage Alerts -->
      <label class="flex items-start cursor-pointer">
        <%= f.check_box :usage_alerts,
          class: "mt-1 mr-3 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900">Usage Alerts</div>
          <p class="text-xs text-gray-600 mt-1">Get notified when you reach 75% and 90% of your monthly quota</p>
        </div>
      </label>

      <!-- Weekly Reports -->
      <label class="flex items-start cursor-pointer">
        <%= f.check_box :weekly_reports,
          class: "mt-1 mr-3 h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900">Weekly Usage Reports</div>
          <p class="text-xs text-gray-600 mt-1">Receive a weekly summary of your API usage and performance</p>
        </div>
      </label>
    </div>
  </div>

  <!-- Save Button -->
  <div class="flex items-center justify-end mb-8">
    <%= f.submit "Save Changes",
      class: "px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors",
      data: { disable_with: "Saving..." } %>
  </div>
<% end %>

<!-- Danger Zone -->
<div class="bg-white rounded-lg shadow border-2 border-red-200">
  <div class="px-6 py-4 bg-red-50 border-b border-red-200">
    <h2 class="text-lg font-semibold text-red-900">Danger Zone</h2>
    <p class="text-sm text-red-700 mt-1">Irreversible actions that permanently affect your account</p>
  </div>

  <div class="p-6">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between">
      <div class="mb-4 lg:mb-0">
        <h3 class="text-sm font-medium text-gray-900 mb-1">Delete Account</h3>
        <p class="text-sm text-gray-600">
          Permanently delete your account and all associated data. This action cannot be undone.
        </p>
        <ul class="mt-2 space-y-1 text-xs text-gray-600">
          <li class="flex items-start">
            <svg class="h-4 w-4 text-red-500 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
            <span>All API keys will be revoked immediately</span>
          </li>
          <li class="flex items-start">
            <svg class="h-4 w-4 text-red-500 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
            <span>Your subscription will be canceled</span>
          </li>
          <li class="flex items-start">
            <svg class="h-4 w-4 text-red-500 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
            <span>All usage data will be permanently deleted</span>
          </li>
        </ul>
      </div>

      <button
        type="button"
        data-controller="confirm-delete"
        data-action="click->confirm-delete#open"
        class="flex-shrink-0 px-6 py-3 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors">
        Delete Account
      </button>
    </div>

    <!-- Delete Confirmation Modal -->
    <div data-confirm-delete-target="modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
      <div class="bg-white rounded-lg max-w-md w-full p-6">
        <div class="mb-4">
          <div class="flex items-center justify-center w-12 h-12 mx-auto bg-red-100 rounded-full mb-4">
            <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 text-center mb-2">Delete Account?</h3>
          <p class="text-sm text-gray-600 text-center mb-4">
            This action cannot be undone. All your data will be permanently deleted.
          </p>
        </div>

        <%= form_with url: account_dashboard_settings_path, method: :delete, local: true, class: "space-y-4" do |f| %>
          <div>
            <%= f.label :confirm_email, "Type your email to confirm:", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.email_field :confirm_email,
              placeholder: current_user.email,
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent",
              required: true,
              data: { confirm_delete_target: "emailInput" } %>
          </div>

          <div class="flex items-center space-x-3">
            <button
              type="button"
              data-action="click->confirm-delete#close"
              class="flex-1 px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
              Cancel
            </button>
            <%= f.submit "Delete My Account",
              class: "flex-1 px-4 py-2 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors",
              data: { disable_with: "Deleting..." } %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
