<% content_for :title, "Create New API Key" %>

<!-- Header with Back Link -->
<div class="mb-8">
  <%= link_to dashboard_api_keys_path, class: "inline-flex items-center text-sm text-gray-600 hover:text-gray-900 mb-4" do %>
    <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
    </svg>
    Back to API Keys
  <% end %>
  <h1 class="text-3xl font-bold text-gray-900">Create New API Key</h1>
  <p class="mt-2 text-sm text-gray-600">Generate a new API key to access our services</p>
</div>

<div class="max-w-2xl">
  <!-- Security Notice -->
  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
    <div class="flex items-start">
      <svg class="h-5 w-5 text-yellow-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <div class="text-sm text-yellow-800">
        <p class="font-medium mb-1">Important Security Information</p>
        <p>Your API key will only be shown once after creation. Make sure to copy and store it securely. We cannot recover lost keys.</p>
      </div>
    </div>
  </div>

  <!-- Form -->
  <div class="bg-white rounded-lg shadow p-6">
    <%= form_with model: @api_key, url: dashboard_api_keys_path, local: true do |f| %>
      <!-- Error Messages -->
      <% if @api_key.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
          <div class="flex items-start">
            <svg class="h-5 w-5 text-red-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div>
              <h3 class="text-sm font-medium text-red-800 mb-1">
                <%= pluralize(@api_key.errors.count, "error") %> prohibited this API key from being created:
              </h3>
              <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
                <% @api_key.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Key Name -->
      <div class="mb-6">
        <%= f.label :name, "Key Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :name,
          placeholder: "e.g., Production Server, Mobile App, Development",
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent",
          required: true,
          autofocus: true %>
        <p class="mt-1 text-xs text-gray-500">A descriptive name to help you identify where this key is used.</p>
      </div>

      <!-- Environment -->
      <div class="mb-6">
        <%= f.label :environment, "Environment", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <div class="space-y-3">
          <label class="flex items-start p-4 border border-gray-300 rounded-lg cursor-pointer hover:bg-gray-50 transition-colors">
            <%= f.radio_button :environment, "live", class: "mt-1 mr-3", checked: true %>
            <div class="flex-1">
              <div class="flex items-center">
                <span class="font-medium text-gray-900">Live</span>
                <%= render "shared/badge", text: "Production", variant: "primary", size: "xs", class_names: "ml-2" %>
              </div>
              <p class="text-sm text-gray-600 mt-1">Use for production environments. All requests will be counted against your quota.</p>
            </div>
          </label>

          <label class="flex items-start p-4 border border-gray-300 rounded-lg cursor-pointer hover:bg-gray-50 transition-colors">
            <%= f.radio_button :environment, "test", class: "mt-1 mr-3" %>
            <div class="flex-1">
              <div class="flex items-center">
                <span class="font-medium text-gray-900">Test</span>
                <%= render "shared/badge", text: "Development", variant: "default", size: "xs", class_names: "ml-2" %>
              </div>
              <p class="text-sm text-gray-600 mt-1">Use for development and testing. Limited functionality, does not count against your quota.</p>
            </div>
          </label>
        </div>
      </div>

      <!-- Shared Quota Notice -->
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
        <div class="flex items-start">
          <svg class="h-5 w-5 text-blue-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div class="text-sm text-blue-800">
            <p class="font-medium mb-1">Shared Quota</p>
            <p>All your API keys share the same monthly request quota based on your subscription plan. Creating multiple keys doesn't increase your limit.</p>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex items-center justify-end space-x-4">
        <%= link_to "Cancel", dashboard_api_keys_path, class: "px-6 py-2 text-gray-700 font-medium hover:text-gray-900 transition-colors" %>
        <%= f.submit "Generate API Key",
          class: "px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors",
          data: { disable_with: "Generating..." } %>
      </div>
    <% end %>
  </div>
</div>
