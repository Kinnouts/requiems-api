<% content_for :title, t("dashboard.api_keys.show_key.title") %>

<!-- Success Message -->
<div class="mb-8">
  <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-6">
    <div class="flex items-start">
      <svg class="h-6 w-6 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div class="flex-1">
        <h2 class="text-lg font-semibold text-green-900 dark:text-green-100 mb-1"><%= t("dashboard.api_keys.show_key.success_heading") %></h2>
        <p class="text-sm text-green-800 dark:text-green-300"><%= t("dashboard.api_keys.show_key.success_body") %></p>
      </div>
    </div>
  </div>
</div>

<!-- Key Display Card -->
<div class="max-w-4xl mx-auto">
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 mb-8">
    <!-- Key Info Header -->
    <div class="mb-6">
      <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2"><%= @api_key.name %></h3>
      <%= render "partials/shared/badge", text: t("dashboard.api_keys.status_active"), variant: "success", size: "sm" %>
    </div>

    <!-- API Key Display -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"><%= t("dashboard.api_keys.show_key.key_label") %></label>
      <div class="relative">
        <div class="flex items-center bg-gray-900 rounded-lg p-4">
          <code id="api-key" class="flex-1 text-green-400 font-mono text-sm break-all select-all"><%= @api_key.full_key %></code>
          <button
            data-controller="copy-key"
            data-copy-key-value="<%= @api_key.full_key %>"
            data-action="click->copy-key#copy"
            class="ml-4 flex-shrink-0 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded hover:bg-blue-700 transition-colors"
            title="Copy to clipboard">
            <span data-copy-key-target="defaultText"><%= t("dashboard.api_keys.show_key.copy_btn") %></span>
            <span data-copy-key-target="copiedText" class="hidden"><%= t("dashboard.api_keys.show_key.copied_btn") %></span>
          </button>
        </div>
      </div>
      <p class="mt-2 text-xs text-gray-500 dark:text-gray-400"><%= t("dashboard.api_keys.show_key.key_hint") %></p>
    </div>

    <!-- Warning Box -->
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-6">
      <div class="flex items-start">
        <svg class="h-5 w-5 text-red-500 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div class="text-sm text-red-800 dark:text-red-300">
          <p class="font-medium mb-1"><%= t("dashboard.api_keys.show_key.warning_heading") %></p>
          <p><%= t("dashboard.api_keys.show_key.warning_body") %></p>
        </div>
      </div>
    </div>

    <!-- Usage Instructions -->
    <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6 mb-6" data-controller="highlight">
      <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-3"><%= t("dashboard.api_keys.show_key.usage_heading") %></h4>

      <div class="space-y-4">
        <div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"><%= t("dashboard.api_keys.show_key.header_example") %></p>
          <div class="relative group">
            <div class="bg-gray-900 rounded p-3 overflow-x-auto">
              <pre class="!m-0"><code class="language-http">requiems-api-key: <%= @api_key.full_key %></code></pre>
            </div>
            <button
              data-controller="copy"
              data-copy-text-value="requiems-api-key: <%= @api_key.full_key %>"
              data-action="click->copy#copy"
              class="absolute top-2 right-2 px-2 py-1 text-xs bg-gray-700 text-gray-300 rounded opacity-0 group-hover:opacity-100 transition-opacity hover:bg-gray-600">
              <%= t("dashboard.api_keys.show_key.copy_btn") %>
            </button>
          </div>
        </div>

        <div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"><%= t("dashboard.api_keys.show_key.curl_example") %></p>
          <div class="relative group">
            <div class="bg-gray-900 rounded p-3 overflow-x-auto">
              <pre class="!m-0"><code class="language-bash">curl -X POST https://api.requiems.xyz/v1/networking/disposable/check \
  -H "requiems-api-key: <%= @api_key.full_key %>" \
  -H "Content-Type: application/json" \
  -d '{"email": "test@example.com"}'</code></pre>
            </div>
            <button
              data-controller="copy"
              data-copy-text-value="curl -X POST https://api.requiems.xyz/v1/networking/disposable/check \
  -H &quot;requiems-api-key: <%= @api_key.full_key %>&quot; \
  -H &quot;Content-Type: application/json&quot; \
  -d '{&quot;email&quot;: &quot;test@example.com&quot;}'"
              data-action="click->copy#copy"
              class="absolute top-2 right-2 px-2 py-1 text-xs bg-gray-700 text-gray-300 rounded opacity-0 group-hover:opacity-100 transition-opacity hover:bg-gray-600">
              <%= t("dashboard.api_keys.show_key.copy_btn") %>
            </button>
          </div>
        </div>

        <div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"><%= t("dashboard.api_keys.show_key.js_example") %></p>
          <div class="relative group">
            <div class="bg-gray-900 rounded p-3 overflow-x-auto">
              <pre class="!m-0"><code class="language-javascript">const response = await fetch('https://api.requiems.xyz/v1/networking/disposable/check', {
  method: 'POST',
  headers: {
    'requiems-api-key': '<%= @api_key.full_key %>',
    'Content-Type': 'application/json'
  },
  body: JSON.stringify({ email: 'test@example.com' })
});</code></pre>
            </div>
            <button
              data-controller="copy"
              data-copy-text-value="const response = await fetch('https://api.requiems.xyz/v1/networking/disposable/check', {
  method: 'POST',
  headers: {
    'requiems-api-key': '<%= @api_key.full_key %>',
    'Content-Type': 'application/json'
  },
  body: JSON.stringify({ email: 'test@example.com' })
});"
              data-action="click->copy#copy"
              class="absolute top-2 right-2 px-2 py-1 text-xs bg-gray-700 text-gray-300 rounded opacity-0 group-hover:opacity-100 transition-opacity hover:bg-gray-600">
              <%= t("dashboard.api_keys.show_key.copy_btn") %>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Security Best Practices -->
    <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
      <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-3"><%= t("dashboard.api_keys.show_key.security_heading") %></h4>
      <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
        <% 4.times do |i| %>
          <li class="flex items-start">
            <svg class="h-5 w-5 text-blue-500 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span><%= t("dashboard.api_keys.show_key.security_#{i + 1}") %></span>
          </li>
        <% end %>
      </ul>
    </div>

    <!-- Actions -->
    <div class="flex items-center justify-between mt-8 pt-6 border-t border-gray-200 dark:border-gray-700">
      <%= link_to dashboard_api_keys_path, class: "text-blue-600 hover:text-blue-700 font-medium" do %>
        <%= t("dashboard.api_keys.show_key.back_btn") %>
      <% end %>
      <div class="flex items-center space-x-4">
        <%= link_to apis_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <%= t("dashboard.api_keys.show_key.view_docs_btn") %>
        <% end %>
        <%= link_to dashboard_root_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
          <%= t("dashboard.api_keys.show_key.go_dashboard_btn") %>
          <svg class="h-4 w-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</div>
