<% content_for :title, t("dashboard.usage.title") %>

<!-- Header -->
<div class="flex flex-col lg:flex-row lg:items-center lg:justify-between mb-8">
  <div>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= t("dashboard.usage.title") %></h1>
    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.usage.subtitle") %></p>
  </div>

  <!-- Export Button -->
  <%= link_to export_dashboard_usage_path(range: params[:range], start_date: params[:start_date], end_date: params[:end_date]),
    class: "mt-4 lg:mt-0 inline-flex items-center px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors",
    data: { turbo: false } do %>
    <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>
    <%= t("dashboard.usage.export_btn") %>
  <% end %>
</div>

<!-- Date Range Filter -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-8" data-controller="date-range">
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between">
    <div class="mb-4 lg:mb-0">
      <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300"><%= t("dashboard.usage.date_range.heading") %></h3>
      <p class="text-lg font-semibold text-gray-900 dark:text-gray-100 mt-1"><%= @range_label %></p>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to t("dashboard.usage.date_range.last_7"),  dashboard_usage_path(range: "7d"),  class: range_button_classes("7d") %>
      <%= link_to t("dashboard.usage.date_range.last_30"), dashboard_usage_path(range: "30d"), class: range_button_classes("30d") %>
      <%= link_to t("dashboard.usage.date_range.last_90"), dashboard_usage_path(range: "90d"), class: range_button_classes("90d") %>

      <button
        data-action="click->date-range#toggle"
        class="<%= range_button_classes("custom") %>">
        <%= t("dashboard.usage.date_range.custom") %>
      </button>
    </div>
  </div>

  <!-- Custom Date Range Form (Hidden by default) -->
  <div data-date-range-target="form" class="<%= params[:range] == 'custom' ? 'mt-6' : 'hidden mt-6' %>">
    <%= form_with url: dashboard_usage_path, method: :get, local: true, class: "flex flex-col lg:flex-row gap-4 items-end" do |f| %>
      <%= f.hidden_field :range, value: "custom" %>

      <div class="flex-1">
        <%= f.label :start_date, t("dashboard.usage.date_range.start_date"), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.date_field :start_date,
          value: params[:start_date] || 30.days.ago.to_date,
          class: "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>

      <div class="flex-1">
        <%= f.label :end_date, t("dashboard.usage.date_range.end_date"), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.date_field :end_date,
          value: params[:end_date] || Date.today,
          class: "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>

      <div>
        <%= f.submit t("dashboard.usage.date_range.apply_btn"),
          class: "px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <!-- Total Requests -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("dashboard.usage.cards.total_requests") %></h3>
      <div class="p-2 bg-blue-100 dark:bg-blue-900 rounded-lg">
        <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= number_with_delimiter(@total_requests) %></p>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.usage.cards.api_calls_in_period") %></p>
  </div>

  <!-- Average Response Time -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("dashboard.usage.cards.avg_response") %></h3>
      <div class="p-2 bg-green-100 dark:bg-green-900 rounded-lg">
        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @avg_response_time %>ms</p>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.usage.cards.avg_latency") %></p>
  </div>

  <!-- Error Rate -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("dashboard.usage.cards.error_rate") %></h3>
      <div class="p-2 <%= @error_rate > 5 ? 'bg-red-100 dark:bg-red-900' : 'bg-gray-100 dark:bg-gray-700' %> rounded-lg">
        <svg class="h-6 w-6 <%= @error_rate > 5 ? 'text-red-600 dark:text-red-400' : 'text-gray-600 dark:text-gray-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @error_rate %>%</p>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.usage.cards.failed_requests") %></p>
  </div>
</div>

<!-- Usage Over Time Chart -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.usage.charts.usage_over_time") %></h2>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.usage.charts.usage_over_time_sub") %></p>
  </div>
  <div class="p-6">
    <div id="usage-over-time-chart" style="height: 360px;">
      <div class="flex items-center justify-center" style="height: 360px;">
        <div class="text-center">
          <svg class="animate-spin h-8 w-8 text-blue-600 mx-auto mb-2" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <p class="text-sm text-gray-500 dark:text-gray-400"><%= t("dashboard.usage.charts.loading") %></p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Usage by Endpoint -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.usage.charts.by_endpoint") %></h2>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.usage.charts.by_endpoint_sub") %></p>
  </div>
  <div id="usage-by-endpoint-container">
    <div class="flex items-center justify-center p-6" style="min-height: 300px;">
      <div class="text-center">
        <svg class="animate-spin h-8 w-8 text-blue-600 mx-auto mb-2" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <p class="text-sm text-gray-500 dark:text-gray-400"><%= t("dashboard.usage.charts.loading_short") %></p>
      </div>
    </div>
  </div>
</div>

<!-- Recent Requests Table -->
<%= turbo_frame_tag "recent-requests" do %>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between gap-4">
      <div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.usage.table.heading") %></h2>
        <% if @pagy.count > 0 %>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
            <%= t("dashboard.usage.table.showing_info",
              from: @pagy.from,
              to: @pagy.to,
              total: number_with_delimiter(@pagy.count)) %>
          </p>
        <% else %>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.usage.table.subheading") %></p>
        <% end %>
      </div>
      <% if @pagy.pages > 1 %>
        <span class="text-xs text-gray-400 dark:text-gray-500 shrink-0">
          <%= t("dashboard.usage.table.page_of", page: @pagy.page, pages: @pagy.pages) %>
        </span>
      <% end %>
    </div>

    <% if @recent_requests.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700 sticky top-0 z-10">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("dashboard.usage.table.col_time") %></th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("dashboard.usage.table.col_endpoint") %></th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("dashboard.usage.table.col_method") %></th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("dashboard.usage.table.col_status") %></th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("dashboard.usage.table.col_response") %></th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("dashboard.usage.table.col_requests") %></th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("dashboard.usage.table.col_api_key") %></th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% @recent_requests.each do |log| %>
              <tr class="hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                <td class="px-4 py-3 whitespace-nowrap text-sm">
                  <span class="text-gray-900 dark:text-gray-100 font-mono tabular-nums"
                        title="<%= time_ago_in_words(log.used_at) %> ago">
                    <%= log.used_at.strftime("%b %d, %H:%M:%S") %>
                  </span>
                </td>
                <td class="px-4 py-3 text-sm max-w-xs">
                  <code class="text-xs bg-gray-100 dark:bg-gray-700 dark:text-gray-300 px-2 py-1 rounded break-all"><%= log.endpoint %></code>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-sm">
                  <%= render "partials/shared/badge", text: log.request_method.presence || "POST", variant: "default", size: "xs" %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-sm">
                  <% status = log.status_code.to_i %>
                  <% display_status = status > 0 ? status.to_s : "—" %>
                  <% variant = status > 0 ? status_code_variant(status) : "default" %>
                  <%= render "partials/shared/badge", text: display_status, variant: variant, size: "xs" %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-sm">
                  <% ms = log.response_time_ms.to_i %>
                  <span class="<%= ms > 1000 ? 'text-red-600 dark:text-red-400 font-medium' : ms > 500 ? 'text-amber-600 dark:text-amber-400' : 'text-gray-600 dark:text-gray-400' %>">
                    <%= ms > 0 ? "#{ms}ms" : "—" %>
                  </span>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400 tabular-nums">
                  <%= log.credits_used || 1 %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= log.api_key&.name || t("dashboard.usage.table.unknown_key") %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 flex items-center justify-between gap-4">
          <div class="flex items-center gap-1">
            <% prev_page = @pagy.page > 1 ? @pagy.page - 1 : nil %>
            <% next_page = @pagy.page < @pagy.pages ? @pagy.page + 1 : nil %>
            <% if prev_page %>
              <%= link_to dashboard_usage_path(page: prev_page, range: params[:range], start_date: params[:start_date], end_date: params[:end_date]),
                    class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors",
                    data: { turbo_frame: "recent-requests" } do %>
                <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                <%= t("dashboard.usage.table.prev") %>
              <% end %>
            <% else %>
              <span class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-gray-200 dark:border-gray-700 text-gray-300 dark:text-gray-600 cursor-not-allowed">
                <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                <%= t("dashboard.usage.table.prev") %>
              </span>
            <% end %>

            <%# Page number pills — show at most 7 (first, last, current ±2, ellipsis) %>
            <% pages = @pagy.pages
               cur   = @pagy.page
               shown = (([1, cur - 2].max..[cur + 2, pages].min).to_a)
               shown = ([1] + shown).uniq if shown.first > 1
               shown = (shown + [pages]).uniq if shown.last < pages %>
            <% prev_p = nil %>
            <% shown.each do |p| %>
              <% if prev_p && p - prev_p > 1 %>
                <span class="px-1 text-gray-400 dark:text-gray-500 text-sm select-none">…</span>
              <% end %>
              <% if p == cur %>
                <span class="inline-flex items-center justify-center w-10 h-10 text-sm font-semibold rounded-md bg-blue-600 text-white tabular-nums"><%= p %></span>
              <% else %>
                <%= link_to p, dashboard_usage_path(page: p, range: params[:range], start_date: params[:start_date], end_date: params[:end_date]),
                      class: "inline-flex items-center justify-center w-10 h-10 text-sm font-medium rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors tabular-nums",
                      data: { turbo_frame: "recent-requests" } %>
              <% end %>
              <% prev_p = p %>
            <% end %>

            <% if next_page %>
              <%= link_to dashboard_usage_path(page: next_page, range: params[:range], start_date: params[:start_date], end_date: params[:end_date]),
                    class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors",
                    data: { turbo_frame: "recent-requests" } do %>
                <%= t("dashboard.usage.table.next") %>
                <svg class="h-4 w-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              <% end %>
            <% else %>
              <span class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md border border-gray-200 dark:border-gray-700 text-gray-300 dark:text-gray-600 cursor-not-allowed">
                <%= t("dashboard.usage.table.next") %>
                <svg class="h-4 w-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            <% end %>
          </div>

          <p class="text-xs text-gray-400 dark:text-gray-500 tabular-nums">
            <%= t("dashboard.usage.table.showing_info",
              from: @pagy.from,
              to: @pagy.to,
              total: number_with_delimiter(@pagy.count)) %>
          </p>
        </div>
      <% end %>

    <% else %>
      <div class="px-6 py-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100"><%= t("dashboard.usage.table.empty_heading") %></h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><%= t("dashboard.usage.table.empty_body") %></p>
      </div>
    <% end %>
  </div>
<% end %>

<!-- Load Chartkick for charts -->
<%= javascript_include_tag "chartkick", "data-turbo-track": "reload" %>
<%= javascript_include_tag "Chart.bundle", "data-turbo-track": "reload" %>

<script>
  const EMPTY_STATE_CHART = `
    <div class="flex items-center justify-center" style="height: 360px;">
      <div class="text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100"><%= j t("dashboard.usage.charts.no_data_heading") %></h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><%= j t("dashboard.usage.charts.no_data_body") %></p>
      </div>
    </div>`;

  const EMPTY_STATE_ENDPOINTS = `
    <div class="px-6 py-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100"><%= j t("dashboard.usage.charts.no_endpoints_heading") %></h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><%= j t("dashboard.usage.charts.no_endpoints_body") %></p>
    </div>`;

  document.addEventListener('turbo:load', function() {
    // Usage over time chart
    fetch('<%= by_date_dashboard_usage_path(range: params[:range], start_date: params[:start_date], end_date: params[:end_date]) %>')
      .then(response => response.json())
      .then(data => {
        const container = document.getElementById('usage-over-time-chart');
        const hasData = data.requests && Object.keys(data.requests).length > 0;

        if (!hasData) {
          container.innerHTML = EMPTY_STATE_CHART;
          return;
        }

        new Chartkick.LineChart("usage-over-time-chart", [
          {name: "Requests", data: data.requests},
          {name: "Errors", data: data.errors}
        ], {
          colors: ["#3b82f6", "#ef4444"],
          library: {
            scales: {
              y: { beginAtZero: true }
            }
          }
        });
      });

    // Usage by endpoint — rendered as a list like Recent Requests
    fetch('<%= by_endpoint_dashboard_usage_path(range: params[:range], start_date: params[:start_date], end_date: params[:end_date]) %>')
      .then(response => response.json())
      .then(data => {
        const container = document.getElementById('usage-by-endpoint-container');
        const entries = data ? Object.entries(data) : [];

        if (entries.length === 0) {
          container.innerHTML = EMPTY_STATE_ENDPOINTS;
          return;
        }

        const maxCount = Math.max(...entries.map(([, v]) => v));

        const rows = entries.map(([endpoint, count]) => {
          const pct = maxCount > 0 ? ((count / maxCount) * 100).toFixed(1) : 0;
          return `
            <div class="px-6 py-4 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
              <div class="flex items-center justify-between gap-4">
                <code class="text-xs bg-gray-100 dark:bg-gray-700 dark:text-gray-300 px-2 py-1 rounded truncate flex-1 min-w-0">${endpoint}</code>
                <span class="text-sm font-semibold text-gray-900 dark:text-gray-100 shrink-0">${count.toLocaleString()}</span>
              </div>
              <div class="mt-2 w-full bg-gray-100 dark:bg-gray-700 rounded-full h-1.5">
                <div class="bg-blue-500 h-1.5 rounded-full transition-all" style="width: ${pct}%"></div>
              </div>
            </div>`;
        }).join('');

        container.innerHTML = `<div class="divide-y divide-gray-200 dark:divide-gray-700 max-h-[26rem] overflow-y-auto">${rows}</div>`;
      });
  });
</script>
