<% content_for :title, "Dashboard" %>

<!-- Welcome Banner -->
<div class="bg-gradient-to-r from-blue-600 to-indigo-600 rounded-lg shadow-lg p-8 text-white mb-8">
  <h1 class="text-3xl font-bold mb-2">
    Welcome back, <%= current_user.email.split('@').first.titleize %>!
  </h1>
  <p class="text-blue-100">
    Here's your API usage overview for <%= Date.current.strftime("%B %Y") %>
  </p>
</div>

<!-- Quick Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <!-- Current Plan Usage -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Current Usage</h3>
      <%= render "partials/shared/badge", text: @current_plan.titleize, variant: @current_plan == "free" ? "default" : "primary", size: "xs" %>
    </div>

    <div class="mb-2">
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100">
        <%= number_with_delimiter(@usage_this_month) %>
      </p>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
        of <%= number_with_delimiter(@usage_this_month + @credits_remaining) %> requests
      </p>
    </div>

    <!-- Usage Progress Bar -->
    <%
      total_limit = @usage_this_month + @credits_remaining
      usage_percentage = total_limit > 0 ? ((@usage_this_month.to_f / total_limit) * 100).round : 0
      bar_color = if usage_percentage >= 90
        "bg-red-500"
      elsif usage_percentage >= 75
        "bg-yellow-500"
      else
        "bg-blue-500"
      end
    %>
    <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2 mt-3">
      <div class="<%= bar_color %> h-2 rounded-full transition-all" style="width: <%= usage_percentage %>%"></div>
    </div>
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-2"><%= usage_percentage %>% used this month</p>
  </div>

  <!-- Total API Calls -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Requests</h3>
      <div class="p-2 bg-green-100 dark:bg-green-900 rounded-lg">
        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
        </svg>
      </div>
    </div>

    <p class="text-3xl font-bold text-gray-900 dark:text-gray-100">
      <%= number_with_delimiter(@total_requests) %>
    </p>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">All-time requests</p>
  </div>

  <!-- Credits Remaining -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Credits Remaining</h3>
      <div class="p-2 bg-blue-100 dark:bg-blue-900 rounded-lg">
        <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
    </div>

    <p class="text-3xl font-bold text-gray-900 dark:text-gray-100">
      <%= number_with_delimiter(@credits_remaining) %>
    </p>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
      <% if @credits_remaining < 100 %>
        <span class="text-red-600 font-medium">Running low!</span>
      <% else %>
        Available this month
      <% end %>
    </p>
  </div>

  <!-- Average Response Time -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Avg Response Time</h3>
      <div class="p-2 bg-purple-100 dark:bg-purple-900 rounded-lg">
        <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
    </div>

    <p class="text-3xl font-bold text-gray-900 dark:text-gray-100">
      <%= @avg_response_time %>ms
    </p>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Last 7 days average</p>
  </div>
</div>

<!-- Recent Activity & Quick Actions Row -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Recent API Activity (Takes 2 columns) -->
  <div class="lg:col-span-2">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Recent API Activity</h2>
        <%= link_to dashboard_usage_path, class: "text-sm font-medium text-blue-600 hover:text-blue-700" do %>
          View All
          <svg class="inline h-4 w-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>

      <div class="overflow-x-auto">
        <% if @recent_activity.any? %>
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-700">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Time</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Endpoint</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Response</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Credits</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <% @recent_activity.each do |log| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                    <%= time_ago_in_words(log.used_at) %> ago
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-100">
                    <code class="text-xs bg-gray-100 dark:bg-gray-700 dark:text-gray-300 px-2 py-1 rounded"><%= log.endpoint %></code>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm">
                    <%
                      status_color = if log.status_code.to_s.start_with?("2")
                        "success"
                      elsif log.status_code.to_s.start_with?("4")
                        "warning"
                      else
                        "danger"
                      end
                    %>
                    <%= render "partials/shared/badge", text: log.status_code.to_s, variant: status_color, size: "xs" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                    <%= log.response_time_ms || "—" %>ms
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                    <%= log.credits_used || 1 %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="px-6 py-12 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">No activity yet</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by making your first API call.</p>
            <div class="mt-6">
              <%= link_to apis_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Browse API Documentation
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Sidebar Widgets (1 column) -->
  <div class="space-y-6">
    <!-- API Keys Quick View -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold text-gray-900 dark:text-gray-100">API Keys</h3>
        <%= link_to dashboard_api_keys_path, class: "text-sm text-blue-600 hover:text-blue-700 font-medium" do %>
          Manage
        <% end %>
      </div>

      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="h-12 w-12 rounded-full bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
            <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @api_keys_count %></p>
          <p class="text-sm text-gray-600 dark:text-gray-400">Active <%= "key".pluralize(@api_keys_count) %></p>
        </div>
      </div>

      <%= link_to new_dashboard_api_key_path, class: "mt-4 block w-full text-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
        <svg class="inline h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Create New Key
      <% end %>
    </div>

    <!-- Billing Status -->
    <% if current_user.subscription %>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold text-gray-900 dark:text-gray-100">Billing</h3>
          <%= link_to dashboard_billing_path, class: "text-sm text-blue-600 hover:text-blue-700 font-medium" do %>
            Manage
          <% end %>
        </div>

        <div class="space-y-3">
          <div>
            <p class="text-sm text-gray-600 dark:text-gray-300">Current Plan</p>
            <p class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= @current_plan.titleize %></p>
          </div>

          <% if @next_billing_date %>
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-300">Next Billing Date</p>
              <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @next_billing_date.strftime("%B %d, %Y") %></p>
            </div>
          <% end %>
        </div>

        <%= link_to dashboard_billing_path, class: "mt-4 block w-full text-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors" do %>
          View Details
        <% end %>
      </div>
    <% else %>
      <!-- Upgrade CTA -->
      <div class="bg-gradient-to-br from-blue-600 to-indigo-600 rounded-lg shadow p-6 text-white">
        <h3 class="font-semibold mb-2">Upgrade Your Plan</h3>
        <p class="text-sm text-blue-100 mb-4">
          Get more requests, faster rate limits, and priority support.
        </p>
        <%= link_to pricing_path, class: "block w-full text-center px-4 py-2 bg-white text-blue-600 text-sm font-medium rounded-lg hover:bg-blue-50 transition-colors" do %>
          View Pricing
        <% end %>
      </div>
    <% end %>
  </div>
</div>
