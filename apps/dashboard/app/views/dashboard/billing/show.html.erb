<% content_for :title, t("dashboard.billing.title") %>

<!-- Plan Selection Notice -->
<% if params[:plan].present? && valid_plan?(params[:plan]) %>
  <div class="mb-6 bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-500 p-4 rounded-md">
    <div class="flex items-start">
      <svg class="h-6 w-6 text-blue-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h3 class="text-sm font-medium text-blue-800 dark:text-blue-300 mb-1"><%= t("dashboard.billing.plan_notice.heading", plan: params[:plan].titleize) %></h3>
        <p class="text-sm text-blue-700 dark:text-blue-400"><%= t("dashboard.billing.plan_notice.body", plan: params[:plan].titleize) %></p>
      </div>
    </div>
  </div>
<% end %>

<!-- Header -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= t("dashboard.billing.title") %></h1>
  <p class="mt-2 text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.subtitle") %></p>
</div>

<!-- Current Plan Section -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.billing.current_plan.heading") %></h2>
    <%= render "partials/shared/badge",
      text: @plan_info[:name],
      variant: @current_plan == "free" ? "default" : "primary",
      size: "sm" %>
  </div>

  <div class="p-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Plan Details -->
      <div>
        <div class="mb-6">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2">
            <% if @current_plan == "free" %>
              <%= t("dashboard.billing.current_plan.free_label") %>
            <% else %>
              $<%= @plan_info[:price_monthly] %><span class="text-lg text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.current_plan.per_month") %></span>
            <% end %>
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            <% if @subscription %>
              <% if @subscription.cancel_at_period_end %>
                <%= t("dashboard.billing.current_plan.cancels_on", date: @subscription.current_period_end.strftime("%B %d, %Y")) %>
              <% else %>
                <%= t("dashboard.billing.current_plan.renews_on", date: @subscription.current_period_end.strftime("%B %d, %Y")) %>
              <% end %>
            <% else %>
              <%= t("dashboard.billing.current_plan.no_renewal") %>
            <% end %>
          </p>
        </div>

        <!-- Plan Features -->
        <div class="space-y-3 mb-6">
          <% @plan_info[:features].each do |feature| %>
            <div class="flex items-start">
              <svg class="h-5 w-5 text-green-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-gray-700 dark:text-gray-300"><%= feature %></span>
            </div>
          <% end %>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-3">
          <% if @current_plan == "free" %>
            <%= link_to pricing_path, class: "inline-flex items-center justify-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
              <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
              <%= t("dashboard.billing.current_plan.upgrade_btn") %>
            <% end %>
          <% else %>
            <%= button_to dashboard_portal_billing_path, method: :post, data: { turbo: false }, class: "inline-flex items-center justify-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
              <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <%= t("dashboard.billing.current_plan.manage_btn") %>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Usage Stats -->
      <div>
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-4"><%= t("dashboard.billing.usage.heading") %></h3>

        <!-- Usage Bar -->
        <div class="mb-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= number_with_delimiter(@usage_this_period) %></span>
            <span class="text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.usage.of_requests", limit: number_with_delimiter(@plan_info[:requests_per_month])) %></span>
          </div>

          <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-3">
            <%
              bar_color = if @quota_used_percent >= 90
                "bg-red-500"
              elsif @quota_used_percent >= 75
                "bg-yellow-500"
              else
                "bg-blue-500"
              end
            %>
            <div class="<%= bar_color %> h-3 rounded-full transition-all" style="width: <%= [@quota_used_percent, 100].min %>%"></div>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-2"><%= t("dashboard.billing.usage.percent_used", percent: @quota_used_percent) %></p>
        </div>

        <!-- Usage Warning -->
        <% if @quota_used_percent >= 90 %>
          <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-4">
            <div class="flex items-start">
              <svg class="h-5 w-5 text-red-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
              <div class="text-sm text-red-800 dark:text-red-300">
                <p class="font-medium mb-1"><%= t("dashboard.billing.usage.warning_critical_heading") %></p>
                <p><%= t("dashboard.billing.usage.warning_critical_body") %></p>
              </div>
            </div>
          </div>
        <% elsif @quota_used_percent >= 75 %>
          <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-4 mb-4">
            <div class="flex items-start">
              <svg class="h-5 w-5 text-yellow-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
              <div class="text-sm text-yellow-800 dark:text-yellow-300">
                <p class="font-medium mb-1"><%= t("dashboard.billing.usage.warning_moderate_heading") %></p>
                <p><%= t("dashboard.billing.usage.warning_moderate_body", percent: @quota_used_percent) %></p>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Rate Limit Info -->
        <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
          <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"><%= t("dashboard.billing.usage.rate_limit_heading") %></h4>
          <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= number_with_delimiter(@plan_info[:rate_limit_per_minute]) %></p>
          <p class="text-xs text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.billing.usage.rate_limit_unit") %></p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Available Plans -->
<% if @current_plan != "professional" %>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8" data-controller="pricing-toggle">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.billing.upgrade_section.heading") %></h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= t("dashboard.billing.upgrade_section.subtitle") %></p>
    </div>

    <div class="p-6">
      <div class="flex justify-center mb-6">
        <div class="bg-gray-100 dark:bg-gray-700 rounded-lg border border-gray-200 dark:border-gray-600 p-1 inline-flex">
          <button
            type="button"
            data-pricing-toggle-target="monthlyButton"
            data-action="click->pricing-toggle#showMonthly"
            class="px-5 py-1.5 rounded-md text-sm font-medium transition-colors bg-blue-600 text-white">
            <%= t("dashboard.billing.upgrade_section.monthly") %>
          </button>
          <button
            type="button"
            data-pricing-toggle-target="yearlyButton"
            data-action="click->pricing-toggle#showYearly"
            class="px-5 py-1.5 rounded-md text-sm font-medium transition-colors text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-gray-100">
            <%= t("dashboard.billing.upgrade_section.yearly") %>
            <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-300"><%= t("dashboard.billing.upgrade_section.save_percent") %></span>
          </button>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <%
          plan_order = { "free" => 0, "developer" => 1, "business" => 2, "professional" => 3 }
          current_tier = plan_order[@current_plan] || 0
        %>
        <% @available_plans.select { |p| (plan_order[p[:id]] || 0) > current_tier }.each do |plan| %>
          <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6 hover:border-blue-500 transition-colors <%= plan[:id] == 'business' ? 'ring-2 ring-blue-500' : '' %>">
            <% if plan[:id] == "business" %>
              <div class="inline-block px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 text-xs font-semibold rounded-full mb-4">
                <%= t("dashboard.billing.upgrade_section.most_popular") %>
              </div>
            <% else %>
              <div class="invisible inline-block px-3 py-1 text-xs font-semibold rounded-full mb-4">&nbsp;</div>
            <% end %>

            <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2"><%= plan[:name] %></h3>
            <div class="mb-4">
              <div data-pricing-toggle-target="monthlyPrice">
                <span class="text-3xl font-bold text-gray-900 dark:text-gray-100">$<%= plan[:price_monthly] %></span>
                <span class="text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.upgrade_section.per_month") %></span>
                <p class="invisible text-sm mt-1">&nbsp;</p>
              </div>
              <div class="hidden" data-pricing-toggle-target="yearlyPrice">
                <span class="text-3xl font-bold text-gray-900 dark:text-gray-100">$<%= (plan[:price_yearly] / 12.0).round %></span>
                <span class="text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.upgrade_section.per_month") %></span>
                <p class="text-sm text-green-600 dark:text-green-400 mt-1"><%= t("dashboard.billing.upgrade_section.billed_yearly", price: plan[:price_yearly]) %></p>
              </div>
            </div>

            <ul class="space-y-2 mb-6">
              <% plan[:features].first(4).each do |feature| %>
                <li class="flex items-start text-sm">
                  <svg class="h-5 w-5 text-green-500 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-gray-700 dark:text-gray-300"><%= feature %></span>
                </li>
              <% end %>
            </ul>

            <%= form_with url: dashboard_checkout_billing_path, method: :post, data: { turbo: false } do |f| %>
              <%= f.hidden_field :plan, value: plan[:id] %>
              <%= f.hidden_field :billing_cycle, value: "monthly", data: { pricing_toggle_target: "billingCycleInput" } %>
              <%= f.submit t("dashboard.billing.upgrade_section.upgrade_btn", plan: plan[:name]), class: "block w-full text-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors cursor-pointer" %>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="mt-6 text-center">
        <%= link_to pricing_path, class: "text-blue-600 hover:text-blue-700 font-medium" do %>
          <%= t("dashboard.billing.upgrade_section.view_all") %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<!-- Billing Information -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <!-- Payment Method -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.billing.payment.heading") %></h2>
    </div>

    <div class="p-6">
      <% if @subscription && @current_plan != "free" %>
        <div class="flex items-center mb-4">
          <div class="flex-shrink-0 h-12 w-12 bg-gray-100 dark:bg-gray-700 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= t("dashboard.billing.payment.managed_by") %></p>
            <p class="text-xs text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.payment.secure_processing") %></p>
          </div>
        </div>

        <%= button_to dashboard_portal_billing_path,
          method: :post,
          data: { turbo: false },
          class: "block w-full text-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors" do %>
          <%= t("dashboard.billing.payment.update_btn") %>
        <% end %>
      <% else %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
          <p class="text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.payment.none_heading") %></p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1"><%= t("dashboard.billing.payment.none_hint") %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Billing History -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.billing.history.heading") %></h2>
    </div>

    <div class="p-6">
      <% if @subscription && @current_plan != "free" %>
        <div class="divide-y divide-gray-100 dark:divide-gray-700">
          <div class="flex items-center justify-between py-3">
            <span class="text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.history.plan_label") %></span>
            <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @plan_info[:name] %></span>
          </div>
          <div class="flex items-center justify-between py-3">
            <span class="text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.history.status_label") %></span>
            <span class="text-sm font-medium <%= @subscription.status == 'active' ? 'text-green-600 dark:text-green-400' : 'text-yellow-600 dark:text-yellow-400' %>">
              <%= @subscription.status&.titleize %>
            </span>
          </div>
          <% if @subscription.current_period_start %>
            <div class="flex items-center justify-between py-3">
              <span class="text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.history.period_started") %></span>
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @subscription.current_period_start.strftime("%b %d, %Y") %></span>
            </div>
          <% end %>
          <% if @subscription.current_period_end %>
            <div class="flex items-center justify-between py-3">
              <span class="text-sm text-gray-600 dark:text-gray-400"><%= @subscription.cancel_at_period_end? ? t("dashboard.billing.history.cancels_on") : t("dashboard.billing.history.renews_on") %></span>
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @subscription.current_period_end.strftime("%b %d, %Y") %></span>
            </div>
          <% end %>
          <div class="pt-4">
            <p class="text-xs text-gray-500 dark:text-gray-400"><%= t("dashboard.billing.history.portal_note") %></p>
          </div>
        </div>
      <% else %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <p class="text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.history.none_heading") %></p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1"><%= t("dashboard.billing.history.none_hint") %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- FAQ Section -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow mt-8">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("dashboard.billing.faq.heading") %></h2>
  </div>

  <div class="p-6">
    <div class="space-y-4">
      <div>
        <h3 class="text-sm font-medium text-gray-900 dark:text-gray-100 mb-1"><%= t("dashboard.billing.faq.q1_heading") %></h3>
        <p class="text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.faq.q1_body") %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-900 dark:text-gray-100 mb-1"><%= t("dashboard.billing.faq.q2_heading") %></h3>
        <p class="text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.faq.q2_body") %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-900 dark:text-gray-100 mb-1"><%= t("dashboard.billing.faq.q3_heading") %></h3>
        <p class="text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.faq.q3_body") %></p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-900 dark:text-gray-100 mb-1"><%= t("dashboard.billing.faq.q4_heading") %></h3>
        <p class="text-sm text-gray-600 dark:text-gray-400"><%= t("dashboard.billing.faq.q4_body") %></p>
      </div>
    </div>
  </div>
</div>
