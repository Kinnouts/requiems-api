<% content_for :title, "Billing & Subscription" %>

<!-- Plan Selection Notice -->
<% if params[:plan].present? && valid_plan?(params[:plan]) %>
  <div class="mb-6 bg-blue-50 border-l-4 border-blue-500 p-4 rounded-md">
    <div class="flex items-start">
      <svg class="h-6 w-6 text-blue-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h3 class="text-sm font-medium text-blue-800 mb-1">Ready to upgrade to <%= params[:plan].titleize %>?</h3>
        <p class="text-sm text-blue-700">Scroll down to see the <%= params[:plan].titleize %> plan details and start your 7-day free trial!</p>
      </div>
    </div>
  </div>
<% end %>

<!-- Header -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Billing & Subscription</h1>
  <p class="mt-2 text-sm text-gray-600">Manage your plan, payment method, and billing history</p>
</div>

<!-- Current Plan Section -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-900">Current Plan</h2>
    <%= render "partials/shared/badge",
      text: @plan_info[:name],
      variant: @current_plan == "free" ? "default" : "primary",
      size: "sm" %>
  </div>

  <div class="p-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Plan Details -->
      <div>
        <div class="mb-6">
          <h3 class="text-2xl font-bold text-gray-900 mb-2">
            <% if @current_plan == "free" %>
              Free Plan
            <% else %>
              $<%= @plan_info[:price_monthly] %><span class="text-lg text-gray-600">/month</span>
            <% end %>
          </h3>
          <p class="text-sm text-gray-600">
            <% if @subscription %>
              <% if @subscription.cancel_at_period_end %>
                Cancels on <%= @subscription.current_period_end.strftime("%B %d, %Y") %>
              <% else %>
                Renews on <%= @subscription.current_period_end.strftime("%B %d, %Y") %>
              <% end %>
            <% else %>
              No renewal - Free plan
            <% end %>
          </p>
        </div>

        <!-- Plan Features -->
        <div class="space-y-3 mb-6">
          <% @plan_info[:features].each do |feature| %>
            <div class="flex items-start">
              <svg class="h-5 w-5 text-green-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-gray-700"><%= feature %></span>
            </div>
          <% end %>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-3">
          <% if @current_plan == "free" %>
            <%= link_to pricing_path, class: "inline-flex items-center justify-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
              <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
              Upgrade Plan
            <% end %>
          <% else %>
            <%= link_to dashboard_portal_billing_path, method: :post, class: "inline-flex items-center justify-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
              <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Manage Subscription
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Usage Stats -->
      <div>
        <h3 class="text-sm font-medium text-gray-700 mb-4">Usage This Period</h3>

        <!-- Usage Bar -->
        <div class="mb-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@usage_this_period) %></span>
            <span class="text-sm text-gray-600">of <%= number_with_delimiter(@plan_info[:requests_per_month]) %> requests</span>
          </div>

          <div class="w-full bg-gray-200 rounded-full h-3">
            <%
              bar_color = if @quota_used_percent >= 90
                "bg-red-500"
              elsif @quota_used_percent >= 75
                "bg-yellow-500"
              else
                "bg-blue-500"
              end
            %>
            <div class="<%= bar_color %> h-3 rounded-full transition-all" style="width: <%= [@quota_used_percent, 100].min %>%"></div>
          </div>
          <p class="text-xs text-gray-500 mt-2"><%= @quota_used_percent %>% used</p>
        </div>

        <!-- Usage Warning -->
        <% if @quota_used_percent >= 90 %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
            <div class="flex items-start">
              <svg class="h-5 w-5 text-red-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
              <div class="text-sm text-red-800">
                <p class="font-medium mb-1">Running low on requests!</p>
                <p>You're approaching your monthly limit. Consider upgrading to avoid service interruption.</p>
              </div>
            </div>
          </div>
        <% elsif @quota_used_percent >= 75 %>
          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-4">
            <div class="flex items-start">
              <svg class="h-5 w-5 text-yellow-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
              <div class="text-sm text-yellow-800">
                <p class="font-medium mb-1">Heads up!</p>
                <p>You've used <%= @quota_used_percent %>% of your monthly quota. You may want to upgrade soon.</p>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Rate Limit Info -->
        <div class="bg-gray-50 rounded-lg p-4">
          <h4 class="text-sm font-medium text-gray-700 mb-2">Rate Limit</h4>
          <p class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@plan_info[:rate_limit_per_minute]) %></p>
          <p class="text-xs text-gray-600 mt-1">requests per minute</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Available Plans -->
<% if @current_plan != "professional" %>
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Upgrade Your Plan</h2>
      <p class="text-sm text-gray-600 mt-1">Choose a plan that fits your needs</p>
    </div>

    <div class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @available_plans.reject { |p| p[:id] == "free" || p[:id] == @current_plan }.each do |plan| %>
          <div class="border border-gray-200 rounded-lg p-6 hover:border-blue-500 transition-colors <%= plan[:id] == 'business' ? 'ring-2 ring-blue-500' : '' %>">
            <% if plan[:id] == "business" %>
              <div class="inline-block px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold rounded-full mb-4">
                Most Popular
              </div>
            <% end %>

            <h3 class="text-xl font-bold text-gray-900 mb-2"><%= plan[:name] %></h3>
            <div class="mb-4">
              <span class="text-3xl font-bold text-gray-900">$<%= plan[:price_monthly] %></span>
              <span class="text-gray-600">/month</span>
              <p class="text-sm text-gray-600 mt-1">
                or $<%= (plan[:price_yearly] / 12.0).round %>/month billed yearly
              </p>
            </div>

            <ul class="space-y-2 mb-6">
              <% plan[:features].first(4).each do |feature| %>
                <li class="flex items-start text-sm">
                  <svg class="h-5 w-5 text-green-500 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-gray-700"><%= feature %></span>
                </li>
              <% end %>
            </ul>

            <%= link_to dashboard_checkout_billing_path(plan: plan[:id], billing_cycle: "monthly"),
              method: :post,
              class: "block w-full text-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
              Upgrade to <%= plan[:name] %>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="mt-6 text-center">
        <%= link_to pricing_path, class: "text-blue-600 hover:text-blue-700 font-medium" do %>
          View all plans and pricing details →
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<!-- Billing Information -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <!-- Payment Method -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Payment Method</h2>
    </div>

    <div class="p-6">
      <% if @subscription && @current_plan != "free" %>
        <div class="flex items-center mb-4">
          <div class="flex-shrink-0 h-12 w-12 bg-gray-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-900">Managed by LemonSqueezy</p>
            <p class="text-xs text-gray-600">Secure payment processing</p>
          </div>
        </div>

        <%= link_to dashboard_portal_billing_path,
          method: :post,
          class: "block w-full text-center px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors" do %>
          Update Payment Method
        <% end %>
      <% else %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
          <p class="text-sm text-gray-600">No payment method on file</p>
          <p class="text-xs text-gray-500 mt-1">Upgrade to add a payment method</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Billing History -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Billing History</h2>
    </div>

    <div class="p-6">
      <% if @subscription && @current_plan != "free" %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <p class="text-sm text-gray-600 mb-4">View your invoices and receipts</p>
          <%= link_to dashboard_portal_billing_path,
            method: :post,
            class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
            View Billing History
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <p class="text-sm text-gray-600">No billing history</p>
          <p class="text-xs text-gray-500 mt-1">Invoices will appear here after your first payment</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- FAQ Section -->
<div class="bg-white rounded-lg shadow mt-8">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Billing FAQ</h2>
  </div>

  <div class="p-6">
    <div class="space-y-4">
      <div>
        <h3 class="text-sm font-medium text-gray-900 mb-1">When will I be charged?</h3>
        <p class="text-sm text-gray-600">You'll be charged at the beginning of each billing period. Your first charge happens when you upgrade to a paid plan.</p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-900 mb-1">Can I cancel anytime?</h3>
        <p class="text-sm text-gray-600">Yes! You can cancel your subscription at any time. You'll continue to have access until the end of your current billing period.</p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-900 mb-1">What happens if I exceed my quota?</h3>
        <p class="text-sm text-gray-600">API requests will be rejected with a 429 status code. You can upgrade your plan to increase your quota immediately.</p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-900 mb-1">Do unused requests roll over?</h3>
        <p class="text-sm text-gray-600">No, unused requests do not roll over to the next billing period. Your quota resets at the start of each period.</p>
      </div>
    </div>
  </div>
</div>
