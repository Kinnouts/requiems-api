<%
  # Modal/dialog component
  # Usage:
  #   <%= render "shared/modal", id: "confirm-delete", title: "Confirm Delete" do %>
  #     <p>Are you sure?</p>
  #   <% end %>

  id ||= "modal"
  title ||= ""
  size ||= "md"  # sm, md, lg, xl

  # Size classes
  sizes = {
    "sm" => "max-w-md",
    "md" => "max-w-lg",
    "lg" => "max-w-2xl",
    "xl" => "max-w-4xl"
  }

  size_class = sizes[size] || sizes["md"]
%>

<div
  id="<%= id %>"
  class="hidden fixed inset-0 z-50 overflow-y-auto"
  data-controller="modal"
  data-modal-backdrop-class="opacity-100"
  aria-labelledby="<%= id %>-title"
  role="dialog"
  aria-modal="true"
>
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" data-action="click->modal#close"></div>

  <!-- Modal panel -->
  <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
    <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full <%= size_class %>">
      <!-- Header -->
      <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
        <div class="flex items-start justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-900" id="<%= id %>-title">
            <%= title %>
          </h3>
          <button
            type="button"
            class="rounded-md bg-white text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
            data-action="click->modal#close"
          >
            <span class="sr-only">Close</span>
            <span class="text-2xl">&times;</span>
          </button>
        </div>

        <!-- Content -->
        <div class="mt-2">
          <%= yield %>
        </div>
      </div>

      <!-- Footer (if provided) -->
      <% if defined?(footer) && footer.present? %>
        <div class="bg-gray-50 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6">
          <%= footer %>
        </div>
      <% end %>
    </div>
  </div>
</div>
