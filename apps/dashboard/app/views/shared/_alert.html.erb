<%
  # Alert/notification component
  # Usage:
  #   <%= render "shared/alert", message: "Success!", variant: "success", dismissible: true %>

  message ||= ""
  title ||= nil
  variant ||= "info"
  dismissible ||= false
  class_names ||= ""

  # Base styles
  base = "rounded-lg p-4"

  # Variant styles
  variants = {
    "success" => "bg-green-50 border border-green-200 text-green-800",
    "error" => "bg-red-50 border border-red-200 text-red-800",
    "warning" => "bg-yellow-50 border border-yellow-200 text-yellow-800",
    "info" => "bg-blue-50 border border-blue-200 text-blue-800"
  }

  # Icon colors
  icon_colors = {
    "success" => "text-green-400",
    "error" => "text-red-400",
    "warning" => "text-yellow-400",
    "info" => "text-blue-400"
  }

  classes = [base, variants[variant], class_names].compact.join(" ")
  icon_class = icon_colors[variant]

  # Icons (using Unicode symbols for simplicity)
  icons = {
    "success" => "✓",
    "error" => "✕",
    "warning" => "⚠",
    "info" => "ℹ"
  }
%>

<div class="<%= classes %>" <%= 'data-controller="alert"' if dismissible %>>
  <div class="flex items-start">
    <div class="flex-shrink-0">
      <span class="<%= icon_class %> text-xl"><%= icons[variant] %></span>
    </div>

    <div class="ml-3 flex-1">
      <% if title.present? %>
        <h3 class="text-sm font-medium mb-1">
          <%= title %>
        </h3>
      <% end %>

      <div class="text-sm">
        <%= message %>
      </div>
    </div>

    <% if dismissible %>
      <div class="ml-auto pl-3">
        <button type="button" class="-mx-1.5 -my-1.5 rounded-lg p-1.5 inline-flex hover:bg-opacity-20 focus:outline-none" data-action="click->alert#dismiss">
          <span class="sr-only">Dismiss</span>
          <span class="text-lg">×</span>
        </button>
      </div>
    <% end %>
  </div>
</div>
