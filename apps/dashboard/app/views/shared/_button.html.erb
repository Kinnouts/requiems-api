<%
  # Reusable button component with variants
  # Usage: render "shared/button", text: "Click me", variant: "primary"

  btn_text = local_assigns.fetch(:text, "Button")
  btn_variant = local_assigns.fetch(:variant, "primary")
  btn_size = local_assigns.fetch(:size, "md")
  btn_type = local_assigns.fetch(:type, "button")
  btn_href = local_assigns.fetch(:href, nil)
  btn_extra_classes = local_assigns.fetch(:class_names, "")
  btn_disabled = local_assigns.fetch(:disabled, false)
  btn_data = local_assigns.fetch(:data, {})

  # Base styles
  btn_base = "inline-flex items-center justify-center font-medium rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"

  # Size variants
  btn_sizes = {
    "xs" => "px-2.5 py-1.5 text-xs",
    "sm" => "px-3 py-2 text-sm",
    "md" => "px-4 py-2 text-sm",
    "lg" => "px-5 py-3 text-base",
    "xl" => "px-6 py-3.5 text-base"
  }

  # Color variants
  btn_variants = {
    "primary" => "bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500",
    "secondary" => "bg-gray-600 text-white hover:bg-gray-700 focus:ring-gray-500",
    "success" => "bg-green-600 text-white hover:bg-green-700 focus:ring-green-500",
    "danger" => "bg-red-600 text-white hover:bg-red-700 focus:ring-red-500",
    "warning" => "bg-yellow-600 text-white hover:bg-yellow-700 focus:ring-yellow-500",
    "outline" => "bg-white border-2 border-gray-300 text-gray-700 hover:bg-gray-50 focus:ring-gray-500",
    "outline-primary" => "bg-white border-2 border-blue-600 text-blue-600 hover:bg-blue-50 focus:ring-blue-500",
    "ghost" => "bg-transparent text-gray-700 hover:bg-gray-100 focus:ring-gray-500",
    "link" => "bg-transparent text-blue-600 hover:underline focus:ring-blue-500"
  }

  btn_classes = [btn_base, btn_sizes[btn_size], btn_variants[btn_variant], btn_extra_classes].reject(&:blank?).join(" ")
  btn_data_attrs = btn_data.map { |k, v| "data-#{k}=\"#{v}\"" }.join(" ")
%>

<% if btn_href.present? %>
  <%= link_to btn_href, class: btn_classes, data: btn_data do %>
    <%= btn_text %>
  <% end %>
<% else %>
  <button type="<%= btn_type %>" class="<%= btn_classes %>" <%= "disabled" if btn_disabled %> <%= btn_data_attrs.html_safe %>>
    <%= btn_text %>
  </button>
<% end %>
