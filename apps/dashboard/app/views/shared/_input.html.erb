<%
  # Form input component
  # Usage:
  #   <%= render "shared/input", name: "email", label: "Email Address", type: "email", required: true %>

  name ||= ""
  label ||= nil
  type ||= "text"
  placeholder ||= ""
  value ||= ""
  required ||= false
  disabled ||= false
  error ||= nil
  hint ||= nil
  class_names ||= ""
  autocomplete ||= nil

  # Input ID
  input_id = name.gsub(/[\[\]]/, '_').gsub(/__/, '_').gsub(/_$/, '')

  # Base input styles
  base_input = "block w-full rounded-lg border shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm"

  # Error state
  if error.present?
    input_class = "#{base_input} border-red-300 text-red-900 placeholder-red-300 focus:ring-red-500 focus:border-red-500"
  else
    input_class = "#{base_input} border-gray-300"
  end

  input_class = [input_class, class_names].compact.join(" ")
%>

<div>
  <% if label.present? %>
    <label for="<%= input_id %>" class="block text-sm font-medium text-gray-700 mb-1">
      <%= label %>
      <% if required %>
        <span class="text-red-500">*</span>
      <% end %>
    </label>
  <% end %>

  <% if hint.present? && error.blank? %>
    <p class="text-sm text-gray-500 mb-2"><%= hint %></p>
  <% end %>

  <input
    type="<%= type %>"
    name="<%= name %>"
    id="<%= input_id %>"
    class="<%= input_class %>"
    placeholder="<%= placeholder %>"
    value="<%= value %>"
    <%= "required" if required %>
    <%= "disabled" if disabled %>
    <%= "autocomplete=\"#{autocomplete}\"" if autocomplete.present? %>
  />

  <% if error.present? %>
    <p class="mt-2 text-sm text-red-600">
      <%= error %>
    </p>
  <% end %>
</div>
