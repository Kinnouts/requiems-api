<nav class="bg-white border-b border-gray-200 sticky top-0 z-40" data-controller="dropdown">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <!-- Left side: Logo and navigation -->
      <div class="flex">
        <!-- Logo -->
        <div class="flex-shrink-0 flex items-center">
          <%= link_to root_path, class: "flex items-center space-x-2" do %>
            <span class="text-2xl font-bold text-blue-600">Requiems</span>
            <span class="text-sm font-medium text-gray-500">API</span>
          <% end %>
        </div>

        <!-- Desktop navigation -->
        <div class="hidden sm:ml-8 sm:flex sm:space-x-8">
          <!-- APIs dropdown -->
          <div class="relative" data-controller="dropdown">
            <button
              type="button"
              class="inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-900 hover:text-blue-600 transition-colors"
              data-action="click->dropdown#toggle"
            >
              APIs
              <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <!-- Dropdown menu -->
            <div
              data-dropdown-target="menu"
              class="hidden absolute left-0 mt-2 w-56 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5"
            >
              <div class="py-1">
                <%= link_to "API Directory", apis_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                <%= link_to "Email APIs", apis_path(category: "email"), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                <%= link_to "Text APIs", apis_path(category: "text"), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                <div class="border-t border-gray-100"></div>
                <%= link_to "Browse All APIs", apis_path, class: "block px-4 py-2 text-sm text-blue-600 hover:bg-gray-100 font-medium" %>
              </div>
            </div>
          </div>

          <%= link_to "Examples", "#", class: "inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-900 hover:text-blue-600 transition-colors" %>
          <%= link_to "Pricing", pricing_path, class: "inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-900 hover:text-blue-600 transition-colors" %>
          <%= link_to "Docs", "#", class: "inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-900 hover:text-blue-600 transition-colors" %>

          <!-- Open Source badge -->
          <a
            href="https://github.com/bobadilla-tech/requiems-api"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-900 hover:text-blue-600 transition-colors"
          >
            <svg class="h-5 w-5 mr-1" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            Open Source
          </a>
        </div>
      </div>

      <!-- Right side: CTA buttons -->
      <div class="hidden sm:ml-6 sm:flex sm:items-center sm:space-x-4">
        <% if user_signed_in? %>
          <!-- User menu -->
          <div class="relative" data-controller="dropdown">
            <button
              type="button"
              class="flex items-center space-x-2 text-sm font-medium text-gray-700 hover:text-gray-900"
              data-action="click->dropdown#toggle"
            >
              <span><%= current_user.email %></span>
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <!-- Dropdown menu -->
            <div
              data-dropdown-target="menu"
              class="hidden absolute right-0 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5"
            >
              <div class="py-1">
                <%= link_to "Dashboard", dashboard_root_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                <%= link_to "API Keys", dashboard_api_keys_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                <%= link_to "Usage", dashboard_usage_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                <%= link_to "Settings", dashboard_settings_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                <div class="border-t border-gray-100"></div>
                <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100" %>
              </div>
            </div>
          </div>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, class: "text-gray-700 hover:text-gray-900 font-medium" %>
          <%= link_to "Get Started", new_user_registration_path, class: "ml-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors" %>
        <% end %>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center sm:hidden">
        <button
          type="button"
          class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100"
          data-controller="dropdown"
          data-action="click->dropdown#toggle"
        >
          <span class="sr-only">Open main menu</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div class="sm:hidden hidden" data-dropdown-target="menu">
    <div class="pt-2 pb-3 space-y-1">
      <%= link_to "API Directory", "#", class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:bg-gray-50" %>
      <%= link_to "Examples", "#", class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:bg-gray-50" %>
      <%= link_to "Pricing", pricing_path, class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:bg-gray-50" %>
      <%= link_to "Docs", "#", class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:bg-gray-50" %>

      <% if user_signed_in? %>
        <div class="border-t border-gray-200 mt-2 pt-2">
          <%= link_to "Dashboard", dashboard_root_path, class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:bg-gray-50" %>
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "block w-full text-left pl-3 pr-4 py-2 text-base font-medium text-red-600 hover:bg-gray-50" %>
        </div>
      <% else %>
        <div class="border-t border-gray-200 mt-2 pt-2">
          <%= link_to "Sign In", new_user_session_path, class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-700 hover:bg-gray-50" %>
          <%= link_to "Get Started", new_user_registration_path, class: "block pl-3 pr-4 py-2 text-base font-medium text-blue-600 hover:bg-gray-50" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
