<nav class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 sticky top-0 z-50">
  <div class="w-full px-4 sm:px-6 lg:px-8">
    <div class="flex items-center h-16 w-full">

      <!-- Left: Logo -->
      <div class="flex-shrink-0 pl-2 sm:pl-4">
        <%= link_to root_path, class: "flex items-center space-x-2" do %>
          <span class="logo-circle">
            <%= image_tag "logo.png", alt: "Requiems API Logo", class: "h-6 w-auto" %>
          </span>
          <span class="text-2xl font-bold text-blue-600">Requiems</span>
          <span class="text-sm font-medium text-gray-500 dark:text-gray-400">API</span>
        <% end %>
      </div>

      <!-- Right: Search + Navigation + Auth (Desktop only, ≥768px) -->
      <div class="hidden md:flex items-center space-x-6 ml-auto">
        <!-- Search Bar -->
        <%= render 'partials/navbar/search' %>

        <!-- Theme Toggle -->
        <div data-controller="theme">
          <button type="button"
                  data-action="click->theme#toggle"
                  class="p-2 rounded-lg text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                  aria-label="Toggle dark mode">
            <span data-theme-target="moon">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
              </svg>
            </span>
            <span data-theme-target="sun" class="hidden">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </span>
          </button>
        </div>

        <!-- Navigation Links -->
        <%= link_to t("shared.nav.apis"), apis_path, class: "text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
        <%= link_to t("shared.nav.examples"), examples_path, class: "text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
        <%= link_to t("shared.nav.pricing"), pricing_path, class: "text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>

        <!-- Auth Buttons -->
        <% if user_signed_in? %>
          <!-- User Dropdown Menu -->
          <div class="relative" data-controller="dropdown">
            <button type="button"
                    class="flex items-center space-x-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                    data-action="click->dropdown#toggle">
              <span><%= current_user.display_name %></span>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <div data-dropdown-target="menu"
                 class="hidden absolute right-0 mt-2 w-56 rounded-lg shadow-lg bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 dark:ring-gray-700 overflow-hidden z-50">
              <div class="py-1">
                <%= link_to dashboard_root_path, class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" do %>
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                    <%= t("shared.nav.dashboard") %>
                  </span>
                <% end %>
                <%= link_to dashboard_api_keys_path, class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" do %>
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                    </svg>
                    <%= t("shared.nav.api_keys") %>
                  </span>
                <% end %>
                <%= link_to dashboard_usage_path, class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" do %>
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    <%= t("shared.nav.usage") %>
                  </span>
                <% end %>
                <%= link_to dashboard_settings_path, class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" do %>
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <%= t("shared.nav.settings") %>
                  </span>
                <% end %>
                <div class="border-t border-gray-100 dark:border-gray-700 my-1"></div>
                <%= button_to destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-gray-50 dark:hover:bg-gray-700" do %>
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    <%= t("shared.nav.sign_out") %>
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <%= link_to t("shared.nav.sign_in"), new_user_session_path, class: "text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors" %>
          <%= link_to t("shared.nav.sign_up"), new_user_registration_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors" %>
        <% end %>
      </div>

      <!-- Mobile: Hamburger Menu (<768px) -->
      <div class="flex items-center md:hidden ml-auto">
        <!-- Mobile Menu Button -->
        <div data-controller="dropdown">
          <button type="button"
                  class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                  data-action="click->dropdown#toggle">
            <span class="sr-only"><%= t("shared.nav.open_menu") %></span>
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

          <!-- Mobile Menu Dropdown -->
          <div data-dropdown-target="menu"
               class="hidden absolute top-16 left-0 right-0 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 shadow-lg z-50">
            <div class="px-4 py-3 space-y-3">
              <!-- Mobile Search Bar -->
              <div class="pb-2" data-controller="navbar-search" data-navbar-search-search-data-value="<%= global_search_data.to_json %>">
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                  </div>
                  <input type="text"
                         data-navbar-search-target="input"
                         data-action="input->navbar-search#search keydown->navbar-search#handleKeydown"
                         placeholder="<%= t("shared.nav.search_placeholder") %>"
                         class="block w-full pl-10 pr-10 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500
                                focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                         autocomplete="off"
                         spellcheck="false">

                  <!-- Clear Button -->
                  <button type="button"
                          data-action="click->navbar-search#clear"
                          class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  </button>
                </div>

                <!-- Mobile Dropdown Results -->
                <div data-navbar-search-target="dropdown"
                     class="hidden mt-2 bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 overflow-hidden max-h-96 overflow-y-auto">
                  <!-- Results Container -->
                  <div data-navbar-search-target="results"></div>

                  <!-- Empty State -->
                  <div data-navbar-search-target="empty" class="hidden px-4 py-6 text-center">
                    <svg class="mx-auto h-10 w-10 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100"><%= t("shared.nav.search_no_results") %></h3>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400"><%= t("shared.nav.search_try_different") %></p>
                  </div>
                </div>
              </div>

              <!-- Navigation Links -->
              <%= link_to t("shared.nav.apis"), apis_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" %>
              <%= link_to t("shared.nav.examples"), examples_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" %>
              <%= link_to t("shared.nav.pricing"), pricing_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" %>

              <!-- Theme Toggle (Mobile) -->
              <div class="border-t border-gray-200 dark:border-gray-700 pt-3" data-controller="theme">
                <button type="button"
                        data-action="click->theme#toggle"
                        class="flex items-center w-full px-3 py-2 rounded-lg text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                  <span data-theme-target="moon" class="flex items-center">
                    <svg class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                    </svg>
                    <%= t("shared.nav.dark_mode") %>
                  </span>
                  <span data-theme-target="sun" class="hidden items-center">
                    <svg class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                    <%= t("shared.nav.light_mode") %>
                  </span>
                </button>
              </div>

              <!-- Locale Switcher (Mobile) -->
              <div class="border-t border-gray-200 dark:border-gray-700 pt-3">
                <p class="px-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2"><%= t("shared.nav.language") %></p>
                <div class="flex space-x-2 px-3">
                  <%= button_to switch_locale_path, method: :post, params: { locale: "en" },
                      class: "flex-1 text-center px-3 py-2 rounded-lg text-sm font-medium transition-colors #{I18n.locale == :en ? 'bg-blue-600 text-white' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700'}" do %>English<% end %>
                  <%= button_to switch_locale_path, method: :post, params: { locale: "es" },
                      class: "flex-1 text-center px-3 py-2 rounded-lg text-sm font-medium transition-colors #{I18n.locale == :es ? 'bg-blue-600 text-white' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700'}" do %>Español<% end %>
                </div>
              </div>

              <% if user_signed_in? %>
                <div class="border-t border-gray-200 dark:border-gray-700 my-2 pt-2">
                  <%= link_to t("shared.nav.dashboard"), dashboard_root_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" %>
                  <%= link_to t("shared.nav.api_keys"), dashboard_api_keys_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" %>
                  <%= link_to t("shared.nav.usage"), dashboard_usage_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" %>
                  <%= button_to t("shared.nav.sign_out"), destroy_user_session_path, method: :delete, class: "block w-full text-left px-3 py-2 rounded-lg text-base font-medium text-red-600 dark:text-red-400 hover:bg-gray-50 dark:hover:bg-gray-700" %>
                </div>
              <% else %>
                <div class="border-t border-gray-200 dark:border-gray-700 my-2 pt-2">
                  <%= link_to t("shared.nav.sign_in"), new_user_session_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700" %>
                  <%= link_to t("shared.nav.get_started"), new_user_registration_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-blue-600 hover:bg-gray-50 dark:hover:bg-gray-700" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>
