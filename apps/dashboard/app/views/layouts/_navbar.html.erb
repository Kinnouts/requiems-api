<nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center h-16 w-full">

      <!-- Left: Logo -->
      <div class="flex-shrink-0 -ml-4 sm:-ml-6 lg:-ml-8">
        <%= link_to root_path, class: "flex items-center space-x-2" do %>
          <span class="text-2xl font-bold text-blue-600">Requiems</span>
          <span class="text-sm font-medium text-gray-500">API</span>
        <% end %>
      </div>

      <!-- Right: Search + Navigation + Auth (Desktop only, ≥768px) -->
      <div class="hidden md:flex items-center space-x-6 ml-auto">
        <!-- Search Bar -->
        <%= render 'partials/navbar/search' %>

        <!-- Navigation Links -->
        <%= link_to "APIs", apis_path, class: "text-sm font-medium text-gray-700 hover:text-blue-600 transition-colors" %>
        <%= link_to "Examples", examples_path, class: "text-sm font-medium text-gray-700 hover:text-blue-600 transition-colors" %>
        <%= link_to "Pricing", pricing_path, class: "text-sm font-medium text-gray-700 hover:text-blue-600 transition-colors" %>

        <!-- Auth Buttons -->
        <% if user_signed_in? %>
          <!-- User Dropdown Menu -->
          <div class="relative" data-controller="dropdown">
            <button type="button"
                    class="flex items-center space-x-2 text-sm font-medium text-gray-700 hover:text-gray-900 px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors"
                    data-action="click->dropdown#toggle">
              <span><%= current_user.email %></span>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <div data-dropdown-target="menu"
                 class="hidden absolute right-0 mt-2 w-56 rounded-lg shadow-lg bg-white ring-1 ring-black ring-opacity-5 overflow-hidden z-50">
              <div class="py-1">
                <%= link_to dashboard_root_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" do %>
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                    Dashboard
                  </span>
                <% end %>
                <%= link_to dashboard_api_keys_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" do %>
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                    </svg>
                    API Keys
                  </span>
                <% end %>
                <%= link_to dashboard_usage_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" do %>
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    Usage
                  </span>
                <% end %>
                <%= link_to dashboard_settings_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" do %>
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Settings
                  </span>
                <% end %>
                <div class="border-t border-gray-100 my-1"></div>
                <%= button_to destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-50" do %>
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Sign Out
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors" %>
          <%= link_to "Sign Up", new_user_registration_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors" %>
        <% end %>
      </div>

      <!-- Mobile: Hamburger Menu (<768px) -->
      <div class="flex items-center md:hidden ml-auto">
        <!-- Mobile Menu Button -->
        <div data-controller="dropdown">
          <button type="button"
                  class="p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors"
                  data-action="click->dropdown#toggle">
            <span class="sr-only">Open main menu</span>
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

          <!-- Mobile Menu Dropdown -->
          <div data-dropdown-target="menu"
               class="hidden absolute top-16 left-0 right-0 bg-white border-b border-gray-200 shadow-lg z-50">
            <div class="px-4 py-3 space-y-3">
              <!-- Mobile Search Bar -->
              <div class="pb-2" data-controller="navbar-search" data-navbar-search-search-data-value="<%= global_search_data.to_json %>">
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                  </div>
                  <input type="text"
                         data-navbar-search-target="input"
                         data-action="input->navbar-search#search keydown->navbar-search#handleKeydown"
                         placeholder="Search APIs, examples, docs..."
                         class="block w-full pl-10 pr-10 py-2.5 text-sm border border-gray-300 rounded-lg bg-white placeholder-gray-400
                                focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
                         autocomplete="off"
                         spellcheck="false">

                  <!-- Clear Button -->
                  <button type="button"
                          data-action="click->navbar-search#clear"
                          class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 transition-colors">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  </button>
                </div>

                <!-- Mobile Dropdown Results -->
                <div data-navbar-search-target="dropdown"
                     class="hidden mt-2 bg-white rounded-lg shadow-xl border border-gray-200 overflow-hidden max-h-96 overflow-y-auto">
                  <!-- Results Container -->
                  <div data-navbar-search-target="results"></div>

                  <!-- Empty State -->
                  <div data-navbar-search-target="empty" class="hidden px-4 py-6 text-center">
                    <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <h3 class="mt-2 text-sm font-medium text-gray-900">No results found</h3>
                    <p class="mt-1 text-xs text-gray-500">Try different keywords</p>
                  </div>
                </div>
              </div>

              <!-- Navigation Links -->
              <%= link_to "APIs", apis_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
              <%= link_to "Examples", examples_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
              <%= link_to "Pricing", pricing_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>

              <% if user_signed_in? %>
                <div class="border-t border-gray-200 my-2 pt-2">
                  <%= link_to "Dashboard", dashboard_root_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
                  <%= link_to "API Keys", dashboard_api_keys_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
                  <%= link_to "Usage", dashboard_usage_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
                  <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-3 py-2 rounded-lg text-base font-medium text-red-600 hover:bg-gray-50" %>
                </div>
              <% else %>
                <div class="border-t border-gray-200 my-2 pt-2">
                  <%= link_to "Sign In", new_user_session_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
                  <%= link_to "Get Started", new_user_registration_path, class: "block px-3 py-2 rounded-lg text-base font-medium text-blue-600 hover:bg-gray-50" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>
