  <%# Dynamic API pages %>
  <% @apis.each do |api| %>
  <url>
    <loc>https://requiems.xyz/apis/<%= api["id"] %></loc>
    <lastmod><%= @last_modified.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  <% end %>
</urlset>
