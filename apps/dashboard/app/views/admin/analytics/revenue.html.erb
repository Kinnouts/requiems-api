<% content_for :title, "Revenue Analytics" %>

<%= render "partials/admin_analytics/nav" %>

<!-- Header -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Revenue Analytics</h1>
  <p class="mt-2 text-sm text-gray-600">Subscription revenue and financial metrics</p>
</div>

<!-- Key Metrics Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <!-- MRR -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500">Monthly Recurring Revenue</h3>
      <div class="p-2 bg-green-100 rounded-lg">
        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-gray-900">$<%= number_with_delimiter(@mrr.to_i) %></p>
    <p class="text-sm text-gray-600 mt-1">per month</p>
  </div>

  <!-- ARR -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500">Annual Recurring Revenue</h3>
      <div class="p-2 bg-blue-100 rounded-lg">
        <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-gray-900">$<%= number_with_delimiter(@arr.to_i) %></p>
    <p class="text-sm text-gray-600 mt-1">per year</p>
  </div>

  <!-- Active Subscriptions -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500">Active Subscriptions</h3>
      <div class="p-2 bg-purple-100 rounded-lg">
        <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-gray-900"><%= number_with_delimiter(@active_subscriptions) %></p>
    <p class="text-sm text-gray-600 mt-1">paying customers</p>
  </div>

  <!-- Churn Rate -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500">Churn Rate (30d)</h3>
      <div class="p-2 <%= @churn_rate > 5 ? 'bg-red-100' : 'bg-green-100' %> rounded-lg">
        <svg class="h-6 w-6 <%= @churn_rate > 5 ? 'text-red-600' : 'text-green-600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold <%= @churn_rate > 5 ? 'text-red-600' : 'text-green-600' %>"><%= @churn_rate %>%</p>
    <p class="text-sm text-gray-600 mt-1">
      <% if @churn_rate > 5 %>
        needs attention
      <% elsif @churn_rate > 3 %>
        acceptable
      <% else %>
        excellent
      <% end %>
    </p>
  </div>
</div>

<!-- Revenue Trend Chart -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Revenue Trend (Last 12 Months)</h2>
    <p class="text-sm text-gray-600 mt-1">Monthly recurring revenue over time</p>
  </div>
  <div class="p-6">
    <%= line_chart @revenue_trend,
      prefix: "$",
      height: "300px",
      colors: ["#10b981"],
      library: {
        scales: {
          y: { beginAtZero: true }
        }
      } %>
  </div>
</div>

<!-- Charts Row -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
  <!-- Revenue by Plan -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Revenue by Plan</h2>
      <p class="text-sm text-gray-600 mt-1">Monthly revenue breakdown</p>
    </div>
    <div class="p-6">
      <%= pie_chart @revenue_by_plan,
        prefix: "$",
        height: "300px",
        colors: ["#3b82f6", "#8b5cf6", "#10b981"] %>
    </div>
  </div>

  <!-- Subscriptions by Plan -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Subscriptions by Plan</h2>
      <p class="text-sm text-gray-600 mt-1">Customer distribution</p>
    </div>
    <div class="p-6">
      <%= pie_chart @subscriptions_by_plan,
        height: "300px",
        colors: ["#3b82f6", "#8b5cf6", "#10b981"] %>
    </div>
  </div>
</div>

<!-- New vs Canceled Subscriptions -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">New vs Canceled Subscriptions</h2>
    <p class="text-sm text-gray-600 mt-1">Subscription growth and churn over time</p>
  </div>
  <div class="p-6">
    <%
      new_subs_data = @new_vs_canceled.transform_values { |v| v[:new] }
      canceled_subs_data = @new_vs_canceled.transform_values { |v| v[:canceled] }
    %>
    <%= line_chart [
      { name: "New Subscriptions", data: new_subs_data },
      { name: "Canceled Subscriptions", data: canceled_subs_data }
    ],
      height: "300px",
      colors: ["#10b981", "#ef4444"],
      library: {
        scales: {
          y: { beginAtZero: true }
        }
      } %>
  </div>
</div>

<!-- Revenue Insights -->
<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Revenue Insights</h2>
  </div>
  <div class="p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Average Revenue Per User -->
      <div class="p-4 bg-blue-50 rounded-lg">
        <div class="flex items-center">
          <svg class="h-10 w-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-500">Average Revenue Per User</p>
            <p class="text-2xl font-bold text-gray-900">
              <% if @active_subscriptions > 0 %>
                $<%= number_with_delimiter((@mrr / @active_subscriptions).round(2)) %>
              <% else %>
                $0
              <% end %>
            </p>
          </div>
        </div>
      </div>

      <!-- Growth Rate -->
      <div class="p-4 bg-green-50 rounded-lg">
        <div class="flex items-center">
          <svg class="h-10 w-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-500">MRR Growth (Last Month)</p>
            <%
              current_month = @revenue_trend.values.last
              previous_month = @revenue_trend.values[-2] || 0
              growth_rate = previous_month > 0 ? (((current_month - previous_month).to_f / previous_month) * 100).round(2) : 0
            %>
            <p class="text-2xl font-bold <%= growth_rate >= 0 ? 'text-green-600' : 'text-red-600' %>">
              <%= growth_rate >= 0 ? '+' : '' %><%= growth_rate %>%
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Key Takeaways -->
    <div class="mt-6 p-4 bg-gray-50 border border-gray-200 rounded-lg">
      <h3 class="text-sm font-semibold text-gray-900 mb-2">Key Takeaways</h3>
      <ul class="list-disc pl-5 space-y-1 text-sm text-gray-700">
        <li>
          <% if @churn_rate > 5 %>
            <strong class="text-red-600">High churn rate:</strong> Focus on customer retention and satisfaction
          <% else %>
            <strong class="text-green-600">Low churn rate:</strong> Customers are satisfied with the service
          <% end %>
        </li>
        <li>
          <% if @active_subscriptions > 0 %>
            Average revenue per customer is $<%= number_with_delimiter((@mrr / @active_subscriptions).round(2)) %>/month
          <% else %>
            No active subscriptions yet - focus on customer acquisition
          <% end %>
        </li>
        <li>
          <% if growth_rate >= 10 %>
            <strong class="text-green-600">Strong growth:</strong> Revenue is increasing rapidly
          <% elsif growth_rate >= 0 %>
            <strong class="text-blue-600">Steady growth:</strong> Revenue is increasing consistently
          <% else %>
            <strong class="text-red-600">Declining revenue:</strong> Investigate causes and implement growth strategies
          <% end %>
        </li>
      </ul>
    </div>
  </div>
</div>
