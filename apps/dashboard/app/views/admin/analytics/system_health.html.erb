<% content_for :title, "System Health" %>

<%= render "partials/admin_analytics/nav" %>

<!-- Header -->
<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">System Health</h1>
      <p class="mt-2 text-sm text-gray-600">API performance and reliability metrics</p>
    </div>

    <!-- Time Range Selector -->
    <div class="flex items-center space-x-2">
      <%= form_with url: system_health_admin_analytics_index_path, method: :get, local: true, class: "flex items-center space-x-2" do |f| %>
        <%= f.select :time_range,
          options_for_select(
            [
              ["Last Hour", "1h"],
              ["Last 24 Hours", "24h"],
              ["Last 7 Days", "7d"],
              ["Last 30 Days", "30d"]
            ],
            @time_range
          ),
          {},
          onchange: "this.form.submit()",
          class: "px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      <% end %>
    </div>
  </div>
</div>

<!-- Health Status Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <!-- API Uptime -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500">API Uptime</h3>
      <div class="p-2 <%= @uptime_percentage >= 99 ? 'bg-green-100' : 'bg-red-100' %> rounded-lg">
        <svg class="h-6 w-6 <%= @uptime_percentage >= 99 ? 'text-green-600' : 'text-red-600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold <%= @uptime_percentage >= 99 ? 'text-green-600' : 'text-red-600' %>"><%= @uptime_percentage %>%</p>
    <p class="text-sm text-gray-600 mt-1">
      <%= @uptime_percentage >= 99.9 ? 'Excellent' : (@uptime_percentage >= 99 ? 'Good' : 'Needs attention') %>
    </p>
  </div>

  <!-- P50 Response Time -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500">P50 Response Time</h3>
      <div class="p-2 bg-blue-100 rounded-lg">
        <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-gray-900"><%= @p50_response_time %><span class="text-xl">ms</span></p>
    <p class="text-sm text-gray-600 mt-1">Median response time</p>
  </div>

  <!-- P95 Response Time -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500">P95 Response Time</h3>
      <div class="p-2 bg-orange-100 rounded-lg">
        <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-gray-900"><%= @p95_response_time %><span class="text-xl">ms</span></p>
    <p class="text-sm text-gray-600 mt-1">95th percentile</p>
  </div>

  <!-- P99 Response Time -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-medium text-gray-500">P99 Response Time</h3>
      <div class="p-2 bg-red-100 rounded-lg">
        <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-gray-900"><%= @p99_response_time %><span class="text-xl">ms</span></p>
    <p class="text-sm text-gray-600 mt-1">99th percentile</p>
  </div>
</div>

<!-- Error Rate Trend -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Error Rate Over Time</h2>
    <p class="text-sm text-gray-600 mt-1">Percentage of requests resulting in errors</p>
  </div>
  <div class="p-6">
    <%= line_chart @error_rate_trend,
      suffix: "%",
      height: "300px",
      colors: ["#ef4444"],
      library: {
        scales: {
          y: {
            beginAtZero: true,
            max: 100
          }
        }
      } %>
  </div>
</div>

<!-- Real-time Monitoring (Last Hour) -->
<% if @time_range == "1h" && @requests_per_minute.present? %>
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Requests Per Minute (Last Hour)</h2>
      <p class="text-sm text-gray-600 mt-1">Real-time traffic monitoring</p>
    </div>
    <div class="p-6">
      <%= line_chart @requests_per_minute,
        height: "250px",
        colors: ["#3b82f6"],
        library: {
          scales: {
            y: { beginAtZero: true }
          }
        } %>
    </div>
  </div>
<% end %>

<!-- Error Analysis -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
  <!-- Common Errors -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Most Common Errors</h2>
      <p class="text-sm text-gray-600 mt-1">Top 10 error status codes</p>
    </div>
    <% if @common_errors.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status Code</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Count</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @common_errors.each do |status_code, count| %>
              <%
                status_descriptions = {
                  400 => "Bad Request",
                  401 => "Unauthorized",
                  403 => "Forbidden",
                  404 => "Not Found",
                  429 => "Too Many Requests",
                  500 => "Internal Server Error",
                  502 => "Bad Gateway",
                  503 => "Service Unavailable",
                  504 => "Gateway Timeout"
                }
              %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap">
                  <%
                    status_variant = case status_code
                      when 400..499 then "warning"
                      when 500..599 then "danger"
                      else "default"
                    end
                  %>
                  <%= render "partials/shared/badge", text: status_code.to_s, variant: status_variant, size: "sm" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= status_descriptions[status_code] || "Unknown" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= number_with_delimiter(count) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center">
        <svg class="mx-auto h-12 w-12 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="mt-2 text-sm font-medium text-green-600">No errors recorded!</p>
        <p class="text-sm text-gray-500">The system is running perfectly.</p>
      </div>
    <% end %>
  </div>

  <!-- Security Metrics -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Security Metrics</h2>
      <p class="text-sm text-gray-600 mt-1">Authentication and security events</p>
    </div>
    <div class="p-6 space-y-6">
      <!-- Failed Authentication Attempts -->
      <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
        <div class="flex items-center">
          <div class="p-3 <%= @failed_auth_attempts > 100 ? 'bg-red-100' : 'bg-green-100' %> rounded-lg">
            <svg class="h-6 w-6 <%= @failed_auth_attempts > 100 ? 'text-red-600' : 'text-green-600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-500">Failed Auth Attempts (24h)</p>
            <p class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@failed_auth_attempts) %></p>
          </div>
        </div>
        <% if @failed_auth_attempts > 100 %>
          <%= render "partials/shared/badge", text: "High", variant: "danger", size: "sm" %>
        <% else %>
          <%= render "partials/shared/badge", text: "Normal", variant: "success", size: "sm" %>
        <% end %>
      </div>

      <!-- Rate Limit Hits -->
      <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
        <div class="flex items-center">
          <div class="p-3 bg-blue-100 rounded-lg">
            <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-500">Rate Limit Hits (24h)</p>
            <p class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@rate_limit_hits) %></p>
          </div>
        </div>
        <%= render "partials/shared/badge", text: "Coming Soon", variant: "default", size: "sm" %>
      </div>

      <!-- Security Notice -->
      <div class="p-4 bg-blue-50 border border-blue-200 rounded-lg">
        <div class="flex">
          <svg class="h-5 w-5 text-blue-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-blue-800">Security Monitoring</h3>
            <p class="mt-1 text-sm text-blue-700">
              All API requests are monitored for suspicious activity. High rates of failed authentication may indicate a security threat.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Health Insights -->
<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">System Health Insights</h2>
  </div>
  <div class="p-6">
    <div class="space-y-4">
      <!-- Uptime Status -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <% if @uptime_percentage >= 99.9 %>
            <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          <% elsif @uptime_percentage >= 99 %>
            <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          <% else %>
            <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          <% end %>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-gray-900">API Uptime</h3>
          <p class="mt-1 text-sm text-gray-600">
            <% if @uptime_percentage >= 99.9 %>
              <strong class="text-green-600">Excellent uptime.</strong> The API is highly reliable with minimal downtime.
            <% elsif @uptime_percentage >= 99 %>
              <strong class="text-blue-600">Good uptime.</strong> The API is performing well with acceptable availability.
            <% else %>
              <strong class="text-red-600">Low uptime.</strong> Investigate recent incidents and implement improvements.
            <% end %>
          </p>
        </div>
      </div>

      <!-- Response Time Status -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <% if @p95_response_time < 500 %>
            <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          <% elsif @p95_response_time < 1000 %>
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          <% else %>
            <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          <% end %>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-gray-900">Response Times</h3>
          <p class="mt-1 text-sm text-gray-600">
            <% if @p95_response_time < 500 %>
              <strong class="text-green-600">Fast response times.</strong> The API is performing optimally.
            <% elsif @p95_response_time < 1000 %>
              <strong class="text-orange-600">Acceptable performance.</strong> Consider optimizing slow endpoints.
            <% else %>
              <strong class="text-red-600">Slow response times.</strong> Performance optimization is needed.
            <% end %>
            P95: <%= @p95_response_time %>ms, P99: <%= @p99_response_time %>ms
          </p>
        </div>
      </div>

      <!-- Security Status -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <% if @failed_auth_attempts > 100 %>
            <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          <% else %>
            <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          <% end %>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-gray-900">Security</h3>
          <p class="mt-1 text-sm text-gray-600">
            <% if @failed_auth_attempts > 100 %>
              <strong class="text-red-600">High failed auth attempts.</strong> Monitor for potential security threats.
            <% else %>
              <strong class="text-green-600">Normal security activity.</strong> No suspicious patterns detected.
            <% end %>
            <%= number_with_delimiter(@failed_auth_attempts) %> failed attempts in last 24h.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
