<% content_for :title, "Usage Analytics" %>

<%= render "partials/admin_analytics/nav" %>

<!-- Header -->
<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Usage Analytics</h1>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">API usage patterns and statistics</p>
    </div>

    <!-- Date Range Selector -->
    <div class="flex items-center space-x-2">
      <%= form_with url: admin_analytics_usage_path, method: :get, local: true, class: "flex items-center space-x-2" do |f| %>
        <%= f.select :date_range,
          options_for_select(
            [
              ["Last 7 Days", "7"],
              ["Last 30 Days", "30"],
              ["Last 90 Days", "90"]
            ],
            @date_range
          ),
          {},
          onchange: "this.form.submit()",
          class: "px-4 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      <% end %>
    </div>
  </div>
</div>

<!-- Summary Card -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-8">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total Requests</p>
      <p class="text-4xl font-bold text-gray-900 dark:text-gray-100 mt-2"><%= number_with_delimiter(@total_requests) %></p>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">in the last <%= @date_range %> days</p>
    </div>
    <div class="p-4 bg-blue-100 dark:bg-blue-900/30 rounded-lg">
      <svg class="h-12 w-12 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
      </svg>
    </div>
  </div>
</div>

<!-- Requests Over Time Chart -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Requests Over Time</h2>
  </div>
  <div class="p-6">
    <%= line_chart @requests_by_day,
      height: "300px",
      colors: ["#3b82f6"],
      library: {
        scales: {
          y: { beginAtZero: true }
        }
      } %>
  </div>
</div>

<!-- Charts Row -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
  <!-- Requests by Endpoint -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Top 10 Endpoints</h2>
    </div>
    <div class="p-6">
      <%= bar_chart @requests_by_endpoint,
        height: "300px",
        colors: ["#3b82f6"],
        library: {
          indexAxis: 'y',
          scales: {
            x: { beginAtZero: true }
          }
        } %>
    </div>
  </div>

  <!-- Requests by Plan -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Requests by Plan</h2>
    </div>
    <div class="p-6">
      <%= pie_chart @requests_by_plan.transform_keys(&:titleize),
        height: "300px",
        colors: ["#9ca3af", "#3b82f6", "#8b5cf6", "#10b981"] %>
    </div>
  </div>
</div>

<!-- Average Response Times -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Average Response Times by Endpoint</h2>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Top 10 slowest endpoints</p>
  </div>
  <div class="p-6">
    <%= bar_chart @avg_response_by_endpoint,
      suffix: "ms",
      height: "300px",
      colors: ["#f59e0b"],
      library: {
        indexAxis: 'y',
        scales: {
          x: { beginAtZero: true }
        }
      } %>
  </div>
</div>

<!-- Top Users by Usage -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Top 10 Users by Usage</h2>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
      <thead class="bg-gray-50 dark:bg-gray-700">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Rank</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">User</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Requests</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total Requests</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
        <% @top_users_by_usage.each_with_index do |user_stat, index| %>
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">
              #<%= index + 1 %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
              <%= user_stat.email %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
              <%= number_with_delimiter(user_stat.request_count) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
              <%= number_with_delimiter(user_stat.total_requests) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= link_to "View User", admin_user_path(user_stat.id), class: "text-blue-600 hover:text-blue-700" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
