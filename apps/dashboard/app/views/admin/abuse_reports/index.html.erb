<% content_for :title, "Abuse Reports" %>

<!-- Header -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Abuse Reports</h1>
  <p class="mt-2 text-sm text-gray-600">Monitor and manage abuse reports</p>
</div>

<!-- Statistics Cards -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
  <div class="bg-white rounded-lg shadow p-6">
    <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-1">Total Reports</p>
    <p class="text-3xl font-bold text-gray-900"><%= number_with_delimiter(@total_reports) %></p>
  </div>
  <div class="bg-white rounded-lg shadow p-6">
    <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-1">Pending</p>
    <p class="text-3xl font-bold text-orange-600"><%= number_with_delimiter(@pending_reports) %></p>
  </div>
  <div class="bg-white rounded-lg shadow p-6">
    <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-1">Investigating</p>
    <p class="text-3xl font-bold text-blue-600"><%= number_with_delimiter(@investigating_reports) %></p>
  </div>
  <div class="bg-white rounded-lg shadow p-6">
    <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-1">Resolved</p>
    <p class="text-3xl font-bold text-green-600"><%= number_with_delimiter(@resolved_reports) %></p>
  </div>
</div>

<!-- Search and Filters -->
<div class="bg-white rounded-lg shadow p-6 mb-8">
  <%= form_with url: admin_abuse_reports_path, method: :get, local: true, class: "space-y-4" do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <!-- Search -->
      <div class="md:col-span-2">
        <%= f.label :search, "Search", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :search,
          value: params[:search],
          placeholder: "Search by user email or description",
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>

      <!-- Status Filter -->
      <div>
        <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :status,
          options_for_select(
            [
              ["All Statuses", "all"],
              ["Pending", "pending"],
              ["Investigating", "investigating"],
              ["Resolved", "resolved"]
            ],
            params[:status] || "all"
          ),
          {},
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>

      <!-- Type Filter -->
      <div>
        <%= f.label :report_type, "Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :report_type,
          options_for_select(
            [
              ["All Types", "all"],
              ["Spam", "spam"],
              ["Abuse", "abuse"],
              ["Malicious Activity", "malicious"],
              ["Terms Violation", "terms_violation"],
              ["Other", "other"]
            ],
            params[:report_type] || "all"
          ),
          {},
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>
    </div>

    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-2">
        <%= f.submit "Apply Filters", class: "px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" %>
        <%= link_to "Clear", admin_abuse_reports_path, class: "px-6 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors" %>
      </div>
    </div>
  <% end %>
</div>

<!-- Abuse Reports Table -->
<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-900">
      Reports (<%= @pagy.count %>)
    </h2>
  </div>

  <% if @abuse_reports.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reported</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @abuse_reports.each do |report| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center">
                    <span class="text-xs font-medium text-gray-700"><%= report.user.email.first.upcase %></span>
                  </div>
                  <div class="ml-3">
                    <div class="text-sm font-medium text-gray-900"><%= report.user.email %></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%
                  type_variant = case report.report_type
                    when "spam" then "warning"
                    when "abuse", "malicious" then "danger"
                    when "terms_violation" then "warning"
                    else "default"
                  end
                %>
                <%= render "shared/badge", text: (report.report_type || "Unknown").titleize, variant: type_variant, size: "xs" %>
              </td>
              <td class="px-6 py-4 max-w-xs truncate text-sm text-gray-600">
                <%= report.description.present? ? truncate(report.description, length: 60) : "—" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                <%= time_ago_in_words(report.created_at) %> ago
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%
                  status_variant = case report.status
                    when "pending" then "warning"
                    when "investigating" then "primary"
                    when "resolved" then "success"
                    else "default"
                  end
                %>
                <%= render "shared/badge", text: (report.status || "Pending").titleize, variant: status_variant, size: "xs" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "View", admin_abuse_report_path(report), class: "text-blue-600 hover:text-blue-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="px-6 py-4 border-t border-gray-200">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No reports found</h3>
      <p class="mt-1 text-sm text-gray-500">
        <% if params[:search].present? || params[:status].present? || params[:report_type].present? %>
          Try adjusting your search or filters.
        <% else %>
          All clear! No abuse reports have been submitted.
        <% end %>
      </p>
    </div>
  <% end %>
</div>
