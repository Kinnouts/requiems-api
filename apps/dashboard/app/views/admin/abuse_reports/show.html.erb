<% content_for :title, "Abuse Report ##{@abuse_report.id}" %>

<!-- Header with Back Button -->
<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to admin_abuse_reports_path, class: "inline-flex items-center text-sm text-gray-600 hover:text-gray-900 mb-2" do %>
        <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Reports
      <% end %>
      <h1 class="text-3xl font-bold text-gray-900">Abuse Report #<%= @abuse_report.id %></h1>
    </div>

    <!-- Status Badge -->
    <div>
      <%
        status_variant = case @abuse_report.status
          when "pending" then "warning"
          when "investigating" then "primary"
          when "resolved" then "success"
          else "default"
        end
      %>
      <%= render "shared/badge", text: (@abuse_report.status || "Pending").titleize, variant: status_variant, size: "sm" %>
    </div>
  </div>
</div>

<!-- Report Details -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
  <!-- Main Info Card -->
  <div class="lg:col-span-2 bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Report Details</h2>
    </div>
    <div class="p-6">
      <div class="space-y-6">
        <!-- Report Type -->
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-2">Report Type</label>
          <%
            type_variant = case @abuse_report.report_type
              when "spam" then "warning"
              when "abuse", "malicious" then "danger"
              when "terms_violation" then "warning"
              else "default"
            end
          %>
          <%= render "shared/badge", text: (@abuse_report.report_type || "Unknown").titleize, variant: type_variant, size: "sm" %>
        </div>

        <!-- Description -->
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-2">Description</label>
          <div class="p-4 bg-gray-50 rounded-lg">
            <p class="text-sm text-gray-900 whitespace-pre-wrap"><%= @abuse_report.description || "No description provided" %></p>
          </div>
        </div>

        <!-- Reported At -->
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-2">Reported At</label>
          <p class="text-sm text-gray-900">
            <%= @abuse_report.created_at.strftime("%B %d, %Y at %I:%M %p") %>
            (<%= time_ago_in_words(@abuse_report.created_at) %> ago)
          </p>
        </div>

        <!-- Resolution Details -->
        <% if @abuse_report.status == "resolved" %>
          <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
            <div class="flex items-start">
              <svg class="h-5 w-5 text-green-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-green-800">Report Resolved</h3>
                <p class="mt-1 text-sm text-green-700">
                  Resolved on <%= @abuse_report.resolved_at.strftime("%B %d, %Y at %I:%M %p") %>
                  <% if @resolver %>
                    by <%= @resolver.email %>
                  <% end %>
                </p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- API Key Info -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">API Key</h2>
    </div>
    <div class="p-6">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">Key Name</label>
          <p class="text-sm text-gray-900"><%= @api_key.name %></p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">Key Prefix</label>
          <p class="text-sm text-gray-900 font-mono"><%= @api_key.prefix %>••••••••</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">Environment</label>
          <%= render "shared/badge",
            text: @api_key.environment.titleize,
            variant: @api_key.environment == "live" ? "primary" : "default",
            size: "xs" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">Status</label>
          <% if @api_key.revoked_at.present? %>
            <%= render "shared/badge", text: "Revoked", variant: "danger", size: "xs" %>
          <% else %>
            <%= render "shared/badge", text: "Active", variant: "success", size: "xs" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- User Information -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Reported User</h2>
  </div>
  <div class="p-6">
    <div class="flex items-center mb-6">
      <div class="flex-shrink-0 h-16 w-16 rounded-full bg-gray-200 flex items-center justify-center">
        <span class="text-2xl font-medium text-gray-700"><%= @user.email.first.upcase %></span>
      </div>
      <div class="ml-4">
        <div class="text-xl font-medium text-gray-900"><%= @user.email %></div>
        <% if @user.name.present? %>
          <div class="text-sm text-gray-600"><%= @user.name %></div>
        <% end %>
        <%= link_to "View Full Profile", admin_user_path(@user), class: "text-sm text-blue-600 hover:text-blue-700" %>
      </div>
    </div>

    <!-- User Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
      <div class="p-4 bg-gray-50 rounded-lg">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Total Requests</p>
        <p class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@usage_stats[:total_requests]) %></p>
      </div>
      <div class="p-4 bg-gray-50 rounded-lg">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">This Month</p>
        <p class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@usage_stats[:requests_this_month]) %></p>
      </div>
      <div class="p-4 bg-gray-50 rounded-lg">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Error Rate</p>
        <p class="text-2xl font-bold <%= @usage_stats[:error_rate] > 10 ? 'text-red-600' : 'text-green-600' %>"><%= @usage_stats[:error_rate] %>%</p>
      </div>
      <div class="p-4 bg-gray-50 rounded-lg">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Last Request</p>
        <p class="text-sm font-medium text-gray-900">
          <% if @usage_stats[:last_request_at].present? %>
            <%= time_ago_in_words(@usage_stats[:last_request_at]) %> ago
          <% else %>
            Never
          <% end %>
        </p>
      </div>
    </div>

    <!-- User Status -->
    <div class="flex items-center space-x-2">
      <% if @user.admin? %>
        <%= render "shared/badge", text: "Admin", variant: "danger", size: "xs" %>
      <% elsif @user.suspended? %>
        <%= render "shared/badge", text: "Suspended", variant: "warning", size: "xs" %>
      <% else %>
        <%= render "shared/badge", text: "Active", variant: "success", size: "xs" %>
      <% end %>

      <% if @user.subscription.present? %>
        <%= render "shared/badge",
          text: @user.subscription.plan_name.titleize,
          variant: @user.subscription.plan_name == "free" ? "default" : "primary",
          size: "xs" %>
      <% else %>
        <%= render "shared/badge", text: "Free Plan", variant: "default", size: "xs" %>
      <% end %>
    </div>
  </div>
</div>

<!-- Other Reports -->
<% if @other_reports.any? %>
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Other Reports for This User</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reported</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @other_reports.each do |report| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%
                  type_variant = case report.report_type
                    when "spam" then "warning"
                    when "abuse", "malicious" then "danger"
                    when "terms_violation" then "warning"
                    else "default"
                  end
                %>
                <%= render "shared/badge", text: (report.report_type || "Unknown").titleize, variant: type_variant, size: "xs" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                <%= time_ago_in_words(report.created_at) %> ago
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%
                  status_variant = case report.status
                    when "pending" then "warning"
                    when "investigating" then "primary"
                    when "resolved" then "success"
                    else "default"
                  end
                %>
                <%= render "shared/badge", text: (report.status || "Pending").titleize, variant: status_variant, size: "xs" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "View", admin_abuse_report_path(report), class: "text-blue-600 hover:text-blue-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<!-- Admin Actions -->
<div class="bg-white rounded-lg shadow border-2 border-orange-200">
  <div class="px-6 py-4 border-b border-gray-200 bg-orange-50">
    <h2 class="text-lg font-semibold text-orange-900">Admin Actions</h2>
    <p class="text-sm text-orange-700 mt-1">Take action on this abuse report</p>
  </div>
  <div class="p-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Investigate -->
      <% if @abuse_report.status == "pending" %>
        <%= button_to investigate_admin_abuse_report_path(@abuse_report), method: :post, class: "w-full px-4 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors text-center" do %>
          <svg class="h-5 w-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          Mark as Investigating
        <% end %>
      <% end %>

      <!-- Resolve -->
      <% if @abuse_report.status != "resolved" %>
        <%= button_to resolve_admin_abuse_report_path(@abuse_report), method: :post, class: "w-full px-4 py-3 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors text-center", data: { turbo_confirm: "Are you sure you want to resolve this report?" } do %>
          <svg class="h-5 w-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Resolve Report
        <% end %>
      <% end %>

      <!-- Suspend User -->
      <% unless @user.suspended? %>
        <%= button_to suspend_admin_user_path(@user), method: :post, class: "w-full px-4 py-3 bg-orange-600 text-white font-medium rounded-lg hover:bg-orange-700 transition-colors text-center", data: { turbo_confirm: "Are you sure you want to suspend this user? All their API keys will be revoked." } do %>
          <svg class="h-5 w-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
          </svg>
          Suspend User
        <% end %>
      <% end %>

      <!-- Ban User -->
      <% unless @user.banned? %>
        <%= button_to ban_admin_user_path(@user), method: :post, class: "w-full px-4 py-3 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors text-center", data: { turbo_confirm: "Are you sure you want to BAN this user? This will revoke all API keys and cancel their subscription." } do %>
          <svg class="h-5 w-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
          </svg>
          Ban User
        <% end %>
      <% end %>
    </div>

    <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
      <div class="flex">
        <svg class="h-5 w-5 text-yellow-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-yellow-800">Action Guidelines</h3>
          <div class="mt-2 text-sm text-yellow-700">
            <ul class="list-disc pl-5 space-y-1">
              <li><strong>Investigate:</strong> Review the report and gather more information</li>
              <li><strong>Resolve:</strong> Close the report if no action is needed or after taking corrective measures</li>
              <li><strong>Suspend:</strong> Temporarily restrict user access and revoke API keys</li>
              <li><strong>Ban:</strong> Permanent restriction for severe violations</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
