<% content_for :title, "API Key: #{@api_key.name}" %>

<!-- Header with Back Button -->
<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to admin_api_keys_path, class: "inline-flex items-center text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 mb-2" do %>
        <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to API Keys
      <% end %>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @api_key.name %></h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 font-mono mt-1"><%= @api_key.masked_key %></p>
    </div>
    <div class="flex items-center space-x-2">
      <% if @api_key.revoked_at.present? %>
        <%= render "partials/shared/badge", text: "Revoked", variant: "danger", size: "sm" %>
      <% else %>
        <%= render "partials/shared/badge", text: "Active", variant: "success", size: "sm" %>
      <% end %>
    </div>
  </div>
</div>

<!-- Key Details + User -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
  <!-- Key Info -->
  <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Key Details</h2>
    </div>
    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-1">Key Prefix</label>
        <p class="text-sm text-gray-900 dark:text-gray-100 font-mono"><%= @api_key.key_prefix %></p>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-1">Environment</label>
        <%= render "partials/shared/badge",
          text: h(@api_key.environment.to_s.titleize.presence || "Live"),
          variant: @api_key.environment == "live" ? "primary" : "default",
          size: "xs" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-1">Created</label>
        <p class="text-sm text-gray-900 dark:text-gray-100"><%= @api_key.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>
      <% if @api_key.revoked_at.present? %>
        <div>
          <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-1">Revoked At</label>
          <p class="text-sm text-gray-900 dark:text-gray-100"><%= @api_key.revoked_at.strftime("%B %d, %Y at %I:%M %p") %></p>
        </div>
        <% if @api_key.revoked_reason.present? %>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-1">Revoke Reason</label>
            <p class="text-sm text-gray-900 dark:text-gray-100"><%= @api_key.revoked_reason %></p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- User Info -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Owner</h2>
    </div>
    <div class="p-6 space-y-4">
      <div class="flex items-center">
        <img src="<%= gravatar_url(@user.email, size: 48) %>" alt="Avatar" class="flex-shrink-0 h-12 w-12 rounded-full">
        <div class="ml-3">
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= @user.email %></div>
          <% if @user.name.present? %>
            <div class="text-xs text-gray-500 dark:text-gray-400"><%= @user.name %></div>
          <% end %>
        </div>
      </div>
      <%= link_to "View User Profile", admin_user_path(@user), class: "text-sm text-blue-600 hover:text-blue-700" %>
    </div>
  </div>
</div>

<!-- Recent Usage -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Recent Usage</h2>
  </div>
  <% if @recent_usage.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Endpoint</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Credits</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Response Time</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Used At</th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
          <% @recent_usage.each do |log| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100 font-mono"><%= log.endpoint %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render "partials/shared/badge",
                  text: h(log.status_code.to_s),
                  variant: (log.status_code || 0) >= 400 ? "danger" : "success",
                  size: "xs" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400"><%= log.credits_used %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                <%= log.response_time_ms ? "#{log.response_time_ms}ms" : "—" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                <%= log.used_at&.strftime("%b %d, %Y %H:%M") || "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-10 text-center text-sm text-gray-500 dark:text-gray-400">No usage recorded for this key.</div>
  <% end %>
</div>

<!-- Admin Actions -->
<% unless @api_key.revoked_at.present? %>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow border-2 border-red-200 dark:border-red-800">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-red-50 dark:bg-red-900/20">
      <h2 class="text-lg font-semibold text-red-900 dark:text-red-300">Admin Actions</h2>
    </div>
    <div class="p-6">
      <%= button_to revoke_admin_api_key_path(@api_key), method: :delete,
        class: "px-6 py-3 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors",
        data: { turbo_confirm: "Are you sure you want to revoke this API key? This cannot be undone." } do %>
        Revoke API Key
      <% end %>
    </div>
  </div>
<% end %>
