<% content_for :title, "User Details - #{@user.email}" %>

<!-- Header with Back Button -->
<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to admin_users_path, class: "inline-flex items-center text-sm text-gray-600 hover:text-gray-900 mb-2" do %>
        <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Users
      <% end %>
      <h1 class="text-3xl font-bold text-gray-900">User Details</h1>
    </div>

    <!-- User Status Badge -->
    <div>
      <% if @user.admin? %>
        <%= render "partials/shared/badge", text: "Admin", variant: "danger", size: "sm" %>
      <% elsif @user.suspended? %>
        <%= render "partials/shared/badge", text: "Suspended", variant: "warning", size: "sm" %>
      <% else %>
        <%= render "partials/shared/badge", text: "Active", variant: "success", size: "sm" %>
      <% end %>
    </div>
  </div>
</div>

<!-- User Information -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
  <!-- Main Info Card -->
  <div class="lg:col-span-2 bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Account Information</h2>
    </div>
    <div class="p-6">
      <div class="flex items-center mb-6">
        <div class="flex-shrink-0 h-16 w-16 rounded-full bg-gray-200 flex items-center justify-center">
          <span class="text-2xl font-medium text-gray-700"><%= @user.email.first.upcase %></span>
        </div>
        <div class="ml-4">
          <div class="text-xl font-medium text-gray-900"><%= @user.email %></div>
          <% if @user.name.present? %>
            <div class="text-sm text-gray-600"><%= @user.name %></div>
          <% end %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">Company</label>
          <p class="text-sm text-gray-900"><%= @user.company.presence || "—" %></p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">User ID</label>
          <p class="text-sm text-gray-900 font-mono"><%= @user.id %></p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">Joined</label>
          <p class="text-sm text-gray-900"><%= @user.created_at.strftime("%B %d, %Y") %></p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-1">Last Sign In</label>
          <p class="text-sm text-gray-900">
            <% if @user.last_sign_in_at.present? %>
              <%= time_ago_in_words(@user.last_sign_in_at) %> ago
            <% else %>
              Never
            <% end %>
          </p>
        </div>
        <% if @user.suspended? %>
          <div>
            <label class="block text-sm font-medium text-gray-500 mb-1">Suspended At</label>
            <p class="text-sm text-gray-900"><%= @user.suspended_at&.strftime("%B %d, %Y") || "—" %></p>
          </div>
        <% end %>
        <% if @user.banned? %>
          <div>
            <label class="block text-sm font-medium text-gray-500 mb-1">Banned At</label>
            <p class="text-sm text-gray-900"><%= @user.banned_at&.strftime("%B %d, %Y") || "—" %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Subscription Card -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Subscription</h2>
    </div>
    <div class="p-6">
      <% if @user.subscription.present? %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-500 mb-1">Plan</label>
            <%= render "partials/shared/badge",
              text: @user.subscription.plan_name.titleize,
              variant: @user.subscription.plan_name == "free" ? "default" : "primary",
              size: "sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-500 mb-1">Billing Cycle</label>
            <p class="text-sm text-gray-900"><%= @user.subscription.billing_cycle&.titleize || "—" %></p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-500 mb-1">Started</label>
            <p class="text-sm text-gray-900"><%= @user.subscription.billing_cycle_start&.strftime("%B %d, %Y") || "—" %></p>
          </div>
          <% if @user.subscription.cancel_at_period_end? %>
            <div>
              <%= render "partials/shared/badge", text: "Canceling at Period End", variant: "warning", size: "xs" %>
              <p class="text-xs text-gray-600 mt-1">
                Ends: <%= @user.subscription.billing_cycle_end&.strftime("%B %d, %Y") || "—" %>
              </p>
            </div>
          <% end %>
          <% if @user.subscription.lemonsqueezy_customer_id.present? %>
            <div>
              <label class="block text-sm font-medium text-gray-500 mb-1">LemonSqueezy ID</label>
              <p class="text-xs text-gray-600 font-mono"><%= @user.subscription.lemonsqueezy_customer_id %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-6">
          <%= render "partials/shared/badge", text: "Free Plan", variant: "default", size: "sm" %>
          <p class="text-sm text-gray-600 mt-2">No active subscription</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Usage Statistics -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Usage Statistics</h2>
  </div>
  <div class="p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Total Requests</p>
        <p class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@usage_stats[:total_requests]) %></p>
      </div>
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">This Month</p>
        <p class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@usage_stats[:requests_this_month]) %></p>
      </div>
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Credits Used</p>
        <p class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@usage_stats[:total_credits_used]) %></p>
      </div>
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Avg Response</p>
        <p class="text-2xl font-bold text-gray-900"><%= @usage_stats[:avg_response_time] %>ms</p>
      </div>
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Error Rate</p>
        <p class="text-2xl font-bold <%= @usage_stats[:error_rate] > 5 ? 'text-red-600' : 'text-green-600' %>"><%= @usage_stats[:error_rate] %>%</p>
      </div>
    </div>
  </div>
</div>

<!-- API Keys -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">API Keys (<%= @api_keys.count %>)</h2>
  </div>
  <% if @api_keys.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Key</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Environment</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @api_keys.each do |api_key| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= api_key.name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 font-mono">
                <%= api_key.prefix %>••••••••••••••••
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render "partials/shared/badge",
                  text: api_key.environment.titleize,
                  variant: api_key.environment == "live" ? "primary" : "default",
                  size: "xs" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                <%= time_ago_in_words(api_key.created_at) %> ago
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if api_key.revoked_at.present? %>
                  <%= render "partials/shared/badge", text: "Revoked", variant: "danger", size: "xs" %>
                <% else %>
                  <%= render "partials/shared/badge", text: "Active", variant: "success", size: "xs" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <p class="text-sm text-gray-500">No API keys created</p>
    </div>
  <% end %>
</div>

<!-- Recent Activity -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Recent Activity</h2>
  </div>
  <% if @recent_activity.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Timestamp</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Endpoint</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Method</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Response Time</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Credits</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @recent_activity.each do |log| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                <%= log.used_at.strftime("%b %d, %I:%M %p") %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-900 font-mono">
                <%= log.endpoint %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                <%= log.http_method %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%
                  status_variant = case log.status_code
                    when 200..299 then "success"
                    when 400..499 then "warning"
                    when 500..599 then "danger"
                    else "default"
                  end
                %>
                <%= render "partials/shared/badge", text: log.status_code.to_s, variant: status_variant, size: "xs" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                <%= log.response_time_ms || "—" %>ms
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                <%= log.credits_used || 0 %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <p class="text-sm text-gray-500">No recent activity</p>
    </div>
  <% end %>
</div>

<!-- Admin Actions -->
<div class="bg-white rounded-lg shadow border-2 border-red-200">
  <div class="px-6 py-4 border-b border-gray-200 bg-red-50">
    <h2 class="text-lg font-semibold text-red-900">Admin Actions</h2>
    <p class="text-sm text-red-700 mt-1">These actions are permanent and cannot be undone easily.</p>
  </div>
  <div class="p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Suspend/Unsuspend -->
      <% if @user.suspended? %>
        <%= button_to unsuspend_admin_user_path(@user), method: :post, class: "w-full px-4 py-3 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors text-center", data: { turbo_confirm: "Are you sure you want to unsuspend this user? They will regain access to their account." } do %>
          <svg class="h-5 w-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Unsuspend User
        <% end %>
      <% else %>
        <%= button_to suspend_admin_user_path(@user), method: :post, class: "w-full px-4 py-3 bg-orange-600 text-white font-medium rounded-lg hover:bg-orange-700 transition-colors text-center", data: { turbo_confirm: "Are you sure you want to suspend this user? All their API keys will be revoked." } do %>
          <svg class="h-5 w-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
          </svg>
          Suspend User
        <% end %>
      <% end %>

      <!-- Ban -->
      <% unless @user.banned? %>
        <%= button_to ban_admin_user_path(@user), method: :post, class: "w-full px-4 py-3 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors text-center", data: { turbo_confirm: "Are you sure you want to BAN this user? This will revoke all API keys and cancel their subscription. This action is severe." } do %>
          <svg class="h-5 w-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
          </svg>
          Ban User
        <% end %>
      <% end %>

      <!-- Make Admin / Remove Admin -->
      <% if @user.admin? %>
        <%= button_to remove_admin_admin_user_path(@user), method: :post, class: "w-full px-4 py-3 bg-gray-600 text-white font-medium rounded-lg hover:bg-gray-700 transition-colors text-center", data: { turbo_confirm: "Are you sure you want to remove admin privileges from this user?" } do %>
          <svg class="h-5 w-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6z"/>
          </svg>
          Remove Admin
        <% end %>
      <% else %>
        <%= button_to make_admin_admin_user_path(@user), method: :post, class: "w-full px-4 py-3 bg-purple-600 text-white font-medium rounded-lg hover:bg-purple-700 transition-colors text-center", data: { turbo_confirm: "Are you sure you want to grant admin privileges to this user? They will have full system access." } do %>
          <svg class="h-5 w-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          Make Admin
        <% end %>
      <% end %>
    </div>

    <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
      <div class="flex">
        <svg class="h-5 w-5 text-yellow-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-yellow-800">Admin Action Guidelines</h3>
          <div class="mt-2 text-sm text-yellow-700">
            <ul class="list-disc pl-5 space-y-1">
              <li><strong>Suspend</strong>: Temporary restriction, revokes all API keys</li>
              <li><strong>Ban</strong>: Permanent restriction, revokes keys and cancels subscription</li>
              <li><strong>Make Admin</strong>: Grants full system access, use with caution</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
