<% content_for :title, "Private Deployment — #{@deployment_request.company}" %>

<!-- Back -->
<div class="mb-6">
  <%= link_to "← All Deployments", admin_private_deployments_path, class: "text-sm text-blue-600 hover:text-blue-700 dark:text-blue-400" %>
</div>

<!-- Header -->
<div class="mb-8 flex items-start justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @deployment_request.company %></h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Request #<%= @deployment_request.id %> · Submitted <%= @deployment_request.created_at.strftime("%B %d, %Y at %H:%M UTC") %></p>
  </div>
  <%
    badge_variant = case @deployment_request.status
      when "pending"   then "warning"
      when "deploying" then "primary"
      when "active"    then "success"
      else "default"
    end
  %>
  <%= render "partials/shared/badge", text: @deployment_request.status.capitalize, variant: badge_variant, size: "sm" %>
</div>

<div class="grid lg:grid-cols-3 gap-8">

  <!-- Left: Request Details -->
  <div class="lg:col-span-2 space-y-6">

    <!-- Contact Info -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Contact</h2>
      <dl class="space-y-3">
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500 dark:text-gray-400">Name</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100"><%= @deployment_request.contact_name %></dd>
        </div>
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500 dark:text-gray-400">Email</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100"><%= mail_to @deployment_request.contact_email, @deployment_request.contact_email, class: "text-blue-600 hover:text-blue-700" %></dd>
        </div>
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500 dark:text-gray-400">Account</dt>
          <dd><%= link_to @deployment_request.user.email, admin_user_path(@deployment_request.user), class: "text-blue-600 hover:text-blue-700 text-sm" %></dd>
        </div>
      </dl>
    </div>

    <!-- Server & Services -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Deployment Spec</h2>
      <dl class="space-y-3 mb-6">
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500 dark:text-gray-400">Server Tier</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100 capitalize">
            <%= @deployment_request.server_tier %>
            <span class="text-gray-500 font-normal">(<%= @deployment_request.tier_specs[:hetzner] %> — <%= @deployment_request.tier_specs[:vcpu] %> vCPU / <%= @deployment_request.tier_specs[:ram] %> RAM)</span>
          </dd>
        </div>
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500 dark:text-gray-400">Monthly Price</dt>
          <dd class="font-bold text-gray-900 dark:text-gray-100">$<%= "%.0f" % @deployment_request.monthly_price_dollars %>/mo</dd>
        </div>
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500 dark:text-gray-400">ENABLED_SERVICES value</dt>
          <dd class="font-mono text-xs bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded text-gray-900 dark:text-gray-100"><%= @deployment_request.selected_services.join(",") %></dd>
        </div>
      </dl>
      <div>
        <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Selected Services (<%= @deployment_request.selected_services.count %>)</p>
        <div class="flex flex-wrap gap-2">
          <% @deployment_request.selected_services.each do |svc| %>
            <span class="inline-block text-sm bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-blue-800 px-3 py-1 rounded-full capitalize"><%= svc %></span>
          <% end %>
        </div>
      </div>
    </div>

    <% if @deployment_request.admin_notes.present? %>
      <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-6">
        <h2 class="text-sm font-semibold text-amber-800 dark:text-amber-300 uppercase tracking-wider mb-2">Customer Notes</h2>
        <p class="text-sm text-amber-900 dark:text-amber-200"><%= @deployment_request.admin_notes %></p>
      </div>
    <% end %>

    <!-- Active deployment info -->
    <% if @deployment_request.status == "active" %>
      <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-6">
        <h2 class="text-lg font-semibold text-green-900 dark:text-green-100 mb-4">Live Deployment</h2>
        <dl class="space-y-3">
          <div class="flex justify-between text-sm">
            <dt class="text-green-700 dark:text-green-400">URL</dt>
            <dd><a href="<%= @deployment_request.live_url %>" target="_blank" class="font-mono text-sm text-blue-600 hover:text-blue-700"><%= @deployment_request.live_url %></a></dd>
          </div>
          <div class="flex justify-between text-sm">
            <dt class="text-green-700 dark:text-green-400">X-Backend-Secret</dt>
            <dd class="font-mono text-xs bg-white dark:bg-gray-800 border border-green-200 dark:border-green-800 px-2 py-1 rounded text-gray-900 dark:text-gray-100"><%= @deployment_request.tenant_secret %></dd>
          </div>
          <div class="flex justify-between text-sm">
            <dt class="text-green-700 dark:text-green-400">Deployed At</dt>
            <dd class="text-gray-900 dark:text-gray-100"><%= @deployment_request.deployed_at&.strftime("%B %d, %Y at %H:%M UTC") %></dd>
          </div>
        </dl>
      </div>
    <% end %>

  </div>

  <!-- Right: Actions -->
  <div class="space-y-6">

    <% unless @deployment_request.status.in?(%w[active cancelled]) %>
      <!-- Activate Form -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Mark as Deployed</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Fill in the subdomain and secret after provisioning the Hetzner VPS. This will auto-send the "Your API is live" email to the customer.</p>

        <%= form_with url: activate_admin_private_deployment_path(@deployment_request), method: :patch, local: true, data: { turbo: false } do |f| %>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Subdomain Slug <span class="text-red-500">*</span></label>
              <div class="flex items-center border border-gray-300 dark:border-gray-600 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500">
                <%= text_field_tag :subdomain_slug, "",
                  placeholder: "mycoolbusiness",
                  class: "flex-1 px-3 py-2 bg-white dark:bg-gray-700 dark:text-gray-100 focus:outline-none text-sm",
                  required: true,
                  pattern: "[a-z0-9\\-]{2,40}" %>
                <span class="px-3 py-2 bg-gray-50 dark:bg-gray-700 text-xs text-gray-500 border-l border-gray-300 dark:border-gray-600 whitespace-nowrap">.requiems.xyz</span>
              </div>
              <p class="mt-1 text-xs text-gray-400">Lowercase letters, numbers, hyphens. 2–40 chars.</p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Tenant Secret (BACKEND_SECRET) <span class="text-red-500">*</span></label>
              <%= text_field_tag :tenant_secret, "",
                placeholder: "32+ character secret",
                class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white dark:bg-gray-700 dark:text-gray-100 font-mono text-sm",
                required: true,
                minlength: 32 %>
              <p class="mt-1 text-xs text-gray-400">The BACKEND_SECRET value set on their VPS. Min 32 chars.</p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Admin Notes</label>
              <%= text_area_tag :admin_notes, @deployment_request.admin_notes,
                rows: 2,
                placeholder: "Hetzner server ID, IP, any notes...",
                class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none bg-white dark:bg-gray-700 dark:text-gray-100 text-sm" %>
            </div>

            <%= submit_tag "Mark as Deployed + Send Email",
              class: "w-full px-4 py-3 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition-colors",
              data: { confirm: "This will send the deployment-ready email to #{@deployment_request.contact_email}. Continue?", disable_with: "Activating..." } %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @deployment_request.status != "cancelled" %>
      <!-- Cancel -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
        <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Cancel Request</h2>
        <%= button_to "Cancel Deployment Request",
          cancel_admin_private_deployment_path(@deployment_request),
          method: :patch,
          class: "w-full px-4 py-2 border border-red-300 dark:border-red-700 text-red-600 dark:text-red-400 text-sm font-medium rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors",
          data: { confirm: "Mark this request as cancelled?" } %>
      </div>
    <% end %>

  </div>
</div>
