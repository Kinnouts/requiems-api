<% content_for :title, "Private Deployments" %>

<!-- Header -->
<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Private Deployments</h1>
    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Manage per-tenant dedicated API deployment requests</p>
  </div>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <p class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Pending</p>
    <p class="text-3xl font-bold text-orange-500"><%= PrivateDeploymentRequest.pending.count %></p>
  </div>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <p class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Deploying</p>
    <p class="text-3xl font-bold text-blue-500"><%= PrivateDeploymentRequest.deploying.count %></p>
  </div>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <p class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Active</p>
    <p class="text-3xl font-bold text-green-600"><%= PrivateDeploymentRequest.active.count %></p>
  </div>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <p class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Cancelled</p>
    <p class="text-3xl font-bold text-gray-400"><%= PrivateDeploymentRequest.cancelled.count %></p>
  </div>
</div>

<!-- Filter Tabs -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex space-x-4">
    <% [["All", nil], ["Pending", "pending"], ["Deploying", "deploying"], ["Active", "active"], ["Cancelled", "cancelled"]].each do |label, value| %>
      <%= link_to label,
        admin_private_deployments_path(status: value),
        class: "px-4 py-2 rounded-md text-sm font-medium transition-colors #{params[:status] == value ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300' : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100'}" %>
    <% end %>
  </div>

  <% if @deployment_requests.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Company</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tier</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Services</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Submitted</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
          <% @deployment_requests.each do |dr| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
              <td class="px-6 py-4">
                <div class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= dr.company %></div>
                <div class="text-xs text-gray-500 dark:text-gray-400"><%= dr.contact_email %></div>
                <% if dr.subdomain_slug.present? %>
                  <div class="text-xs font-mono text-blue-600 dark:text-blue-400 mt-0.5"><%= dr.subdomain_slug %>.requiems.xyz</div>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900 dark:text-gray-100 capitalize"><%= dr.server_tier %></div>
                <div class="text-xs text-gray-500 dark:text-gray-400">$<%= "%.0f" % dr.monthly_price_dollars %>/mo</div>
              </td>
              <td class="px-6 py-4">
                <div class="flex flex-wrap gap-1 max-w-xs">
                  <% dr.selected_services.first(4).each do |svc| %>
                    <span class="inline-block text-xs bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-2 py-0.5 rounded"><%= svc %></span>
                  <% end %>
                  <% if dr.selected_services.length > 4 %>
                    <span class="inline-block text-xs text-gray-400">+<%= dr.selected_services.length - 4 %> more</span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                <%= time_ago_in_words(dr.created_at) %> ago
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%
                  badge_variant = case dr.status
                    when "pending"   then "warning"
                    when "deploying" then "primary"
                    when "active"    then "success"
                    else "default"
                  end
                %>
                <%= render "partials/shared/badge", text: dr.status.capitalize, variant: badge_variant, size: "xs" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "View", admin_private_deployment_path(dr), class: "text-blue-600 hover:text-blue-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-16 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">No deployment requests</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">None yet in this category.</p>
    </div>
  <% end %>
</div>
