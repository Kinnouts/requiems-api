<%
  sidebar_categories = local_assigns.fetch(:categories, [])
%>

<div class="h-full p-4">
  <h3 class="text-xs font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider mb-3 px-2">
    API Directory
  </h3>

  <nav class="space-y-0.5">
    <!-- Most Popular -->
    <a href="<%= apis_path %>" class="flex items-center px-2 py-2 text-sm font-medium rounded transition-colors text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
      <span class="mr-2 inline-flex items-center justify-center w-6 h-6 rounded-full bg-yellow-100 dark:bg-yellow-900 text-yellow-500 dark:text-yellow-300 flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
          <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.006Z" clip-rule="evenodd" />
        </svg>
      </span>
      <span class="flex-1">Most Popular</span>
    </a>

    <!-- Live Category Links -->
    <% sidebar_categories.each do |category| %>
      <%= link_to category_path(category["id"]), class: "flex items-center px-2 py-2 text-sm font-medium rounded transition-colors text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700" do %>
        <span class="mr-2 inline-flex items-center justify-center w-6 h-6 rounded-full flex-shrink-0 <%= category_color_classes(category["id"]) %>">
          <%= category_icon_svg(category["id"], size: "w-3.5 h-3.5") %>
        </span>
        <span class="flex-1"><%= category["name"] %></span>
      <% end %>
    <% end %>

    <!-- Coming Soon Categories -->
    <% api_categories.select { |c| c["coming_soon"] }.each do |category| %>
      <%= link_to category_path(category["id"]), class: "flex items-center px-2 py-2 text-sm font-medium rounded transition-colors text-gray-400 dark:text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700" do %>
        <span class="mr-2 inline-flex items-center justify-center w-6 h-6 rounded-full flex-shrink-0 <%= category_color_classes(category["id"]) %> opacity-60">
          <%= category_icon_svg(category["id"], size: "w-3.5 h-3.5") %>
        </span>
        <span class="flex-1"><%= category["name"] %></span>
      <% end %>
    <% end %>
  </nav>
</div>
