<%
  section_category = local_assigns.fetch(:category, {})
  section_apis = local_assigns.fetch(:apis, [])
  category_id = section_category["id"]
  category_name = section_category["name"]
  category_description = section_category["short_description"] || section_category["description"]
%>

<% if section_apis.any? %>
  <section id="category-<%= category_id %>" class="mb-10 scroll-mt-6" data-api-search-target="section">
    <!-- Section Header -->
    <div class="mb-4">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 flex items-center">
        <span class="mr-2 inline-flex items-center justify-center w-8 h-8 rounded-full flex-shrink-0 <%= category_color_classes(category_id) %>">
          <%= category_icon_svg(category_id, size: "w-4 h-4") %>
        </span>
        <%= link_to category_name, category_path(category_id), class: "hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
      </h2>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
        <%= category_description %>
      </p>
    </div>

    <!-- API Cards Grid - 5 columns on larger screens -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-3" data-api-search-target="grid">
      <% section_apis.each do |api| %>
        <%= render 'partials/apis_index/api_card', api: api %>
      <% end %>
    </div>
  </section>
<% end %>
