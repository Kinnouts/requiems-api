<%
  popular_apis_list = local_assigns.fetch(:apis, [])
%>

<% if popular_apis_list.any? %>
  <section id="most-popular" class="mb-10 scroll-mt-6" data-api-search-target="section">
    <!-- Section Header -->
    <div class="mb-4">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 flex items-center">
        <span class="mr-2 inline-flex items-center justify-center w-8 h-8 rounded-full flex-shrink-0 bg-yellow-100 dark:bg-yellow-900 text-yellow-500 dark:text-yellow-300">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.006Z" clip-rule="evenodd" />
          </svg>
        </span>
        Most Popular
      </h2>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
        Our most popular APIs based on usage and customer satisfaction.
      </p>
    </div>

    <!-- API Cards Grid - 5 columns on larger screens -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-3" data-api-search-target="grid">
      <% popular_apis_list.each do |api| %>
        <%= render 'partials/apis_index/api_card', api: api %>
      <% end %>
    </div>
  </section>
<% end %>
