<div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
  <div class="px-8 py-6">
    <!-- Page Title & Description -->
    <div class="flex items-start justify-between mb-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">API Directory</h1>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
          Unlock all our APIs with a single API key -
          <% unless user_signed_in? %>
            <span class="font-medium text-blue-600 hover:text-blue-700 cursor-pointer" onclick="window.location.href='<%= new_user_registration_path %>'">Sign up for a free API key</span>
          <% else %>
            <span>Browse our collection of production-ready APIs</span>
          <% end %>
          to get started.
        </p>
      </div>
      <% unless user_signed_in? %>
        <%= link_to "Get Free API Key", new_user_registration_path, class: "inline-flex items-center px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors" %>
      <% end %>
    </div>

    <!-- Search Bar -->
    <div data-controller="api-search">
      <div class="relative max-w-2xl">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
        <input type="text"
               data-api-search-target="input"
               data-action="input->api-search#filter"
               placeholder="Search..."
               value="<%= @search_query %>"
               class="block w-full pl-10 pr-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
      </div>

      <!-- Empty State -->
      <div class="hidden text-center py-12 mt-8 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700" data-api-search-target="empty">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">No APIs found</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Try adjusting your search terms.</p>
      </div>
    </div>
  </div>
</div>
