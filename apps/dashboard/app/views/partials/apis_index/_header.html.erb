<div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 py-10 px-8">
  <div class="text-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-3">API Directory</h1>
    <p class="text-base text-gray-600 dark:text-gray-400">
      Unlock all our APIs with a single API key &mdash;
      <% if user_signed_in? %>
        Browse our collection of production-ready APIs.
      <% else %>
        <%= link_to new_user_registration_path, class: "font-semibold text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300" do %>Sign up for a <strong>free API key</strong><% end %> to get started.
      <% end %>
    </p>
  </div>

  <div class="relative max-w-2xl mx-auto">
    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
      <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </div>
    <input type="text"
           data-api-search-target="input"
           data-action="input->api-search#filter"
           placeholder="Search APIs..."
           value="<%= @search_query %>"
           class="block w-full pl-10 pr-3 py-2.5 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
  </div>
</div>
