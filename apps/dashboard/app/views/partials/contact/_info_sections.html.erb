<h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-6"><%= t("home.contact.heading") %></h1>

<p class="text-lg text-gray-600 dark:text-gray-400 mb-12">
  <%= t("home.contact.intro") %>
</p>

<!-- General Questions -->
<div class="mb-10">
  <div class="flex items-start mb-3">
    <svg class="h-6 w-6 text-blue-600 mr-3 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
    <div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.contact.general_questions.heading") %></h2>
      <p class="text-gray-600 dark:text-gray-400 mb-3">
        <%= t("home.contact.general_questions.text") %> <%= link_to "eliaz@bobadilla.tech", "mailto:eliaz@bobadilla.tech", class: "text-blue-600 hover:text-blue-700 font-medium" %>.
      </p>
    </div>
  </div>
</div>

<!-- Technical Support -->
<div class="mb-10">
  <div class="flex items-start mb-3">
    <svg class="h-6 w-6 text-blue-600 mr-3 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
    <div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">
        <%= t("home.contact.technical_support.heading") %>
        <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-300">
          <%= t("home.contact.technical_support.badge") %>
        </span>
      </h2>
      <p class="text-gray-600 dark:text-gray-400 mb-3">
        <%= t("home.contact.technical_support.text") %>
      </p>
    </div>
  </div>
</div>
