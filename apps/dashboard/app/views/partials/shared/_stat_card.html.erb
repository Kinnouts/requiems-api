<%
  # Statistics card component for dashboards
  # Usage: render "shared/stat_card", title: "Total Requests", value: "1.2M", change: "+12%", trend: "up"

  stat_title = local_assigns.fetch(:title, "")
  stat_value = local_assigns.fetch(:value, "")
  stat_subtitle = local_assigns.fetch(:subtitle, nil)
  stat_change = local_assigns.fetch(:change, nil)
  stat_trend = local_assigns.fetch(:trend, nil)  # "up", "down", or nil
  stat_icon = local_assigns.fetch(:icon, nil)
  stat_extra_classes = local_assigns.fetch(:class_names, "")

  # Trend colors
  stat_trend_colors = {
    "up" => "text-green-600",
    "down" => "text-red-600"
  }

  stat_trend_class = stat_trend_colors[stat_trend] || "text-gray-600 dark:text-gray-400"
%>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 <%= stat_extra_classes %>">
  <div class="flex items-center justify-between">
    <div class="flex-1">
      <p class="text-sm font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wide">
        <%= stat_title %>
      </p>
      <p class="mt-2 text-3xl font-bold text-gray-900 dark:text-gray-100">
        <%= stat_value %>
      </p>

      <% if stat_subtitle.present? %>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          <%= stat_subtitle %>
        </p>
      <% end %>

      <% if stat_change.present? %>
        <p class="mt-2 text-sm <%= stat_trend_class %> font-medium">
          <% if stat_trend == "up" %>
            <span>↑</span>
          <% elsif stat_trend == "down" %>
            <span>↓</span>
          <% end %>
          <%= stat_change %>
        </p>
      <% end %>
    </div>

    <% if stat_icon.present? %>
      <div class="flex-shrink-0">
        <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center">
          <%= stat_icon %>
        </div>
      </div>
    <% end %>
  </div>
</div>
