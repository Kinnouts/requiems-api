<%
  # Reusable infinite logo marquee strip.
  #
  # Usage:
  #   render "partials/shared/logo_marquee",
  #     logos:      [{ file: "companies/foo.png", alt: "Foo" }, ...],
  #     label:      "Trusted by teams worldwide",
  #     reverse:    false,
  #     speed:      "30s",
  #     bg_class:   "bg-white dark:bg-gray-950 border-y border-gray-100 dark:border-gray-800",
  #     label_class: "text-gray-400 dark:text-gray-500",
  #     logo_class:  "opacity-60 hover:opacity-100 hover:brightness-110 hover:drop-shadow-[0_0_10px_rgba(99,102,241,0.2)] transition-all duration-300"

  logos       = local_assigns.fetch(:logos, [])
  label       = local_assigns.fetch(:label, nil)
  reverse     = local_assigns.fetch(:reverse, false)
  speed       = local_assigns.fetch(:speed, "32s")
  bg_class    = local_assigns.fetch(:bg_class,    "bg-white dark:bg-gray-950 border-y border-gray-100 dark:border-gray-800")
  label_class = local_assigns.fetch(:label_class, "text-gray-400 dark:text-gray-500")
  logo_class  = local_assigns.fetch(:logo_class,  "opacity-60 hover:opacity-100 hover:brightness-110 transition-all duration-300")

  anim_name   = reverse ? "lm-reverse-#{speed.gsub(/\W/,'')}" : "lm-forward-#{speed.gsub(/\W/,'')}"
  from_x      = reverse ? "-50%" : "0%"
  to_x        = reverse ? "0%"   : "-50%"
  track_id    = "lm-track-#{SecureRandom.hex(4)}"
%>

<style>
  @keyframes <%= anim_name %> {
    from { transform: translateX(<%= from_x %>); }
    to   { transform: translateX(<%= to_x %>); }
  }
  #<%= track_id %> {
    display: flex;
    width: max-content;
    animation: <%= anim_name %> <%= speed %> linear infinite;
  }
  #<%= track_id %>:hover { animation-play-state: paused; }
  .lm-outer {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
  }
  .lm-slot {
    width: 220px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
  }
  .lm-slot img {
    height: 40px;
    width: auto;
    max-width: 172px;
    object-fit: contain;
  }
</style>

<div class="py-14 <%= bg_class %>">
  <% if label.present? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-semibold tracking-widest uppercase mb-10 <%= label_class %>">
        <%= label %>
      </p>
    </div>
  <% end %>

  <div class="lm-outer">
    <div id="<%= track_id %>">
      <% 2.times do %>
        <% logos.each do |logo| %>
          <div class="lm-slot">
            <%= image_tag logo[:file], alt: logo[:alt], class: logo_class %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
