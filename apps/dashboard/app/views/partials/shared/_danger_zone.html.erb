<%
  # Danger Zone component
  #
  # Renders a self-contained red danger card. Clicking "Delete Account" opens a
  # modal where the user submits a reason. A time-limited confirmation email is
  # then sent — the actual deletion only happens after clicking the link in that email.
  #
  # Required locals:
  #   form_url (String) — URL for the POST request_deletion action
  #
  # Optional locals:
  #   title       (String) — action name in the card (default: "Delete Account")
  #   description (String) — one-line description of the action
  #   bullets     (Array)  — list of consequence strings

  title       = local_assigns.fetch(:title, "Delete Account")
  description = local_assigns.fetch(:description, "Permanently delete your account and all associated data. This action cannot be undone.")
  bullets     = local_assigns.fetch(:bullets, [
    "All API keys will be revoked immediately",
    "Your subscription will be canceled",
    "All usage data will be permanently deleted",
  ])
%>

<div
  class="bg-white dark:bg-gray-800 rounded-lg shadow border-2 border-red-200 dark:border-red-800"
  data-controller="request-deletion"
>
  <!-- Card Header -->
  <div class="px-6 py-4 bg-red-50 dark:bg-red-900/30 border-b border-red-200 dark:border-red-800 rounded-t-lg">
    <div class="flex items-center gap-2">
      <svg class="h-5 w-5 text-red-600 dark:text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <h2 class="text-lg font-semibold text-red-900 dark:text-red-300">Danger Zone</h2>
    </div>
    <p class="text-sm text-red-700 dark:text-red-400 mt-1 ml-7">Irreversible actions that permanently affect your account</p>
  </div>

  <!-- Card Body -->
  <div class="p-6">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
      <!-- Description + bullets -->
      <div class="flex-1">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-1"><%= title %></h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-3"><%= description %></p>
        <ul class="space-y-1.5">
          <% bullets.each do |bullet| %>
            <li class="flex items-start gap-2 text-xs text-gray-600 dark:text-gray-400">
              <svg class="h-4 w-4 text-red-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
              </svg>
              <span><%= bullet %></span>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Trigger -->
      <div class="flex-shrink-0">
        <button
          type="button"
          data-action="click->request-deletion#open"
          class="px-5 py-2.5 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 active:bg-red-800 transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800"
        >
          Delete Account
        </button>
      </div>
    </div>
  </div>

  <!-- Reason Modal -->
  <div
    data-request-deletion-target="modal"
    data-action="click->request-deletion#closeOnBackdrop"
    class="hidden fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="deletion-modal-title"
  >
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-md w-full overflow-hidden">

      <!-- Modal Header -->
      <div class="px-6 pt-6 pb-4 border-b border-gray-100 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="flex-shrink-0 w-10 h-10 bg-red-100 dark:bg-red-900/50 rounded-full flex items-center justify-center">
              <svg class="h-5 w-5 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
            </div>
            <h3 id="deletion-modal-title" class="text-lg font-semibold text-gray-900 dark:text-gray-100">
              Delete your account?
            </h3>
          </div>
          <button
            type="button"
            data-action="click->request-deletion#close"
            class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors rounded-lg p-1 focus:outline-none focus:ring-2 focus:ring-gray-400"
            aria-label="Close"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Modal Body -->
      <div class="px-6 py-5">
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-5">
          We'll send a confirmation link to
          <strong class="text-gray-900 dark:text-gray-100"><%= current_user.email %></strong>.
          The link expires in <strong class="text-gray-900 dark:text-gray-100">1 hour</strong>.
        </p>

        <%= form_with url: form_url, method: :post, local: true do |f| %>

          <!-- Reason textarea -->
          <div class="mb-5">
            <%= f.label :deletion_reason, "Why are you leaving?",
              class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= f.text_area :deletion_reason,
              rows: 3,
              placeholder: "Tell us what we could have done better...",
              data: {
                "request_deletion_target": "textarea",
                action: "input->request-deletion#validate",
              },
              class: "w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent resize-none transition-colors" %>
            <p data-request-deletion-target="counter" class="text-xs mt-1.5"></p>
          </div>

          <!-- Actions -->
          <div class="flex gap-3">
            <button
              type="button"
              data-action="click->request-deletion#close"
              class="flex-1 px-4 py-2.5 border border-gray-300 dark:border-gray-600 text-sm font-medium text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-gray-400"
            >
              Cancel
            </button>
            <%= f.submit "Send Confirmation Email",
              disabled: true,
              data: {
                "request_deletion_target": "submit",
                disable_with: "Sending...",
              },
              class: "flex-1 px-4 py-2.5 bg-red-600 text-white text-sm font-medium rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800 disabled:opacity-40 disabled:cursor-not-allowed enabled:hover:bg-red-700 enabled:active:bg-red-800 cursor-pointer" %>
          </div>

        <% end %>
      </div>
    </div>
  </div>
</div>
