<%
  # Reusable card component
  # Usage: render "shared/card", title: "Statistics", padding: true do ... end

  card_title = local_assigns.fetch(:title, nil)
  card_subtitle = local_assigns.fetch(:subtitle, nil)
  card_padding = local_assigns.fetch(:padding, true)
  card_hover = local_assigns.fetch(:hover, false)
  card_extra_classes = local_assigns.fetch(:class_names, "")
  card_header_action = local_assigns.fetch(:header_action, nil)

  # Base styles
  card_base = "bg-white dark:bg-gray-800 rounded-lg shadow"
  card_base += " hover:shadow-lg transition-shadow" if card_hover

  # Card wrapper class
  card_wrapper_class = [card_base, card_extra_classes].reject(&:blank?).join(" ")

  # Content padding
  card_content_padding = card_padding ? "p-6" : ""
%>

<div class="<%= card_wrapper_class %>">
  <% if card_title.present? || card_subtitle.present? || card_header_action.present? %>
    <div class="border-b border-gray-200 dark:border-gray-700 px-6 py-4 flex items-center justify-between">
      <div>
        <% if card_title.present? %>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= card_title %></h3>
        <% end %>
        <% if card_subtitle.present? %>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><%= card_subtitle %></p>
        <% end %>
      </div>
      <% if card_header_action.present? %>
        <div class="flex-shrink-0">
          <%= card_header_action %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="<%= card_content_padding %>">
    <%= yield %>
  </div>
</div>
