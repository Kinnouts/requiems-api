<%
  # Alert/notification component
  # Usage: render "shared/alert", message: "Success!", variant: "success", dismissible: true

  alert_message = local_assigns.fetch(:message, "")
  alert_title = local_assigns.fetch(:title, nil)
  alert_variant = local_assigns.fetch(:variant, "info")
  alert_dismissible = local_assigns.fetch(:dismissible, false)
  alert_extra_classes = local_assigns.fetch(:class_names, "")

  # Base styles
  alert_base = "rounded-lg p-4"

  # Variant styles
  alert_variants = {
    "success" => "bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-800 dark:text-green-300",
    "error" => "bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-300",
    "warning" => "bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 text-yellow-800 dark:text-yellow-300",
    "info" => "bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 text-blue-800 dark:text-blue-300"
  }

  # Icon colors
  alert_icon_colors = {
    "success" => "text-green-400",
    "error" => "text-red-400",
    "warning" => "text-yellow-400",
    "info" => "text-blue-400"
  }

  alert_classes = [alert_base, alert_variants[alert_variant], alert_extra_classes].reject(&:blank?).join(" ")
  alert_icon_class = alert_icon_colors[alert_variant]

  # Icons (using Unicode symbols for simplicity)
  alert_icons = {
    "success" => "✓",
    "error" => "✕",
    "warning" => "⚠",
    "info" => "ℹ"
  }
%>

<div class="<%= alert_classes %>" <%= 'data-controller="alert"' if alert_dismissible %>>
  <div class="flex items-start">
    <div class="flex-shrink-0">
      <span class="<%= alert_icon_class %> text-xl"><%= alert_icons[alert_variant] %></span>
    </div>

    <div class="ml-3 flex-1">
      <% if alert_title.present? %>
        <h3 class="text-sm font-medium mb-1">
          <%= alert_title %>
        </h3>
      <% end %>

      <div class="text-sm">
        <%= alert_message %>
      </div>
    </div>

    <% if alert_dismissible %>
      <div class="ml-auto pl-3">
        <button type="button" class="-mx-1.5 -my-1.5 rounded-lg p-1.5 inline-flex hover:bg-opacity-20 focus:outline-none" data-action="click->alert#dismiss">
          <span class="sr-only">Dismiss</span>
          <span class="text-lg">×</span>
        </button>
      </div>
    <% end %>
  </div>
</div>
