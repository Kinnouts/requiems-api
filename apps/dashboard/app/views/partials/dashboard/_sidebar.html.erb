<div class="bg-white dark:bg-gray-800 rounded-lg shadow sticky top-20">
  <!-- User Info -->
  <div class="p-6 border-b border-gray-200 dark:border-gray-700">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <img src="<%= gravatar_url(current_user.email, size: 48) %>" alt="Avatar" class="h-12 w-12 rounded-full">
      </div>
      <div class="ml-3 flex-1 min-w-0">
        <p class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate">
          <%= current_user.email %>
        </p>
        <% if current_user.subscription %>
          <%= render "partials/shared/badge",
            text: current_user.subscription.plan_name.titleize,
            variant: current_user.subscription.plan_name == "free" ? "default" : "primary",
            size: "xs",
            class_names: "mt-1" %>
        <% else %>
          <%= render "partials/shared/badge", text: "Free", variant: "default", size: "xs", class_names: "mt-1" %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="p-4">
    <ul class="space-y-1">
      <%= render "partials/dashboard/sidebar_link",
        icon: "chart-bar",
        text: "Dashboard",
        path: dashboard_root_path,
        active: controller_name == "overview" %>

      <%= render "partials/dashboard/sidebar_link",
        icon: "key",
        text: "API Keys",
        path: dashboard_api_keys_path,
        active: controller_name == "api_keys" %>

      <%= render "partials/dashboard/sidebar_link",
        icon: "chart-line",
        text: "Usage & Analytics",
        path: dashboard_usage_path,
        active: controller_name == "usage" %>

      <%= render "partials/dashboard/sidebar_link",
        icon: "credit-card",
        text: "Billing",
        path: dashboard_billing_path,
        active: controller_name == "billing" %>

      <%= render "partials/dashboard/sidebar_link",
        icon: "cog",
        text: "Settings",
        path: dashboard_settings_path,
        active: controller_name == "settings" %>
    </ul>
  </nav>

  <!-- Quick Actions -->
  <div class="p-4 border-t border-gray-200 dark:border-gray-700">
    <%= link_to apis_path, class: "block w-full text-center px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors mb-2" do %>
      <svg class="h-4 w-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      API Documentation
    <% end %>

    <%= link_to examples_path, class: "block w-full text-center px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors" do %>
      <svg class="h-4 w-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
      </svg>
      View Examples
    <% end %>
  </div>
</div>
