<%
  card_name = local_assigns.fetch(:name, "")
  card_monthly_price = local_assigns.fetch(:monthly_price, 0)
  card_yearly_price = local_assigns.fetch(:yearly_price, 0)
  card_description = local_assigns.fetch(:description, "")
  card_requests = local_assigns.fetch(:requests, "")
  card_rate_limit = local_assigns.fetch(:rate_limit, "")
  card_features = local_assigns.fetch(:features, [])
  card_cta_text = local_assigns.fetch(:cta_text, "Get Started")
  card_cta_url = local_assigns.fetch(:cta_url, "#")
  card_popular = local_assigns.fetch(:popular, false)
%>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg <%= 'ring-2 ring-blue-600 relative' if card_popular %> overflow-hidden">
  <% if card_popular %>
    <div class="absolute top-0 right-0 bg-blue-600 text-white px-4 py-1 text-xs font-semibold uppercase rounded-bl-lg">
      <%= t("home.pricing.plans.popular_badge") %>
    </div>
  <% end %>

  <div class="p-6 flex flex-col h-full">
    <!-- Plan Name -->
    <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2"><%= card_name %></h3>
    <p class="text-gray-600 dark:text-gray-400 text-sm mb-6 h-10 line-clamp-2"><%= card_description %></p>

    <!-- Price -->
    <div class="mb-6">
      <div data-pricing-toggle-target="monthlyPrice">
        <div class="flex items-baseline gap-1">
          <span class="text-4xl font-bold text-gray-900 dark:text-gray-100">$<%= card_monthly_price %></span>
          <span class="text-gray-600 dark:text-gray-400"><%= t("home.pricing.plans.per_month") %></span>
        </div>
        <p class="invisible text-sm mt-1">&nbsp;</p>
      </div>

      <div class="hidden" data-pricing-toggle-target="yearlyPrice">
        <div class="flex items-baseline gap-1">
          <span class="text-4xl font-bold text-gray-900 dark:text-gray-100">$<%= card_yearly_price %></span>
          <span class="text-gray-600 dark:text-gray-400"><%= t("home.pricing.plans.per_month") %></span>
        </div>
        <% if card_yearly_price > 0 && card_monthly_price > card_yearly_price %>
          <p class="text-sm text-green-600 mt-1">
            <%= t("home.pricing.plans.save_per_year", amount: ((card_monthly_price - card_yearly_price) * 12).to_i) %>
          </p>
        <% end %>
      </div>
    </div>

    <!-- Features List -->
    <div class="border-t border-gray-200 dark:border-gray-700 pt-6 flex-1">
      <ul class="space-y-3">
        <% card_features.each do |feature| %>
          <li class="flex items-start">
            <svg class="h-5 w-5 text-green-500 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-gray-700 dark:text-gray-300"><%= feature %></span>
          </li>
        <% end %>
      </ul>
    </div>

    <!-- CTA Button -->
    <div class="mt-6">
      <% if card_cta_url.is_a?(Hash) && card_cta_url[:method] == :post %>
        <%= form_with url: card_cta_url[:url], method: :post, data: { turbo: false } do |f| %>
          <%= f.hidden_field :plan, value: card_cta_url[:params][:plan] %>
          <%= f.hidden_field :billing_cycle, value: "monthly", data: { pricing_toggle_target: "billingCycleInput" } %>
          <%= f.submit card_cta_text, class: "block w-full px-6 py-3 #{card_popular ? 'bg-blue-600 hover:bg-blue-700 text-white' : 'bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-900 dark:text-gray-100'} font-medium rounded-lg transition-colors cursor-pointer" %>
        <% end %>
      <% else %>
        <%= link_to card_cta_text, card_cta_url, class: "block w-full text-center px-6 py-3 #{card_popular ? 'bg-blue-600 hover:bg-blue-700 text-white' : 'bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-900 dark:text-gray-100'} font-medium rounded-lg transition-colors" %>
      <% end %>
    </div>
  </div>
</div>
