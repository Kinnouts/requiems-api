<%
  faq_question = local_assigns.fetch(:question, "")
  faq_answer = local_assigns.fetch(:answer, "")
%>

<div class="border border-gray-200 rounded-lg">
  <button type="button"
          class="w-full px-6 py-4 text-left flex items-center justify-between hover:bg-gray-50 transition-colors"
          data-action="click->faq-accordion#toggle"
          data-faq-accordion-target="button">
    <span class="font-medium text-gray-900"><%= faq_question %></span>
    <svg class="h-5 w-5 text-gray-500 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </button>
  <div class="hidden px-6 pb-4 text-gray-700" data-faq-accordion-target="content">
    <%= faq_answer %>
  </div>
</div>
