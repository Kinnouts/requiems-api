<div class="bg-gray-50 dark:bg-gray-900 py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 dark:text-gray-100">
        <%= t("home.index.faq.heading") %>
      </h2>
      <p class="mt-4 text-xl text-gray-600 dark:text-gray-400">
        <%= t("home.index.faq.subheading") %>
      </p>
    </div>

    <div class="space-y-4" data-controller="tabs">
      <!-- FAQ 1 -->
      <%= render "partials/shared/card", padding: true do %>
        <button class="w-full flex justify-between items-center text-left" data-action="click->tabs#select" data-tabs-index-param="0">
          <span class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("home.index.faq.q1") %></span>
          <svg class="h-5 w-5 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mt-4 text-gray-600 dark:text-gray-400 hidden" data-tabs-target="panel">
          <%= t("home.index.faq.a1") %>
        </div>
      <% end %>

      <!-- FAQ 2 -->
      <%= render "partials/shared/card", padding: true do %>
        <button class="w-full flex justify-between items-center text-left" data-action="click->tabs#select" data-tabs-index-param="1">
          <span class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("home.index.faq.q2") %></span>
          <svg class="h-5 w-5 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mt-4 text-gray-600 dark:text-gray-400 hidden" data-tabs-target="panel">
          <%= t("home.index.faq.a2") %>
        </div>
      <% end %>

      <!-- FAQ 3 -->
      <%= render "partials/shared/card", padding: true do %>
        <button class="w-full flex justify-between items-center text-left" data-action="click->tabs#select" data-tabs-index-param="2">
          <span class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("home.index.faq.q3") %></span>
          <svg class="h-5 w-5 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mt-4 text-gray-600 dark:text-gray-400 hidden" data-tabs-target="panel">
          <%= t("home.index.faq.a3") %>
        </div>
      <% end %>

      <!-- FAQ 4 -->
      <%= render "partials/shared/card", padding: true do %>
        <button class="w-full flex justify-between items-center text-left" data-action="click->tabs#select" data-tabs-index-param="3">
          <span class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= t("home.index.faq.q4") %></span>
          <svg class="h-5 w-5 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mt-4 text-gray-600 dark:text-gray-400 hidden" data-tabs-target="panel">
          <%= t("home.index.faq.a4") %>
        </div>
      <% end %>
    </div>

    <div class="mt-12 text-center">
      <p class="text-gray-600 dark:text-gray-400 mb-4"><%= t("home.index.faq.still_questions") %></p>
      <%= link_to contact_path, class: "inline-flex items-center text-blue-600 hover:text-blue-700 font-medium" do %>
        <%= t("home.index.faq.contact_link") %>
        <svg class="ml-1 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      <% end %>
    </div>
  </div>
</div>
