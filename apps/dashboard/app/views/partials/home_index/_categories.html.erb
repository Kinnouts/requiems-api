<div class="bg-white dark:bg-gray-800 py-20" id="api-docs">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-gray-900 dark:text-gray-100">
        <%= t("home.index.categories.heading") %>
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        <%= t("home.index.categories.description") %>
      </p>
    </div>

    <div class="grid gap-3 mb-16 grid-cols-2 md:grid-cols-8">
      <% @categories.first(16).each_with_index do |category, index| %>
        <%= link_to category_path(category["id"]),
            class: "group bg-gray-50 dark:bg-gray-700 rounded-lg p-4 text-center transition-all duration-200 hover:bg-blue-50 dark:hover:bg-gray-600 #{index >= 8 ? 'hidden md:block' : ''}" do %>
          <div class="text-3xl mb-2"><%= category["icon"] %></div>
          <h3 class="text-xs font-semibold text-gray-900 dark:text-gray-100 group-hover:text-blue-600 leading-tight">
            <%= category["name"] %>
          </h3>
        <% end %>
      <% end %>
    </div>

    <div class="text-center">
      <%= link_to apis_path, class: "inline-flex items-center justify-center px-8 py-3 bg-blue-600 text-white text-base font-medium rounded-lg hover:bg-blue-700 transition-colors shadow-sm" do %>
        <%= t("home.index.categories.browse_all") %>
      <% end %>
    </div>
  </div>
</div>
