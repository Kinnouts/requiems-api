<div class="bg-gray-50 dark:bg-gray-900 py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 dark:text-gray-100">
        Performance You Can Count On
      </h2>
      <p class="mt-4 text-xl text-gray-600 dark:text-gray-400">
        Enterprise-grade infrastructure without the enterprise complexity
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <%= render "partials/shared/stat_card", title: "Median Latency", value: "243ms", subtitle: "P50 response time", class_names: "border-2 border-blue-200" %>
      <%= render "partials/shared/stat_card", title: "Uptime", value: "99.99%", subtitle: "Last 12 months SLA", class_names: "border-2 border-green-200" %>
      <%= render "partials/shared/stat_card", title: "Monthly Requests", value: "200M+", subtitle: "Requests processed/month", class_names: "border-2 border-purple-200" %>
      <%= render "partials/shared/stat_card", title: "Data Centers", value: "EU", subtitle: "European Union", class_names: "border-2 border-yellow-200" %>
    </div>
  </div>
</div>
