<style>
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-scroll 30s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
</style>

<div class="py-14 bg-white dark:bg-gray-950 border-y border-gray-100 dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-xs font-semibold tracking-widest uppercase text-gray-400 dark:text-gray-500 mb-10">
      <%= t("home.index.trusted_by.label") %>
    </p>
  </div>

  <div class="overflow-hidden">
    <div class="marquee-track">
      <%# First set %>
      <div class="flex items-center gap-16 px-8">
        <%= image_tag "companies/bobadilla-tech.png",   alt: "Bobadilla Tech",    class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
        <%= image_tag "companies/compile-strength.png", alt: "Compile Strength",  class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
        <%= image_tag "companies/flyver.jpeg",          alt: "Flyver",            class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
        <%= image_tag "companies/flyver-docs.png",      alt: "Flyver Docs",       class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
        <%= image_tag "companies/korealexa.png",        alt: "Korealexa",         class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
        <%= image_tag "companies/verigeo.png",          alt: "Verigeo",           class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
      </div>
      <%# Duplicate for seamless loop %>
      <div class="flex items-center gap-16 px-8">
        <%= image_tag "companies/bobadilla-tech.png",   alt: "", class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
        <%= image_tag "companies/compile-strength.png", alt: "", class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
        <%= image_tag "companies/flyver.jpeg",          alt: "", class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
        <%= image_tag "companies/flyver-docs.png",      alt: "", class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
        <%= image_tag "companies/korealexa.png",        alt: "", class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
        <%= image_tag "companies/verigeo.png",          alt: "", class: "h-9 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 cursor-default" %>
      </div>
    </div>
  </div>
</div>
