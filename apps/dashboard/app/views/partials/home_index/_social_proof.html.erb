<% logos = [
  { file: "companies/verigeo.png",             alt: "Verigeo"          },
  { file: "companies/shareweave.jpeg",          alt: "Shareweave"       },
  { file: "companies/korealexa-whitebg.jpeg",   alt: "Korealexa"        },
  { file: "companies/flyver-docs.png",          alt: "Flyver Docs"      },
  { file: "companies/flyver.jpeg",              alt: "Fleyver"           },
  { file: "companies/compile-strength.png",     alt: "Compile Strength" },
  { file: "companies/bobadilla-tech.png",       alt: "Bobadilla Tech"   },
] %>

<%= render "partials/shared/logo_marquee",
      logos:       logos,
      label:       t("home.index.social_proof.label"),
      reverse:     true,
      speed:       "40s",
      bg_class:    "bg-gray-950 dark:bg-black",
      label_class: "text-gray-600 dark:text-gray-700",
      logo_class:  "opacity-40 hover:opacity-90 hover:brightness-110 hover:drop-shadow-[0_0_12px_rgba(255,255,255,0.12)] transition-all duration-300" %>
