<div class="relative bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800 text-white overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Hero copy -->
      <div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          <%= t("home.index.hero.title_line1") %>
          <span class="block text-yellow-300"><%= t("home.index.hero.title_line2") %></span>
        </h1>

        <p class="text-xl text-blue-100 mb-8">
          <%= t("home.index.hero.description") %>
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-4 border border-transparent text-base font-medium rounded-lg text-blue-700 bg-white hover:bg-gray-50 transition-colors shadow-lg" do %>
            <%= t("home.index.hero.cta_primary") %>
            <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          <% end %>

          <%= link_to apis_path, class: "inline-flex items-center justify-center px-8 py-4 border-2 border-white text-base font-medium rounded-lg text-white hover:bg-white/10 transition-colors" do %>
            <%= t("home.index.hero.cta_secondary") %>
          <% end %>
        </div>
      </div>

      <!-- Right: Animated API Playground -->
      <div data-controller="hero-demo">
        <div class="rounded-3xl overflow-hidden" style="background-color: #0d1117; border: 1px solid rgba(255,255,255,0.07); box-shadow: 0 25px 50px rgba(0,0,0,0.5), 0 0 40px rgba(37,99,235,0.12);">

          <!-- Titlebar: traffic lights + demo label -->
          <div class="px-4 py-3 flex items-center gap-3" style="background-color: #161b22; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <div class="flex items-center gap-1.5 shrink-0">
              <div class="w-3 h-3 rounded-full" style="background-color: #ff5f57;"></div>
              <div class="w-3 h-3 rounded-full" style="background-color: #febc2e;"></div>
              <div class="w-3 h-3 rounded-full" style="background-color: #28c840;"></div>
            </div>
            <span class="flex-1 text-center text-xs font-mono text-gray-200 truncate" data-hero-demo-target="demoLabel">Email Validation</span>
            <div class="shrink-0 w-14"></div><!-- balance the traffic lights -->
          </div>

          <!-- URL bar -->
          <div class="px-4 pt-4 pb-3">
            <div class="flex items-center gap-2 rounded-xl px-3 py-2" style="background-color: #0d1117; border: 1px solid rgba(255,255,255,0.06);">
<span class="flex-1 min-w-0" style="font-family:ui-monospace,monospace;font-size:12px;color:#e2e8f0;white-space:nowrap;overflow-x:auto;display:block;scrollbar-width:none;">api.requiems.xyz/v1/<span data-hero-demo-target="urlPath"></span></span>
            </div>
          </div>

          <!-- Divider -->
          <div style="height: 1px; background: rgba(255,255,255,0.04); margin: 0 1rem;"></div>

          <!-- Response area — fixed height (tall enough for longest demo) -->
          <div class="px-4 pt-3 pb-4">
            <div style="height: 320px; overflow-y: auto; overflow-x: hidden; scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.1) transparent;">
              <div data-hero-demo-target="responseArea"></div>
            </div>
          </div>
        </div>

        <!-- Demo indicator dots -->
        <div class="mt-4 flex items-center justify-center gap-2">
          <% 3.times do |i| %>
            <div class="rounded-full transition-all duration-300" style="<%= i == 0 ? 'width:8px;height:8px;background-color:rgb(96,165,250);' : 'width:6px;height:6px;background-color:rgba(255,255,255,0.2);' %>" data-hero-demo-target="dot"></div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
