<div class="relative bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800 text-white overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Hero copy -->
      <div>
        <h1 class="text-5xl lg:text-6xl font-bold leading-tight mb-6">
          <%= t("home.index.hero.title_line1") %>
          <span class="block text-yellow-300"><%= t("home.index.hero.title_line2") %></span>
        </h1>

        <p class="text-xl text-blue-100 mb-8">
          <%= t("home.index.hero.description") %>
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-4 border border-transparent text-base font-medium rounded-lg text-blue-700 bg-white hover:bg-gray-50 transition-colors shadow-lg" do %>
            <%= t("home.index.hero.cta_primary") %>
            <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          <% end %>

          <%= link_to apis_path, class: "inline-flex items-center justify-center px-8 py-4 border-2 border-white text-base font-medium rounded-lg text-white hover:bg-white/10 transition-colors" do %>
            <%= t("home.index.hero.cta_secondary") %>
          <% end %>
        </div>
      </div>

      <!-- Right: Code example / API demo -->
      <div class="lg:mt-0 mt-8">
        <div class="bg-gray-900 rounded-lg shadow-2xl overflow-hidden border border-gray-700">
          <!-- Terminal header -->
          <div class="bg-gray-800 px-3 sm:px-4 py-2 flex items-center space-x-2">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <span class="ml-2 sm:ml-4 text-gray-400 text-xs sm:text-sm"><%= t("home.index.hero.api_request") %></span>
          </div>

          <!-- Code -->
          <div class="p-3 sm:p-6 overflow-x-auto">
            <pre class="text-xs sm:text-sm font-mono text-gray-300 whitespace-pre"><code><span class="text-pink-400">curl</span> <span class="text-blue-400">-H</span> <span class="text-green-400">"requiems-api-key: YOUR_KEY"</span> \
  <span class="text-yellow-400">https://api.requiems.xyz/v1/text/advice</span>

{
  <span class="text-blue-400">"advice"</span>: <span class="text-green-400">"Don't compare yourself to others."</span>,
  <span class="text-blue-400">"id"</span>: <span class="text-yellow-400">42</span>
}</code></pre>
          </div>
        </div>

        <!-- Try it badge -->
        <div class="mt-4 text-center">
          <span class="text-xs sm:text-sm text-blue-200"><%= t("home.index.hero.try_badge") %></span>
        </div>
      </div>
    </div>
  </div>
</div>
