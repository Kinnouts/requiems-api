<div class="bg-white dark:bg-gray-800 py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 dark:text-gray-100">
        Security & Compliance First
      </h2>
      <p class="mt-4 text-xl text-gray-600 dark:text-gray-400">
        Enterprise-grade security for teams of all sizes
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- SOC 2 -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-blue-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">SOC 2 Certification</h3>
          <%= render "partials/shared/badge", text: "In Progress", variant: "info", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            In progress.
          </p>
        </div>
      </div>

      <!-- Data Encryption -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-green-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Data Encryption</h3>
          <%= render "partials/shared/badge", text: "Active", variant: "success", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            TLS 1.3 in transit, AES-256 at rest. Zero data storage policy for API inputs/outputs.
          </p>
        </div>
      </div>

      <!-- EU Infrastructure -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-purple-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">EU Infrastructure</h3>
          <%= render "partials/shared/badge", text: "EU", variant: "primary", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            All data centers located in the European Union. GDPR compliant.
          </p>
        </div>
      </div>

      <!-- Secure Payments -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-yellow-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Secure Payments</h3>
          <%= render "partials/shared/badge", text: "Stripe", variant: "success", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            All payments processed through Stripe. We never see or store your payment details.
          </p>
        </div>
      </div>

      <!-- GDPR Compliant -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-indigo-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">GDPR / CCPA Compliant</h3>
          <%= render "partials/shared/badge", text: "Compliant", variant: "success", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            Full compliance with GDPR, CCPA, and international privacy regulations.
          </p>
        </div>
      </div>

      <!-- API Security -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-red-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">API Security</h3>
          <%= render "partials/shared/badge", text: "Rate Limited", variant: "success", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            Built-in rate limiting, DDoS protection, and abuse prevention at the edge.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
