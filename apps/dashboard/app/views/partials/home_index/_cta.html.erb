<div class="bg-gradient-to-br from-blue-600 to-indigo-800 py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
      Ready to ship faster?
    </h2>
    <p class="text-xl text-blue-100 mb-8">
      Join thousands of developers building with production-ready APIs
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
      <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-medium rounded-lg text-blue-700 bg-white hover:bg-gray-50 transition-colors shadow-lg" do %>
        Get Started Free
        <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      <% end %>

      <%= link_to pricing_path, class: "inline-flex items-center justify-center px-8 py-4 border-2 border-white text-lg font-medium rounded-lg text-white hover:bg-white/10 transition-colors" do %>
        View Pricing
      <% end %>
    </div>

    <p class="text-sm text-blue-200">
      No credit card required • Get started free • Cancel anytime
    </p>
  </div>
</div>
