<div class="bg-gray-50 dark:bg-gray-900 py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 dark:text-gray-100">
        <%= t("home.index.features.heading") %>
      </h2>
      <p class="mt-4 text-xl text-gray-600 dark:text-gray-400">
        <%= t("home.index.features.subheading") %>
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Feature 1: Live Demos -->
      <%= render "partials/shared/card", padding: true, hover: true do %>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.index.features.playground_title") %></h3>
          <p class="text-gray-600 dark:text-gray-400">
            <%= t("home.index.features.playground_desc") %>
          </p>
        </div>
      <% end %>

      <!-- Feature 2: Code Examples -->
      <%= render "partials/shared/card", padding: true, hover: true do %>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 dark:bg-green-900 text-green-600 dark:text-green-300 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.index.features.examples_title") %></h3>
          <p class="text-gray-600 dark:text-gray-400">
            <%= t("home.index.features.examples_desc") %>
          </p>
        </div>
      <% end %>

      <!-- Feature 3: Precise Docs -->
      <%= render "partials/shared/card", padding: true, hover: true do %>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-purple-100 dark:bg-purple-900 text-purple-600 dark:text-purple-300 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.index.features.docs_title") %></h3>
          <p class="text-gray-600 dark:text-gray-400">
            <%= t("home.index.features.docs_desc") %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>
