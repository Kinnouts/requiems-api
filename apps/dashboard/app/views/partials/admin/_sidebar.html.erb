<div class="bg-white rounded-lg shadow sticky top-8">
  <!-- Admin Info -->
  <div class="p-6 border-b border-gray-200">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <div class="h-12 w-12 rounded-full bg-red-600 flex items-center justify-center text-white font-bold text-lg">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
      </div>
      <div class="ml-3 flex-1 min-w-0">
        <p class="text-sm font-medium text-gray-900 truncate">
          <%= current_user.email %>
        </p>
        <%= render "partials/shared/badge", text: "Admin", variant: "danger", size: "xs", class_names: "mt-1" %>
      </div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="p-4">
    <ul class="space-y-1">
      <%
        nav_items = [
          { icon: "chart-bar", text: "Dashboard", path: admin_root_path, controller: "dashboard" },
          { icon: "users", text: "Users", path: admin_users_path, controller: "users" },
          { icon: "key", text: "API Keys", path: admin_api_keys_path, controller: "api_keys" },
          { icon: "chart-line", text: "Analytics", path: admin_analytics_usage_path, controller: "analytics" },
          { icon: "flag", text: "Abuse Reports", path: admin_abuse_reports_path, controller: "abuse_reports" }
        ]
      %>

      <% nav_items.each do |item| %>
        <%
          is_active = controller_name == item[:controller]
          link_classes = if is_active
            "flex items-center px-4 py-3 text-sm font-medium text-blue-700 bg-blue-50 rounded-lg"
          else
            "flex items-center px-4 py-3 text-sm font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50 rounded-lg transition-colors"
          end

          icon_paths = {
            "chart-bar" => "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
            "users" => "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z",
            "key" => "M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z",
            "chart-line" => "M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z",
            "flag" => "M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"
          }
        %>

        <li>
          <%= link_to item[:path], class: link_classes do %>
            <svg class="h-5 w-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= icon_paths[item[:icon]] %>"/>
            </svg>
            <%= item[:text] %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </nav>

  <!-- Quick Actions -->
  <div class="p-4 border-t border-gray-200">
    <%= link_to dashboard_root_path, class: "block w-full text-center px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200 transition-colors mb-2" do %>
      <svg class="h-4 w-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to User Dashboard
    <% end %>

    <%= link_to root_path, class: "block w-full text-center px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200 transition-colors" do %>
      <svg class="h-4 w-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      View Public Site
    <% end %>
  </div>
</div>
