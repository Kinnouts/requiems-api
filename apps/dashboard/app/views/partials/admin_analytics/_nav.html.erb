<nav class="bg-white dark:bg-gray-800 rounded-lg shadow mb-8">
  <div class="px-6">
    <div class="flex space-x-8">
      <%
        nav_items = [
          { name: "Usage Analytics", path: admin_analytics_usage_path, action: "usage" },
          { name: "Revenue Analytics", path: admin_analytics_revenue_path, action: "revenue" },
          { name: "System Health", path: admin_analytics_system_health_path, action: "system_health" }
        ]
      %>

      <% nav_items.each do |item| %>
        <%
          is_active = action_name == item[:action]
          link_classes = if is_active
            "border-b-2 border-blue-500 py-4 px-1 text-sm font-medium text-blue-600 dark:text-blue-400"
          else
            "border-b-2 border-transparent py-4 px-1 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:border-gray-300"
          end
        %>
        <%= link_to item[:name], item[:path], class: link_classes %>
      <% end %>
    </div>
  </div>
</nav>
