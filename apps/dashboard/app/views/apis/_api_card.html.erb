<%
  card_api = local_assigns.fetch(:api, {})
  card_api_name = card_api["name"]
  card_api_description = card_api["description"]
  card_api_status = card_api["status"]
  card_api_endpoints_count = card_api["endpoints_count"]
  card_api_tags = card_api["tags"] || []
  card_api_id = card_api["id"]
  card_api_doc_url = card_api["documentation_url"]
%>

<div class="bg-white rounded-lg shadow hover:shadow-lg transition-shadow border border-gray-200 p-6"
     data-api-search-target="card"
     data-api-name="<%= card_api_name.downcase %>"
     data-api-description="<%= card_api_description.downcase %>"
     data-api-tags="<%= card_api_tags.map(&:downcase).join(' ') %>">

  <!-- Header -->
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-lg font-semibold text-gray-900">
      <%= card_api_name %>
    </h3>
    <%= render "shared/badge", text: api_status_text(card_api_status), variant: api_status_variant(card_api_status), size: "sm" %>
  </div>

  <!-- Description -->
  <p class="text-sm text-gray-600 mb-4 line-clamp-2">
    <%= card_api_description %>
  </p>

  <!-- Tags -->
  <% if card_api_tags.any? %>
    <div class="flex flex-wrap gap-2 mb-4">
      <% card_api_tags.take(3).each do |tag| %>
        <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-700">
          <%= tag %>
        </span>
      <% end %>
      <% if card_api_tags.count > 3 %>
        <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-700">
          +<%= card_api_tags.count - 3 %> more
        </span>
      <% end %>
    </div>
  <% end %>

  <!-- Footer -->
  <div class="flex items-center justify-between pt-4 border-t border-gray-200">
    <div class="flex items-center text-sm text-gray-500">
      <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
      <span><%= card_api_endpoints_count %> <%= "endpoint".pluralize(card_api_endpoints_count) %></span>
    </div>

    <%= link_to card_api_doc_url, class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors" do %>
      View Docs
      <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>
  </div>
</div>
