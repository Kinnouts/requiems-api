<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <!-- Header -->
  <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- API Header -->
      <div class="flex items-start justify-between">
        <div class="flex-1">
          <div class="flex items-center space-x-3 mb-3">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">
              <%= @documentation["api_name"] %>
            </h1>
            <%= render "partials/shared/badge", text: api_status_text(@api["status"]), variant: api_status_variant(@api["status"]) %>
          </div>
          <p class="text-lg text-gray-600 dark:text-gray-400 max-w-3xl">
            <%= @documentation["description"] %>
          </p>
        </div>

        <div class="flex flex-col items-end gap-2">
          <% unless user_signed_in? %>
            <%= link_to new_user_registration_path, class: "inline-flex items-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
              Get API Key
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            <% end %>
          <% end %>
          <div class="flex gap-2">
            <button type="button"
                    data-controller="copy"
                    data-copy-text-value="<%= html_escape(api_documentation_as_text(@documentation)) %>"
                    data-action="click->copy#copy"
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-600 dark:text-gray-400 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              Copy as Text
            </button>
            <button type="button"
                    data-controller="copy"
                    data-copy-text-value="<%= html_escape(api_documentation_as_markdown(@documentation)) %>"
                    data-action="click->copy#copy"
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-600 dark:text-gray-400 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
              </svg>
              Copy as Markdown
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="lg:grid lg:grid-cols-12 lg:gap-8">
      <!-- Left Sidebar Navigation -->
      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-8">
          <nav class="space-y-1" data-controller="scroll-spy">
            <a href="#overview" class="block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg">Overview</a>
            <a href="#endpoints" class="block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg">Endpoints</a>
            <% @documentation["endpoints"]&.each_with_index do |endpoint, index| %>
              <a href="#endpoint-<%= index %>" class="block pl-6 py-2 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200">
                <%= endpoint["method"] %> <%= endpoint["name"] %>
              </a>
            <% end %>
            <% if @documentation["faq"].present? %>
              <a href="#faq" class="block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg">FAQ</a>
            <% end %>
          </nav>
        </div>
      </aside>

      <!-- Main Documentation Content -->
      <main class="lg:col-span-9">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
          <!-- Overview Section -->
          <div id="overview" class="p-8 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">Overview</h2>

            <% if @documentation.dig("overview", "use_cases").present? %>
              <div class="mb-6">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Use Cases</h3>
                <ul class="space-y-2">
                  <% @documentation.dig("overview", "use_cases").each do |use_case| %>
                    <li class="flex items-start">
                      <svg class="h-5 w-5 text-green-500 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                      <span class="text-gray-700 dark:text-gray-300"><%= use_case %></span>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <% if @documentation.dig("overview", "features").present? %>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Features</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <% @documentation.dig("overview", "features").each do |feature| %>
                    <div class="flex items-start">
                      <svg class="h-5 w-5 text-blue-500 mr-2 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      <span class="text-gray-700 dark:text-gray-300"><%= feature %></span>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Endpoints Section -->
          <div id="endpoints" class="p-8">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">API Endpoints</h2>

            <% @documentation["endpoints"]&.each_with_index do |endpoint, index| %>
              <%= render "partials/apis_show/endpoint_documentation", endpoint: endpoint, index: index, base_url: @documentation["base_url"] %>
            <% end %>
          </div>

          <!-- FAQ Section -->
          <% if @documentation["faq"].present? %>
            <div id="faq" class="p-8 border-t border-gray-200 dark:border-gray-700">
              <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Frequently Asked Questions</h2>

              <div class="space-y-4" data-controller="faq-accordion">
                <% @documentation["faq"].each_with_index do |faq, index| %>
                  <div class="border border-gray-200 dark:border-gray-700 rounded-lg">
                    <button type="button"
                            class="w-full px-6 py-4 text-left flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-700"
                            data-action="click->faq-accordion#toggle"
                            data-faq-accordion-target="button">
                      <span class="font-medium text-gray-900 dark:text-gray-100"><%= faq["question"] %></span>
                      <svg class="h-5 w-5 text-gray-500 dark:text-gray-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </button>
                    <div class="hidden px-6 pb-4 text-gray-700 dark:text-gray-300" data-faq-accordion-target="content">
                      <%= faq["answer"] %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </main>
    </div>
  </div>
</div>
