<%
  sidebar_categories = local_assigns.fetch(:categories, [])
  sidebar_selected_category = local_assigns.fetch(:selected_category, nil)
%>

<div class="sticky top-8 bg-white rounded-lg shadow p-6">
  <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">
    Categories
  </h3>

  <nav class="space-y-1">
    <!-- All APIs -->
    <%= link_to apis_path, class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-colors #{sidebar_selected_category.nil? ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-gray-50'}" do %>
      <span class="mr-3 text-lg">📂</span>
      <span class="flex-1">All APIs</span>
      <span class="ml-auto inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
        <%= live_apis.count %>
      </span>
    <% end %>

    <!-- Divider -->
    <div class="border-t border-gray-200 my-3"></div>

    <!-- Category Links -->
    <% sidebar_categories.each do |category| %>
      <% category_apis = apis_by_category(category["id"]) %>
      <% is_selected = sidebar_selected_category == category["id"] %>
      <% is_coming_soon = category["coming_soon"] %>

      <% if is_coming_soon %>
        <div class="flex items-center px-3 py-2 text-sm font-medium text-gray-400 cursor-not-allowed rounded-lg">
          <span class="mr-3 text-lg"><%= category["icon"] %></span>
          <span class="flex-1"><%= category["name"] %></span>
          <%= render "shared/badge", text: "Soon", variant: "default", size: "xs", class_names: "ml-auto" %>
        </div>
      <% else %>
        <%= link_to apis_path(category: category["id"]), class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-colors #{is_selected ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-gray-50'}" do %>
          <span class="mr-3 text-lg"><%= category["icon"] %></span>
          <span class="flex-1"><%= category["name"] %></span>
          <span class="ml-auto inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= is_selected ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
            <%= category_apis.count %>
          </span>
        <% end %>
      <% end %>
    <% end %>
  </nav>

  <!-- Help Section -->
  <div class="mt-6 pt-6 border-t border-gray-200">
    <h4 class="text-xs font-semibold text-gray-900 uppercase tracking-wider mb-3">
      Need Help?
    </h4>
    <p class="text-sm text-gray-600 mb-3">
      Check our documentation or contact support for assistance.
    </p>
    <%= link_to "View Docs", docs_path, class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-700" %>
  </div>
</div>
