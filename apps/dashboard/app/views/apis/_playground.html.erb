<%
  playground_endpoint = local_assigns.fetch(:endpoint, {})
  playground_full_url = local_assigns.fetch(:full_url, "")
  playground_index = local_assigns.fetch(:index, 0)

  playground_method = playground_endpoint["method"]
  playground_parameters = playground_endpoint["parameters"] || []
  playground_request_example = playground_endpoint["request_example"]
%>

<div data-controller="api-playground"
     data-api-playground-method-value="<%= playground_method %>"
     data-api-playground-url-value="<%= playground_full_url %>"
     data-api-playground-index-value="<%= playground_index %>">

  <!-- Request Section -->
  <div class="bg-white rounded-lg p-4">
    <h5 class="text-sm font-semibold text-gray-900 mb-3">Request</h5>

    <% if playground_parameters.any? %>
      <div class="space-y-3 mb-4">
        <% playground_parameters.each do |param| %>
          <% param_location = param["location"] || "body" %>
          <% next if param_location == "path" %> <%# Path params are handled in URL %>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              <%= param["name"] %>
              <% if param["required"] %>
                <span class="text-red-500">*</span>
              <% end %>
              <span class="text-gray-500 font-normal">(<%= param["type"] %>)</span>
            </label>

            <% if param["type"] == "array" %>
              <textarea
                data-api-playground-target="param"
                data-param-name="<%= param["name"] %>"
                data-param-type="array"
                data-param-required="<%= param["required"] %>"
                placeholder='<%= param["example"] || "[]" %>'
                rows="3"
                class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm font-mono"
              ></textarea>
              <p class="mt-1 text-xs text-gray-500">Enter JSON array, e.g., <%= param["example"] || '["item1", "item2"]' %></p>
            <% elsif param["type"] == "object" %>
              <textarea
                data-api-playground-target="param"
                data-param-name="<%= param["name"] %>"
                data-param-type="object"
                data-param-required="<%= param["required"] %>"
                placeholder='<%= param["example"] || "{}" %>'
                rows="3"
                class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm font-mono"
              ></textarea>
              <p class="mt-1 text-xs text-gray-500">Enter JSON object</p>
            <% else %>
              <input
                type="text"
                data-api-playground-target="param"
                data-param-name="<%= param["name"] %>"
                data-param-type="<%= param["type"] %>"
                data-param-required="<%= param["required"] %>"
                placeholder="<%= param["example"] || param["description"] %>"
                class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
              />
            <% end %>

            <% if param["description"] %>
              <p class="mt-1 text-xs text-gray-500"><%= param["description"] %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <button
      type="button"
      data-action="click->api-playground#sendRequest"
      data-api-playground-target="submitButton"
      class="w-full inline-flex items-center justify-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
    >
      <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
      <span data-api-playground-target="submitText">Send Request</span>
    </button>

    <!-- Loading indicator (hidden by default) -->
    <div class="hidden mt-4 flex items-center justify-center text-sm text-gray-600" data-api-playground-target="loading">
      <svg class="animate-spin h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      Sending request...
    </div>
  </div>

  <!-- Response Section -->
  <div class="mt-4 hidden" data-api-playground-target="responseContainer">
    <h5 class="text-sm font-semibold text-gray-900 mb-3">Response</h5>

    <!-- Response Status -->
    <div class="flex items-center justify-between mb-3 p-3 bg-gray-50 rounded-lg" data-api-playground-target="responseStatus">
      <div class="flex items-center space-x-2">
        <span class="text-sm font-medium text-gray-700">Status:</span>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium" data-api-playground-target="statusBadge">
          --
        </span>
      </div>
      <div class="text-sm text-gray-600">
        <span data-api-playground-target="responseTime">--</span>
      </div>
    </div>

    <!-- Response Headers (collapsible) -->
    <details class="mb-3">
      <summary class="cursor-pointer text-sm font-medium text-gray-700 hover:text-gray-900 mb-2">
        Response Headers
      </summary>
      <pre class="bg-gray-50 rounded-lg p-3 text-xs overflow-x-auto" data-api-playground-target="responseHeaders">--</pre>
    </details>

    <!-- Response Body -->
    <div class="relative">
      <pre class="bg-gray-900 text-gray-100 rounded-lg p-4 overflow-x-auto text-sm max-h-96" data-api-playground-target="responseBody">Waiting for response...</pre>
      <button
        type="button"
        data-controller="copy"
        data-copy-target-value="responseBody"
        data-action="click->copy#copyFromTarget"
        class="absolute top-2 right-2 p-2 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded transition-colors"
        title="Copy response">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Error Section -->
  <div class="mt-4 hidden" data-api-playground-target="errorContainer">
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <div>
          <h6 class="text-sm font-medium text-red-900">Error</h6>
          <p class="text-sm text-red-700 mt-1" data-api-playground-target="errorMessage">--</p>
        </div>
      </div>
    </div>
  </div>
</div>
