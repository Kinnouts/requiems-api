<div class="min-h-screen flex flex-col bg-gray-50 dark:bg-gray-900" data-controller="api-search">
  <%= render 'partials/apis_index/header' %>

  <div class="flex flex-1">
    <!-- Sidebar -->
    <aside class="hidden lg:block w-52 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex-shrink-0">
      <div class="sticky top-16 max-h-[calc(100vh-4rem)] overflow-y-auto">
        <%= render 'partials/apis_index/sidebar', categories: @categories_with_apis %>
      </div>
    </aside>

    <!-- Main Content Area -->
    <div class="flex-1 px-12 py-8">
      <!-- Empty State (shown by api-search controller when no results) -->
      <div class="hidden text-center py-16 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700" data-api-search-target="empty">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">No APIs found</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Try adjusting your search terms.</p>
      </div>

      <%= render 'partials/apis_index/most_popular', apis: @popular_apis %>

      <% @categories_with_apis.each do |category| %>
        <% category_apis = @apis_by_category[category["id"]] || [] %>
        <%= render 'partials/apis_index/category_section', category: category, apis: category_apis %>
      <% end %>
    </div>
  </div>
</div>
