<div class="min-h-screen flex bg-gray-50 dark:bg-gray-900">
  <!-- Sidebar -->
  <aside class="hidden lg:block w-52 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex-shrink-0">
    <div class="sticky top-16 max-h-[calc(100vh-4rem)] overflow-y-auto">
      <%= render 'partials/apis_index/sidebar', categories: @categories_with_apis %>
    </div>
  </aside>

  <!-- Main Content Area -->
  <div class="flex-1 apis-content">
    <!-- Page Header -->
    <div class="text-center mb-10 max-w-3xl mx-auto">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-3">API Directory</h1>
      <p class="text-base text-gray-600 dark:text-gray-400">
        Unlock all our APIs with a single API key &mdash;
        <% if user_signed_in? %>
          browse our collection of production-ready APIs.
        <% else %>
          <%= link_to new_user_registration_path, class: "font-semibold text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300" do %>sign up for a <strong>free API key</strong><% end %> to get started.
        <% end %>
      </p>
    </div>

    <%= render 'partials/apis_index/most_popular', apis: @popular_apis %>

    <% @categories_with_apis.each do |category| %>
      <% category_apis = @apis_by_category[category["id"]] || [] %>
      <%= render 'partials/apis_index/category_section', category: category, apis: category_apis %>
    <% end %>
  </div>
</div>
