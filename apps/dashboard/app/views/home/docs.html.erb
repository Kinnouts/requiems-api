<div class="min-h-screen bg-gray-50">
  <!-- Redirect to APIs directory -->
  <% content_for :head do %>
    <meta http-equiv="refresh" content="0; url=<%= apis_path %>">
  <% end %>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center">
      <svg class="animate-spin h-12 w-12 text-blue-600 mx-auto mb-4" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <p class="text-gray-600">Redirecting to API documentation...</p>
      <p class="mt-4">
        <% if !request.env['HTTP_REFERER'] || !request.env['HTTP_REFERER'].include?('apis') %>
          <%= link_to "Click here if you're not redirected", apis_path, class: "text-blue-600 hover:text-blue-700 font-medium" %>
        <% end %>
      </p>
    </div>
  </div>
</div>
