<% content_for :title, t("home.faq.title") %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 md:p-12">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4"><%= t("home.faq.heading") %></h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 mb-12">
        <%= t("home.faq.intro") %>
      </p>

      <div class="space-y-8">
        <!-- Getting Started -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 pb-2 border-b border-gray-200 dark:border-gray-700"><%= t("home.faq.getting_started.heading") %></h2>
          <div class="space-y-6">
            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.getting_started.q1") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.getting_started.a1_html", docs_link: link_to(t("home.faq.getting_started.docs_link"), docs_path, class: "text-blue-600 hover:text-blue-700 underline")).html_safe %>
              </p>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.getting_started.q2") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.getting_started.a2") %>
              </p>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.getting_started.q3") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.getting_started.a3") %>
              </p>
            </div>
          </div>
        </div>

        <!-- Authentication -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 pb-2 border-b border-gray-200 dark:border-gray-700"><%= t("home.faq.authentication.heading") %></h2>
          <div class="space-y-6">
            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.authentication.q1") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.authentication.a1") %><br>
                <code class="bg-gray-800 text-gray-100 px-3 py-1 rounded mt-2 inline-block">Authorization: Bearer YOUR_API_KEY</code>
              </p>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.authentication.q2") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.authentication.a2_html").html_safe %>
              </p>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.authentication.q3") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.authentication.a3") %>
              </p>
            </div>
          </div>
        </div>

        <!-- Billing & Usage -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 pb-2 border-b border-gray-200 dark:border-gray-700"><%= t("home.faq.billing.heading") %></h2>
          <div class="space-y-6">
            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.billing.q1") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.billing.a1") %>
              </p>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.billing.q2") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.billing.a2") %>
              </p>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.billing.q3") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.billing.a3") %>
              </p>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.billing.q4") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.billing.a4") %>
              </p>
            </div>
          </div>
        </div>

        <!-- Rate Limits -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 pb-2 border-b border-gray-200 dark:border-gray-700"><%= t("home.faq.rate_limits.heading") %></h2>
          <div class="space-y-6">
            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.rate_limits.q1") %></h3>
              <p class="text-gray-700 dark:text-gray-300 mb-2">
                <%= t("home.faq.rate_limits.a1") %>
              </p>
              <ul class="text-gray-700 dark:text-gray-300 space-y-1 ml-4">
                <li>• <%= t("home.faq.rate_limits.free") %></li>
                <li>• <%= t("home.faq.rate_limits.developer") %></li>
                <li>• <%= t("home.faq.rate_limits.business") %></li>
                <li>• <%= t("home.faq.rate_limits.professional") %></li>
              </ul>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.rate_limits.q2") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.rate_limits.a2_html").html_safe %>
              </p>
            </div>
          </div>
        </div>

        <!-- Support -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 pb-2 border-b border-gray-200 dark:border-gray-700"><%= t("home.faq.support.heading") %></h2>
          <div class="space-y-6">
            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.support.q1") %></h3>
              <p class="text-gray-700 dark:text-gray-300 mb-2">
                <%= t("home.faq.support.a1") %>
              </p>
              <ul class="text-gray-700 dark:text-gray-300 space-y-1 ml-4">
                <li>• <%= link_to t("home.faq.support.docs_channel").split(" - ").first, docs_path, class: "text-blue-600 hover:text-blue-700 underline" %> - <%= t("home.faq.support.docs_channel").split(" - ").last %></li>
                <li>• <%= link_to t("home.faq.support.contact_channel").split(" - ").first, contact_path, class: "text-blue-600 hover:text-blue-700 underline" %> - <%= t("home.faq.support.contact_channel").split(" - ").last %></li>
                <li>• <%= link_to t("home.faq.support.github_channel").split(" - ").first, "#{ExternalLinks::GITHUB[:repository]}/issues", target: "_blank", class: "text-blue-600 hover:text-blue-700 underline" %> - <%= t("home.faq.support.github_channel").split(" - ").last %></li>
              </ul>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.support.q2") %></h3>
              <p class="text-gray-700 dark:text-gray-300 mb-2">
                <%= t("home.faq.support.a2") %>
              </p>
              <ul class="text-gray-700 dark:text-gray-300 space-y-1 ml-4">
                <li>• <%= t("home.faq.support.free_dev") %></li>
                <li>• <%= t("home.faq.support.business_time") %></li>
                <li>• <%= t("home.faq.support.professional_time") %></li>
              </ul>
            </div>

            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.faq.support.q3") %></h3>
              <p class="text-gray-700 dark:text-gray-300">
                <%= t("home.faq.support.a3_html", sales_link: link_to(t("home.faq.support.contact_sales"), talk_to_sales_path, class: "text-blue-600 hover:text-blue-700 underline")).html_safe %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Still have questions -->
      <div class="mt-12 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6">
        <h2 class="text-lg font-semibold text-blue-900 dark:text-blue-300 mb-2"><%= t("home.faq.still_questions.heading") %></h2>
        <p class="text-blue-800 dark:text-blue-300 mb-4">
          <%= t("home.faq.still_questions.text") %>
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <%= link_to contact_path, class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors" do %>
            <%= t("home.faq.still_questions.contact") %>
          <% end %>
          <%= link_to docs_path, class: "inline-flex items-center justify-center px-4 py-2 border border-blue-300 dark:border-blue-700 text-sm font-medium rounded-md text-blue-700 dark:text-blue-400 bg-white dark:bg-gray-800 hover:bg-blue-50 dark:hover:bg-gray-700 transition-colors" do %>
            <%= t("home.faq.still_questions.docs") %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
