<% content_for :title, t("home.about.title") %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 md:p-12">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-6"><%= t("home.about.heading") %></h1>

      <div class="prose prose-lg max-w-none">
        <p class="text-xl text-gray-600 dark:text-gray-400 mb-8">
          <%= t("home.about.intro") %>
        </p>

        <div class="bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-600 p-4 mb-8">
          <p class="text-gray-700 dark:text-gray-300">
            <%= t("home.about.company_info_html").html_safe %>
          </p>
        </div>

        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mt-8 mb-4"><%= t("home.about.mission.heading") %></h2>
        <p class="text-gray-700 dark:text-gray-300 mb-6">
          <%= t("home.about.mission.text") %>
        </p>

        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mt-8 mb-4"><%= t("home.about.offerings.heading") %></h2>
        <ul class="list-disc pl-6 text-gray-700 dark:text-gray-300 space-y-2 mb-6">
          <% t("home.about.offerings.items").each do |item| %>
            <li><%= item %></li>
          <% end %>
        </ul>

        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mt-8 mb-4"><%= t("home.about.values.heading") %></h2>
        <div class="grid md:grid-cols-2 gap-6 mb-8">
          <div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.about.values.dx_title") %></h3>
            <p class="text-gray-700 dark:text-gray-300">
              <%= t("home.about.values.dx_text") %>
            </p>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.about.values.reliability_title") %></h3>
            <p class="text-gray-700 dark:text-gray-300">
              <%= t("home.about.values.reliability_text") %>
            </p>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.about.values.transparency_title") %></h3>
            <p class="text-gray-700 dark:text-gray-300">
              <%= t("home.about.values.transparency_text") %>
            </p>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.about.values.privacy_title") %></h3>
            <p class="text-gray-700 dark:text-gray-300">
              <%= t("home.about.values.privacy_text") %>
            </p>
          </div>
        </div>

        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mt-8 mb-4"><%= t("home.about.contact.heading") %></h2>
        <p class="text-gray-700 dark:text-gray-300">
          <%= t("home.about.contact.intro") %>
          <%= link_to t("home.about.contact.get_in_touch"), contact_path, class: "text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 font-medium" %>
          <%= t("home.about.contact.or_email") %>
          <a href="mailto:eliaz@bobadilla.tech" class="text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 font-medium">eliaz@bobadilla.tech</a>
        </p>
      </div>
    </div>
  </div>
</div>
