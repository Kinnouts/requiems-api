<% content_for :title, "Requiems API - Ship Faster With Production-Ready APIs" %>

<!-- Hero Section -->
<div class="relative bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800 text-white overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Hero copy -->
      <div>
        <h1 class="text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Ship Faster With
          <span class="block text-yellow-300">Production-Ready APIs</span>
        </h1>

        <p class="text-xl text-blue-100 mb-8">
          One API key. Unlimited possibilities. Access email validation, text utilities, and more through a single managed platform hosted on EU servers.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-4 border border-transparent text-base font-medium rounded-lg text-blue-700 bg-white hover:bg-gray-50 transition-colors shadow-lg" do %>
            Get Free API Key
            <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          <% end %>

          <%= link_to apis_path, class: "inline-flex items-center justify-center px-8 py-4 border-2 border-white text-base font-medium rounded-lg text-white hover:bg-white/10 transition-colors" do %>
            Browse API Docs
          <% end %>
        </div>
      </div>

      <!-- Right: Code example / API demo -->
      <div class="lg:mt-0 mt-8">
        <div class="bg-gray-900 rounded-lg shadow-2xl overflow-hidden border border-gray-700">
          <!-- Terminal header -->
          <div class="bg-gray-800 px-3 sm:px-4 py-2 flex items-center space-x-2">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <span class="ml-2 sm:ml-4 text-gray-400 text-xs sm:text-sm">API Request</span>
          </div>

          <!-- Code -->
          <div class="p-3 sm:p-6 overflow-x-auto">
            <pre class="text-xs sm:text-sm font-mono text-gray-300 whitespace-pre"><code><span class="text-pink-400">curl</span> <span class="text-blue-400">-H</span> <span class="text-green-400">"requiems-api-key: YOUR_KEY"</span> \
  <span class="text-yellow-400">https://api.requiems.xyz/v1/text/advice</span>

{
  <span class="text-blue-400">"advice"</span>: <span class="text-green-400">"Don't compare yourself to others."</span>,
  <span class="text-blue-400">"id"</span>: <span class="text-yellow-400">42</span>
}</code></pre>
          </div>
        </div>

        <!-- Try it badge -->
        <div class="mt-4 text-center">
          <span class="text-xs sm:text-sm text-blue-200">✨ Try it now • No credit card required</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Trust / Social Proof Section -->
<div class="bg-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900">
        Trusted by developers worldwide
      </h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <%= render "partials/shared/stat_card", title: "Developers", value: "10,000+", subtitle: "Building with Requiems" %>
      <%= render "partials/shared/stat_card", title: "API Calls", value: "200M+", subtitle: "Total requests served" %>
      <%= render "partials/shared/stat_card", title: "Countries", value: "100+", subtitle: "Global reach" %>
      <%= render "partials/shared/stat_card", title: "Uptime", value: "99.99%", subtitle: "Last 12 months" %>
    </div>
  </div>
</div>

<!-- Documentation Quality Section -->
<div class="bg-gray-50 py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900">
        Built for Developer Experience
      </h2>
      <p class="mt-4 text-xl text-gray-600">
        Everything you need to integrate and ship fast
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Feature 1: Live Demos -->
      <%= render "partials/shared/card", padding: true, hover: true do %>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 text-blue-600 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Live API Playground</h3>
          <p class="text-gray-600">
            Test every endpoint directly in the docs. See real responses instantly without writing code.
          </p>
        </div>
      <% end %>

      <!-- Feature 2: Code Examples -->
      <%= render "partials/shared/card", padding: true, hover: true do %>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 text-green-600 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Code Examples</h3>
          <p class="text-gray-600">
            Copy-paste examples in cURL, Python, JavaScript, Ruby, Go, and more. Start in seconds.
          </p>
        </div>
      <% end %>

      <!-- Feature 3: Precise Docs -->
      <%= render "partials/shared/card", padding: true, hover: true do %>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-purple-100 text-purple-600 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Precise Documentation</h3>
          <p class="text-gray-600">
            Every parameter, response field, and error code documented. No guessing required.
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- API Categories Grid -->
<div class="bg-white py-20" id="api-docs">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-gray-900">
        API Categories
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Explore our comprehensive collection of APIs organized by category to find exactly what you need.
      </p>
    </div>

    <div class="grid gap-3 mb-16 grid-cols-2 md:grid-cols-8">
      <% @categories.first(16).each_with_index do |category, index| %>
        <%= link_to apis_path(category: category["id"]),
            class: "group bg-gray-50 rounded-lg p-4 text-center transition-all duration-200 hover:bg-blue-50 #{index >= 8 ? 'hidden md:block' : ''}" do %>
          <div class="text-3xl mb-2"><%= category["icon"] %></div>
          <h3 class="text-xs font-semibold text-gray-900 group-hover:text-blue-600 leading-tight">
            <%= category["name"] %>
          </h3>
        <% end %>
      <% end %>
    </div>

    <div class="text-center">
      <%= link_to apis_path, class: "inline-flex items-center justify-center px-8 py-3 bg-blue-600 text-white text-base font-medium rounded-lg hover:bg-blue-700 transition-colors shadow-sm" do %>
        Browse All APIs
      <% end %>
    </div>
  </div>
</div>

<!-- Metrics Section -->
<div class="bg-gradient-to-br from-gray-50 to-gray-100 py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900">
        Performance You Can Count On
      </h2>
      <p class="mt-4 text-xl text-gray-600">
        Enterprise-grade infrastructure without the enterprise complexity
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <%= render "partials/shared/stat_card", title: "Median Latency", value: "243ms", subtitle: "P50 response time", class_names: "border-2 border-blue-200" %>
      <%= render "partials/shared/stat_card", title: "Uptime", value: "99.99%", subtitle: "Last 12 months SLA", class_names: "border-2 border-green-200" %>
      <%= render "partials/shared/stat_card", title: "Monthly Requests", value: "200M+", subtitle: "Requests processed/month", class_names: "border-2 border-purple-200" %>
      <%= render "partials/shared/stat_card", title: "Data Centers", value: "EU", subtitle: "European Union", class_names: "border-2 border-yellow-200" %>
    </div>
  </div>
</div>

<!-- Security & Compliance Section -->
<div class="bg-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900">
        Security & Compliance First
      </h2>
      <p class="mt-4 text-xl text-gray-600">
        Enterprise-grade security for teams of all sizes
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- SOC 2 -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-blue-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900">SOC 2 Certification</h3>
          <%= render "partials/shared/badge", text: "In Progress", variant: "info", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600">
            In progress.
          </p>
        </div>
      </div>

      <!-- Data Encryption -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-green-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900">Data Encryption</h3>
          <%= render "partials/shared/badge", text: "Active", variant: "success", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600">
            TLS 1.3 in transit, AES-256 at rest. Zero data storage policy for API inputs/outputs.
          </p>
        </div>
      </div>

      <!-- Global Infrastructure -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-purple-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900">EU Infrastructure</h3>
          <%= render "partials/shared/badge", text: "EU", variant: "primary", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600">
            All data centers located in the European Union. GDPR compliant.
          </p>
        </div>
      </div>

      <!-- Secure Payments -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-yellow-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900">Secure Payments</h3>
          <%= render "partials/shared/badge", text: "Stripe", variant: "success", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600">
            All payments processed through Stripe. We never see or store your payment details.
          </p>
        </div>
      </div>

      <!-- GDPR Compliant -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-indigo-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900">GDPR / CCPA Compliant</h3>
          <%= render "partials/shared/badge", text: "Compliant", variant: "success", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600">
            Full compliance with GDPR, CCPA, and international privacy regulations.
          </p>
        </div>
      </div>

      <!-- API Security -->
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-red-500 text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <h3 class="text-lg font-semibold text-gray-900">API Security</h3>
          <%= render "partials/shared/badge", text: "Rate Limited", variant: "success", size: "sm", class_names: "mt-1" %>
          <p class="mt-2 text-gray-600">
            Built-in rate limiting, DDoS protection, and abuse prevention at the edge.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- FAQ Accordion Section -->
<div class="bg-white py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900">
        Frequently Asked Questions
      </h2>
      <p class="mt-4 text-xl text-gray-600">
        Everything you need to know about Requiems API
      </p>
    </div>

    <div class="space-y-4" data-controller="tabs">
      <!-- FAQ 1 -->
      <%= render "partials/shared/card", padding: true do %>
        <button class="w-full flex justify-between items-center text-left" data-action="click->tabs#select" data-tabs-index-param="0">
          <span class="text-lg font-semibold text-gray-900">Is Requiems API really free to start?</span>
          <svg class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mt-4 text-gray-600 hidden" data-tabs-target="panel">
          Yes! You get 500 requests per month completely free with no credit card required. Perfect for testing, side projects, and small applications. Upgrade to paid plans only when you need more capacity.
        </div>
      <% end %>

      <!-- FAQ 2 -->
      <%= render "partials/shared/card", padding: true do %>
        <button class="w-full flex justify-between items-center text-left" data-action="click->tabs#select" data-tabs-index-param="1">
          <span class="text-lg font-semibold text-gray-900">Can I use this for commercial projects?</span>
          <svg class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mt-4 text-gray-600 hidden" data-tabs-target="panel">
          Yes! All plans, including the free tier, can be used for commercial projects within the usage limits. Our managed service is designed for production use by businesses of all sizes.
        </div>
      <% end %>

      <!-- FAQ 3 -->
      <%= render "partials/shared/card", padding: true do %>
        <button class="w-full flex justify-between items-center text-left" data-action="click->tabs#select" data-tabs-index-param="2">
          <span class="text-lg font-semibold text-gray-900">Where are your servers located?</span>
          <svg class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mt-4 text-gray-600 hidden" data-tabs-target="panel">
          All our data centers are located in the European Union, powered by Cloudflare's global edge network for GDPR compliance.
        </div>
      <% end %>

      <!-- FAQ 4 -->
      <%= render "partials/shared/card", padding: true do %>
        <button class="w-full flex justify-between items-center text-left" data-action="click->tabs#select" data-tabs-index-param="3">
          <span class="text-lg font-semibold text-gray-900">What payment methods do you accept?</span>
          <svg class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mt-4 text-gray-600 hidden" data-tabs-target="panel">
          We accept all major credit cards (Visa, Mastercard, American Express) and debit cards through Stripe. All payments are processed securely and we never see or store your payment details.
        </div>
      <% end %>
    </div>

    <div class="mt-12 text-center">
      <p class="text-gray-600 mb-4">Still have questions?</p>
      <%= link_to contact_path, class: "inline-flex items-center text-blue-600 hover:text-blue-700 font-medium" do %>
        Contact our support team
        <svg class="ml-1 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      <% end %>
    </div>
  </div>
</div>

<!-- Final CTA Section -->
<div class="bg-gradient-to-br from-blue-600 to-indigo-800 py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
      Ready to ship faster?
    </h2>
    <p class="text-xl text-blue-100 mb-8">
      Join thousands of developers building with production-ready APIs
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
      <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-medium rounded-lg text-blue-700 bg-white hover:bg-gray-50 transition-colors shadow-lg" do %>
        Get Started Free
        <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      <% end %>

      <%= link_to pricing_path, class: "inline-flex items-center justify-center px-8 py-4 border-2 border-white text-lg font-medium rounded-lg text-white hover:bg-white/10 transition-colors" do %>
        View Pricing
      <% end %>
    </div>

    <p class="text-sm text-blue-200">
      No credit card required • 500 requests/month free • Cancel anytime
    </p>
  </div>
</div>
