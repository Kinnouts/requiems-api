          <%= link_to "Dashboard", dashboard_root_path, class: "text-gray-300 hover:text-white transition-colors" %>
          <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "px-4 py-2 bg-white/10 hover:bg-white/20 rounded-lg transition-colors" %>
        <% else %>
          <%= link_to "Documentation", docs_path, class: "text-gray-300 hover:text-white transition-colors" %>
          <%= link_to "Sign In", new_user_session_path, class: "text-gray-300 hover:text-white transition-colors" %>
          <%= link_to "Get Started Free", new_user_registration_path, class: "px-4 py-2 bg-white text-indigo-900 hover:bg-gray-100 rounded-lg font-medium transition-colors" %>
        <% end %>
      </div>
    </div>
  </nav>

  <!-- Hero Content -->
  <div class="container mx-auto px-4 py-20 lg:py-32">
    <div class="max-w-4xl">
      <h1 class="text-5xl md:text-7xl font-bold leading-tight">
        One API Key.<br>
        Unlimited Possibilities.
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 mt-6 max-w-2xl">
        Access production-ready APIs through a single managed platform. We build, operate, and scale the APIs. You focus on shipping product.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-4">
        <%= link_to "Get Started Free", new_user_registration_path, class: "px-8 py-4 bg-white text-indigo-900 hover:bg-gray-100 rounded-lg font-semibold text-lg transition-colors text-center" %>
        <%= link_to "View Documentation", docs_path, class: "px-8 py-4 bg-white/10 hover:bg-white/20 rounded-lg font-semibold text-lg transition-colors text-center border border-white/20" %>
      </div>

      <!-- Code Example -->
      <div class="mt-12 bg-gray-900/50 backdrop-blur-sm rounded-lg p-6 border border-white/10">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
        </div>
        <pre class="text-sm md:text-base text-gray-300 overflow-x-auto"><code><span class="text-pink-400">curl</span> <span class="text-blue-400">-H</span> <span class="text-green-400">"requiems-api-key: YOUR_KEY"</span> \
     <span class="text-yellow-400">https://api.requiems.xyz/v1/text/advice</span>

<span class="text-gray-500"># Response:</span>
{
  <span class="text-blue-400">"advice"</span>: <span class="text-green-400">"Don't compare yourself to others."</span>,
  <span class="text-blue-400">"id"</span>: <span class="text-yellow-400">42</span>
}</code></pre>
      </div>
    </div>
  </div>
</div>

