<%
  card_name = local_assigns.fetch(:name, "")
  card_monthly_price = local_assigns.fetch(:monthly_price, 0)
  card_yearly_price = local_assigns.fetch(:yearly_price, 0)
  card_description = local_assigns.fetch(:description, "")
  card_requests = local_assigns.fetch(:requests, "")
  card_rate_limit = local_assigns.fetch(:rate_limit, "")
  card_features = local_assigns.fetch(:features, [])
  card_cta_text = local_assigns.fetch(:cta_text, "Get Started")
  card_cta_url = local_assigns.fetch(:cta_url, "#")
  card_popular = local_assigns.fetch(:popular, false)
%>

<div class="bg-white rounded-lg shadow-lg <%= 'ring-2 ring-blue-600 relative' if card_popular %> overflow-hidden">
  <% if card_popular %>
    <div class="absolute top-0 right-0 bg-blue-600 text-white px-4 py-1 text-xs font-semibold uppercase rounded-bl-lg">
      Most Popular
    </div>
  <% end %>

  <div class="p-6">
    <!-- Plan Name -->
    <h3 class="text-2xl font-bold text-gray-900 mb-2"><%= card_name %></h3>
    <p class="text-gray-600 text-sm mb-6"><%= card_description %></p>

    <!-- Price -->
    <div class="mb-6">
      <div data-pricing-toggle-target="monthlyPrice">
        <div class="flex items-baseline">
          <span class="text-4xl font-bold text-gray-900">$<%= card_monthly_price %></span>
          <span class="ml-2 text-gray-600">/month</span>
        </div>
      </div>

      <div class="hidden" data-pricing-toggle-target="yearlyPrice">
        <div class="flex items-baseline">
          <span class="text-4xl font-bold text-gray-900">$<%= card_yearly_price %></span>
          <span class="ml-2 text-gray-600">/month</span>
        </div>
        <% if card_yearly_price > 0 && card_monthly_price > card_yearly_price %>
          <p class="text-sm text-green-600 mt-1">
            Save $<%= ((card_monthly_price - card_yearly_price) * 12).to_i %>/year
          </p>
        <% end %>
      </div>
    </div>

    <!-- CTA Button -->
    <%= link_to card_cta_text, card_cta_url, class: "block w-full text-center px-6 py-3 #{card_popular ? 'bg-blue-600 hover:bg-blue-700 text-white' : 'bg-gray-100 hover:bg-gray-200 text-gray-900'} font-medium rounded-lg transition-colors mb-6" %>

    <!-- Features List -->
    <div class="border-t border-gray-200 pt-6">
      <ul class="space-y-3">
        <% card_features.each do |feature| %>
          <li class="flex items-start">
            <svg class="h-5 w-5 text-green-500 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-gray-700"><%= feature %></span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
