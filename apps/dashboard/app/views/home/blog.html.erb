<% content_for :title, t("home.blog.title") %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 md:p-12">
      <div class="text-center mb-12">
        <div class="text-6xl mb-6">📝</div>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4"><%= t("home.blog.heading") %></h1>
        <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          <%= t("home.blog.description") %>
        </p>
      </div>

      <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6 mb-8">
        <h2 class="text-lg font-semibold text-blue-900 dark:text-blue-300 mb-2"><%= t("home.blog.what_to_expect.heading") %></h2>
        <ul class="text-blue-800 dark:text-blue-300 space-y-2">
          <% t("home.blog.what_to_expect.items").each do |item| %>
            <li class="flex items-start">
              <span class="mr-2">•</span>
              <span><%= item %></span>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="text-center">
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          <%= t("home.blog.meanwhile") %>
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <%= link_to docs_path, class: "inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors" do %>
            <%= t("home.blog.cta_docs") %>
          <% end %>
          <%= link_to apis_path, class: "inline-flex items-center justify-center px-6 py-3 border border-gray-300 dark:border-gray-600 text-base font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors" do %>
            <%= t("home.blog.cta_apis") %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
