<% content_for :title, "Contact Us - Requiems API" %>

<div class="min-h-screen bg-gray-50 py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-lg shadow-lg p-8 md:p-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-6">Contact Us</h1>

      <p class="text-xl text-gray-600 mb-12">
        Have questions? We're here to help.
      </p>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- General Inquiries -->
        <div class="border border-gray-200 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="ml-3 text-xl font-bold text-gray-900">General Inquiries</h2>
          </div>
          <p class="text-gray-700 mb-4">
            Questions about our services, features, or getting started?
          </p>
          <a href="mailto:eliaz@bobadilla.tech" class="text-blue-600 hover:text-blue-700 font-medium">
            eliaz@bobadilla.tech
          </a>
        </div>

        <!-- Sales -->
        <div class="border border-gray-200 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h2 class="ml-3 text-xl font-bold text-gray-900">Sales & Enterprise</h2>
          </div>
          <p class="text-gray-700 mb-4">
            Interested in Enterprise plans or custom solutions?
          </p>
          <a href="mailto:eliaz@bobadilla.tech" class="text-blue-600 hover:text-blue-700 font-medium">
            eliaz@bobadilla.tech
          </a>
        </div>

        <!-- Technical Support -->
        <div class="border border-gray-200 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h2 class="ml-3 text-xl font-bold text-gray-900">Technical Support</h2>
          </div>
          <p class="text-gray-700 mb-4">
            Need help with integration or experiencing issues?
          </p>
          <p class="text-gray-600 text-sm mb-2">
            <% if user_signed_in? %>
              <%= link_to "View Dashboard", dashboard_root_path, class: "text-blue-600 hover:text-blue-700 font-medium" %>
            <% else %>
              <%= link_to "Sign In", new_user_session_path, class: "text-blue-600 hover:text-blue-700 font-medium" %> for account-specific support
            <% end %>
          </p>
        </div>

        <!-- GitHub -->
        <div class="border border-gray-200 rounded-lg p-6">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
            </div>
            <h2 class="ml-3 text-xl font-bold text-gray-900">GitHub</h2>
          </div>
          <p class="text-gray-700 mb-4">
            Found a bug or want to request a feature?
          </p>
          <a href="https://github.com/bobadilla-tech/requiems-api" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-700 font-medium">
            Open an issue →
          </a>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-8">
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Response Times</h3>
        <ul class="space-y-2 text-gray-700">
          <li><strong>Free Plan:</strong> Community support via GitHub</li>
          <li><strong>Developer Plan:</strong> 24-hour email response</li>
          <li><strong>Business Plan:</strong> 4-hour priority email response</li>
          <li><strong>Professional Plan:</strong> 1-hour priority support</li>
          <li><strong>Enterprise:</strong> Dedicated support with custom SLA</li>
        </ul>
      </div>

      <div class="mt-12 pt-8 border-t border-gray-200">
        <%= link_to "Back to Home", root_path, class: "text-blue-600 hover:text-blue-700 font-medium inline-flex items-center" %>
        <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </div>
    </div>
  </div>
</div>
