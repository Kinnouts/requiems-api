<% content_for :title, "API Reference - Requiems API" %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 md:p-12">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-6">API Reference</h1>

      <p class="text-xl text-gray-600 dark:text-gray-400 mb-12">
        Complete reference documentation for all Requiems API endpoints.
      </p>

      <!-- Base URL -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">Base URL</h2>
        <div class="bg-gray-900 text-white p-4 rounded-lg font-mono text-sm">
          https://api.requiems.xyz
        </div>
      </div>

      <!-- Authentication -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">Authentication</h2>
        <p class="text-gray-700 dark:text-gray-300 mb-4">
          All API requests require authentication using an API key in the request header:
        </p>
        <div class="bg-gray-900 text-white p-4 rounded-lg font-mono text-sm">
          requiems-api-key: YOUR_API_KEY
        </div>
        <p class="text-gray-600 dark:text-gray-400 text-sm mt-2">
          <%= link_to "Get your API key", user_signed_in? ? dashboard_api_keys_path : new_user_registration_path, class: "text-blue-600 hover:text-blue-700" %>
        </p>
      </div>

      <!-- Available APIs -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Available APIs</h2>

        <div class="space-y-6">
          <!-- Email APIs -->
          <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100">Email APIs</h3>
              <%= render "partials/shared/badge", text: "Live", variant: "success", size: "sm" %>
            </div>
            <p class="text-gray-700 dark:text-gray-300 mb-4">
              Validate email addresses, detect disposable emails, and check email domains.
            </p>
            <%= link_to "View Email API Documentation", apis_path(category: "email"), class: "text-blue-600 hover:text-blue-700 font-medium inline-flex items-center" %>
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>

          <!-- Text APIs -->
          <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100">Text APIs</h3>
              <%= render "partials/shared/badge", text: "Live", variant: "success", size: "sm" %>
            </div>
            <p class="text-gray-700 dark:text-gray-300 mb-4">
              Generate random advice, quotes, Lorem Ipsum text, and random words.
            </p>
            <%= link_to "View Text API Documentation", apis_path(category: "text"), class: "text-blue-600 hover:text-blue-700 font-medium inline-flex items-center" %>
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>

          <!-- Miscellaneous APIs -->
          <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100">Miscellaneous APIs</h3>
              <%= render "partials/shared/badge", text: "Live", variant: "success", size: "sm" %>
            </div>
            <p class="text-gray-700 dark:text-gray-300 mb-4">
              General-purpose utility endpoints. Convert between units of measurement including length, weight, volume, temperature, area, and speed.
            </p>
            <%= link_to "View Miscellaneous API Documentation", apis_path(category: "misc"), class: "text-blue-600 hover:text-blue-700 font-medium inline-flex items-center" %>
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>

          <!-- Coming Soon -->
          <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6 opacity-60">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100">More APIs Coming Soon</h3>
              <%= render "partials/shared/badge", text: "Roadmap", variant: "secondary", size: "sm" %>
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Data APIs, Finance APIs, Image APIs, and more utility endpoints are in development.
            </p>
          </div>
        </div>
      </div>

      <!-- Rate Limits -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">Rate Limits</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-700">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Plan</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Requests/Month</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Rate Limit</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">Free</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">500</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">30/minute</td>
              </tr>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">Developer</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">100,000</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">5,000/minute</td>
              </tr>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">Business</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">1,000,000</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">10,000/minute</td>
              </tr>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">Professional</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">10,000,000</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">50,000/minute</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-gray-600 dark:text-gray-400 text-sm mt-4">
          <%= link_to "View pricing details", pricing_path, class: "text-blue-600 hover:text-blue-700" %>
        </p>
      </div>

      <!-- Error Codes -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">HTTP Status Codes</h2>
        <div class="space-y-3">
          <div class="flex items-start">
            <span class="inline-block px-3 py-1 bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-300 rounded text-sm font-mono mr-3">200</span>
            <div>
              <strong class="text-gray-900 dark:text-gray-100">OK</strong> <span class="text-gray-700 dark:text-gray-300">- Request succeeded</span>
            </div>
          </div>
          <div class="flex items-start">
            <span class="inline-block px-3 py-1 bg-yellow-100 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-300 rounded text-sm font-mono mr-3">400</span>
            <div>
              <strong class="text-gray-900 dark:text-gray-100">Bad Request</strong> <span class="text-gray-700 dark:text-gray-300">- Invalid request parameters</span>
            </div>
          </div>
          <div class="flex items-start">
            <span class="inline-block px-3 py-1 bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-300 rounded text-sm font-mono mr-3">401</span>
            <div>
              <strong class="text-gray-900 dark:text-gray-100">Unauthorized</strong> <span class="text-gray-700 dark:text-gray-300">- Missing or invalid API key</span>
            </div>
          </div>
          <div class="flex items-start">
            <span class="inline-block px-3 py-1 bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-300 rounded text-sm font-mono mr-3">429</span>
            <div>
              <strong class="text-gray-900 dark:text-gray-100">Too Many Requests</strong> <span class="text-gray-700 dark:text-gray-300">- Rate limit exceeded</span>
            </div>
          </div>
          <div class="flex items-start">
            <span class="inline-block px-3 py-1 bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-300 rounded text-sm font-mono mr-3">500</span>
            <div>
              <strong class="text-gray-900 dark:text-gray-100">Internal Server Error</strong> <span class="text-gray-700 dark:text-gray-300">- Something went wrong on our end</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
