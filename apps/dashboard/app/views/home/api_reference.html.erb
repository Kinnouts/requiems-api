<% content_for :title, "API Reference - Requiems API" %>

<div class="min-h-screen bg-gray-50 py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-lg shadow-lg p-8 md:p-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-6">API Reference</h1>

      <p class="text-xl text-gray-600 mb-12">
        Complete reference documentation for all Requiems API endpoints.
      </p>

      <!-- Base URL -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Base URL</h2>
        <div class="bg-gray-900 text-white p-4 rounded-lg font-mono text-sm">
          https://api.requiems.xyz
        </div>
      </div>

      <!-- Authentication -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Authentication</h2>
        <p class="text-gray-700 mb-4">
          All API requests require authentication using an API key in the request header:
        </p>
        <div class="bg-gray-900 text-white p-4 rounded-lg font-mono text-sm">
          requiems-api-key: YOUR_API_KEY
        </div>
        <p class="text-gray-600 text-sm mt-2">
          <%= link_to "Get your API key", user_signed_in? ? dashboard_api_keys_path : new_user_registration_path, class: "text-blue-600 hover:text-blue-700" %>
        </p>
      </div>

      <!-- Available APIs -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Available APIs</h2>

        <div class="space-y-6">
          <!-- Email APIs -->
          <div class="border border-gray-200 rounded-lg p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-900">Email APIs</h3>
              <%= render "partials/shared/badge", text: "Live", variant: "success", size: "sm" %>
            </div>
            <p class="text-gray-700 mb-4">
              Validate email addresses, detect disposable emails, and check email domains.
            </p>
            <%= link_to "View Email API Documentation", apis_path(category: "email"), class: "text-blue-600 hover:text-blue-700 font-medium inline-flex items-center" %>
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>

          <!-- Text APIs -->
          <div class="border border-gray-200 rounded-lg p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-900">Text APIs</h3>
              <%= render "partials/shared/badge", text: "Live", variant: "success", size: "sm" %>
            </div>
            <p class="text-gray-700 mb-4">
              Generate random advice, quotes, Lorem Ipsum text, and random words.
            </p>
            <%= link_to "View Text API Documentation", apis_path(category: "text"), class: "text-blue-600 hover:text-blue-700 font-medium inline-flex items-center" %>
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>

          <!-- Coming Soon -->
          <div class="border border-gray-200 rounded-lg p-6 opacity-60">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-900">More APIs Coming Soon</h3>
              <%= render "partials/shared/badge", text: "Roadmap", variant: "secondary", size: "sm" %>
            </div>
            <p class="text-gray-700">
              Data APIs, Finance APIs, Image APIs, and more utility endpoints are in development.
            </p>
          </div>
        </div>
      </div>

      <!-- Rate Limits -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Rate Limits</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Plan</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Requests/Month</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Rate Limit</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Free</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">500</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">30/minute</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Developer</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">100,000</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">5,000/minute</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Business</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">1,000,000</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">10,000/minute</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Professional</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">10,000,000</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">50,000/minute</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-gray-600 text-sm mt-4">
          <%= link_to "View pricing details", pricing_path, class: "text-blue-600 hover:text-blue-700" %>
        </p>
      </div>

      <!-- Error Codes -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">HTTP Status Codes</h2>
        <div class="space-y-3">
          <div class="flex items-start">
            <span class="inline-block px-3 py-1 bg-green-100 text-green-800 rounded text-sm font-mono mr-3">200</span>
            <div>
              <strong class="text-gray-900">OK</strong> - Request succeeded
            </div>
          </div>
          <div class="flex items-start">
            <span class="inline-block px-3 py-1 bg-yellow-100 text-yellow-800 rounded text-sm font-mono mr-3">400</span>
            <div>
              <strong class="text-gray-900">Bad Request</strong> - Invalid request parameters
            </div>
          </div>
          <div class="flex items-start">
            <span class="inline-block px-3 py-1 bg-red-100 text-red-800 rounded text-sm font-mono mr-3">401</span>
            <div>
              <strong class="text-gray-900">Unauthorized</strong> - Missing or invalid API key
            </div>
          </div>
          <div class="flex items-start">
            <span class="inline-block px-3 py-1 bg-red-100 text-red-800 rounded text-sm font-mono mr-3">429</span>
            <div>
              <strong class="text-gray-900">Too Many Requests</strong> - Rate limit exceeded
            </div>
          </div>
          <div class="flex items-start">
            <span class="inline-block px-3 py-1 bg-red-100 text-red-800 rounded text-sm font-mono mr-3">500</span>
            <div>
              <strong class="text-gray-900">Internal Server Error</strong> - Something went wrong on our end
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
