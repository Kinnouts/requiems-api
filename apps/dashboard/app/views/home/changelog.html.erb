<% content_for :title, t("home.changelog.title") %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 md:p-12">
      <div class="flex items-center justify-between mb-6">
        <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100"><%= t("home.changelog.heading") %></h1>
        <%= render "partials/shared/badge", text: "v0.1.0", variant: "info", size: "md" %>
      </div>

      <p class="text-xl text-gray-600 dark:text-gray-400 mb-12">
        <%= t("home.changelog.description") %>
      </p>

      <div class="space-y-12">
        <!-- v0.1.0 - CI Pipeline -->
        <div class="border-l-4 border-blue-600 pl-6">
          <div class="flex items-center mb-2">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">v0.1.0</h2>
            <%= render "partials/shared/badge", text: t("home.changelog.badge_latest"), variant: "success", size: "sm", class_names: "ml-3" %>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4"><%= l(Date.new(2026, 2, 17), format: :long) %></p>

          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">✅ <%= t("home.changelog.v010.ci.heading") %></h3>
          <ul class="list-disc pl-6 text-gray-700 dark:text-gray-300 space-y-2 mb-4">
            <% t("home.changelog.v010.ci.items").each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>

          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">🐛 <%= t("home.changelog.v010.bugs.heading") %></h3>
          <ul class="list-disc pl-6 text-gray-700 dark:text-gray-300 space-y-2 mb-4">
            <% t("home.changelog.v010.bugs.items").each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>

          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">📊 <%= t("home.changelog.v010.coverage.heading") %></h3>
          <ul class="list-disc pl-6 text-gray-700 dark:text-gray-300 space-y-2">
            <% t("home.changelog.v010.coverage.items").each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>
        </div>

        <!-- v0.0.2 - Initial Deployment -->
        <div class="border-l-4 border-green-600 pl-6">
          <div class="flex items-center mb-2">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">v0.0.2</h2>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4"><%= l(Date.new(2026, 2, 8), format: :long) %></p>

          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">🚀 <%= t("home.changelog.v002.deploy.heading") %></h3>
          <ul class="list-disc pl-6 text-gray-700 dark:text-gray-300 space-y-2 mb-4">
            <% t("home.changelog.v002.deploy.items").each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>

          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">✨ <%= t("home.changelog.v002.features.heading") %></h3>
          <ul class="list-disc pl-6 text-gray-700 dark:text-gray-300 space-y-2">
            <% t("home.changelog.v002.features.items").each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>
        </div>

        <!-- v0.0.1 - Project Kickoff -->
        <div class="border-l-4 border-purple-600 pl-6">
          <div class="flex items-center mb-2">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">v0.0.1</h2>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4"><%= l(Date.new(2025, 12, 15), format: :long) %></p>

          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">🎯 <%= t("home.changelog.v001.init.heading") %></h3>
          <ul class="list-disc pl-6 text-gray-700 dark:text-gray-300 space-y-2 mb-4">
            <% t("home.changelog.v001.init.items").each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>

          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">⚡ <%= t("home.changelog.v001.gateway.heading") %></h3>
          <ul class="list-disc pl-6 text-gray-700 dark:text-gray-300 space-y-2">
            <% t("home.changelog.v001.gateway.items").each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>
        </div>

        <!-- Upcoming -->
        <div class="border-l-4 border-gray-300 dark:border-gray-600 pl-6 opacity-75">
          <div class="flex items-center mb-2">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">v0.2.0</h2>
            <%= render "partials/shared/badge", text: t("home.changelog.badge_coming_soon"), variant: "warning", size: "sm", class_names: "ml-3" %>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4"><%= t("home.changelog.v020.planned_release") %></p>

          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">🚀 <%= t("home.changelog.v020.features.heading") %></h3>
          <ul class="list-disc pl-6 text-gray-700 dark:text-gray-300 space-y-2 mb-4">
            <% t("home.changelog.v020.features.items").each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>

          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">🔮 <%= t("home.changelog.v020.roadmap.heading") %></h3>
          <ul class="list-disc pl-6 text-gray-700 dark:text-gray-300 space-y-2">
            <% t("home.changelog.v020.roadmap.items").each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>
        </div>

        <!-- Newsletter Signup -->
        <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.changelog.stay_updated.heading") %></h3>
          <p class="text-gray-700 dark:text-gray-300 mb-4">
            <%= t("home.changelog.stay_updated.text") %>
          </p>
          <% if user_signed_in? %>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              <%= t("home.changelog.stay_updated.signed_in", email: current_user.email) %>
            </p>
          <% else %>
            <%= link_to t("home.changelog.stay_updated.sign_up_cta"), new_user_registration_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
