<% content_for :title, "Changelog - Requiems API" %>

<div class="min-h-screen bg-gray-50 py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-lg shadow-lg p-8 md:p-12">
      <div class="flex items-center justify-between mb-6">
        <h1 class="text-4xl font-bold text-gray-900">Changelog</h1>
        <%= render "shared/badge", text: "v0.9", variant: "info", size: "md" %>
      </div>

      <p class="text-xl text-gray-600 mb-12">
        Track updates, new features, and improvements to Requiems API.
      </p>

      <div class="space-y-12">
        <!-- Version Entry -->
        <div class="border-l-4 border-blue-600 pl-6">
          <div class="flex items-center mb-2">
            <h2 class="text-2xl font-bold text-gray-900">v0.9.0</h2>
            <%= render "shared/badge", text: "Latest", variant: "success", size: "sm", class_names: "ml-3" %>
          </div>
          <p class="text-sm text-gray-600 mb-4"><%= Time.current.strftime("%B %d, %Y") %></p>

          <h3 class="text-lg font-semibold text-gray-900 mb-2">✨ New Features</h3>
          <ul class="list-disc pl-6 text-gray-700 space-y-2 mb-4">
            <li>Email validation and disposable email detection APIs</li>
            <li>Text utility APIs (advice, quotes, Lorem Ipsum, random words)</li>
            <li>EU-based infrastructure for GDPR compliance</li>
            <li>Dashboard with usage analytics and API key management</li>
            <li>Multiple subscription tiers with free trial</li>
          </ul>

          <h3 class="text-lg font-semibold text-gray-900 mb-2">🔧 Improvements</h3>
          <ul class="list-disc pl-6 text-gray-700 space-y-2 mb-4">
            <li>99.99% uptime SLA implementation</li>
            <li>Enhanced rate limiting at the edge</li>
            <li>Improved API documentation</li>
            <li>Real-time usage tracking</li>
          </ul>

          <h3 class="text-lg font-semibold text-gray-900 mb-2">🐛 Bug Fixes</h3>
          <ul class="list-disc pl-6 text-gray-700 space-y-2">
            <li>Fixed authentication header parsing</li>
            <li>Resolved rate limit counter sync issues</li>
            <li>Improved error message clarity</li>
          </ul>
        </div>

        <!-- Upcoming -->
        <div class="border-l-4 border-gray-300 pl-6 opacity-75">
          <div class="flex items-center mb-2">
            <h2 class="text-2xl font-bold text-gray-900">v1.0.0</h2>
            <%= render "shared/badge", text: "Coming Soon", variant: "warning", size: "sm", class_names: "ml-3" %>
          </div>
          <p class="text-sm text-gray-600 mb-4">Planned Release: Q2 2026</p>

          <h3 class="text-lg font-semibold text-gray-900 mb-2">🚀 Planned Features</h3>
          <ul class="list-disc pl-6 text-gray-700 space-y-2 mb-4">
            <li>Data APIs (IP geolocation, currency conversion)</li>
            <li>Finance APIs (stock quotes, crypto prices)</li>
            <li>Image APIs (optimization, placeholders, QR codes)</li>
            <li>SOC 2 Type II certification completion</li>
            <li>Webhooks for usage alerts</li>
            <li>GraphQL API support</li>
            <li>SDK libraries (Python, JavaScript, Go, Ruby)</li>
          </ul>
        </div>

        <!-- Newsletter Signup -->
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Stay Updated</h3>
          <p class="text-gray-700 mb-4">
            Want to be notified about new releases and features?
          </p>
          <% if user_signed_in? %>
            <p class="text-sm text-gray-600">
              We'll send update notifications to your registered email:
              <strong><%= current_user.email %></strong>
            </p>
          <% else %>
            <%= link_to "Sign up for an account", new_user_registration_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
