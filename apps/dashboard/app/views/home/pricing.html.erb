<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <!-- Header -->
  <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">
        <%= t("home.pricing.header.heading") %>
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
        <%= t("home.pricing.header.description") %>
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12" data-controller="pricing-toggle">
    <!-- Billing Toggle -->
    <div class="flex justify-center mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-lg border-2 border-gray-200 dark:border-gray-700 p-1 inline-flex">
        <button
          type="button"
          data-pricing-toggle-target="monthlyButton"
          data-action="click->pricing-toggle#showMonthly"
          class="px-6 py-2 rounded-md text-sm font-medium transition-colors bg-blue-600 text-white">
          <%= t("home.pricing.toggle.monthly") %>
        </button>
        <button
          type="button"
          data-pricing-toggle-target="yearlyButton"
          data-action="click->pricing-toggle#showYearly"
          class="px-6 py-2 rounded-md text-sm font-medium transition-colors text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-gray-100">
          <%= t("home.pricing.toggle.yearly") %>
          <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-300">
            <%= t("home.pricing.toggle.save") %>
          </span>
        </button>
      </div>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      <!-- Free Plan -->
      <%= render "partials/pricing/pricing_card",
        name: t("home.pricing.plans.free.name"),
        monthly_price: 0,
        yearly_price: 0,
        description: t("home.pricing.plans.free.description"),
        requests: "500",
        rate_limit: "30/min",
        features: t("home.pricing.plans.free.features"),
        cta_text: t("home.pricing.plans.free.cta"),
        cta_url: new_user_registration_path,
        popular: false %>

      <!-- Developer Plan -->
      <%= render "partials/pricing/pricing_card",
        name: t("home.pricing.plans.developer.name"),
        monthly_price: 30,
        yearly_price: 25,
        description: t("home.pricing.plans.developer.description"),
        requests: "100k",
        rate_limit: "5,000/min",
        features: t("home.pricing.plans.developer.features"),
        cta_text: t("home.pricing.plans.developer.cta"),
        cta_url: user_signed_in? ? { method: :post, url: dashboard_checkout_billing_path, params: { plan: "developer", billing_cycle: "monthly" } } : new_user_registration_path(plan: "developer"),
        popular: false %>

      <!-- Business Plan (Most Popular) -->
      <%= render "partials/pricing/pricing_card",
        name: t("home.pricing.plans.business.name"),
        monthly_price: 75,
        yearly_price: 62.5,
        description: t("home.pricing.plans.business.description"),
        requests: "1M",
        rate_limit: "10k/min",
        features: t("home.pricing.plans.business.features"),
        cta_text: t("home.pricing.plans.business.cta"),
        cta_url: user_signed_in? ? { method: :post, url: dashboard_checkout_billing_path, params: { plan: "business", billing_cycle: "monthly" } } : new_user_registration_path(plan: "business"),
        popular: true %>

      <!-- Professional Plan -->
      <%= render "partials/pricing/pricing_card",
        name: t("home.pricing.plans.professional.name"),
        monthly_price: 150,
        yearly_price: 125,
        description: t("home.pricing.plans.professional.description"),
        requests: "10M",
        rate_limit: "50k/min",
        features: t("home.pricing.plans.professional.features"),
        cta_text: t("home.pricing.plans.professional.cta"),
        cta_url: user_signed_in? ? { method: :post, url: dashboard_checkout_billing_path, params: { plan: "professional", billing_cycle: "monthly" } } : new_user_registration_path(plan: "professional"),
        popular: false %>
    </div>

    <!-- Private Deployment -->
    <div class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-xl text-white p-8 md:p-12 mb-16">
      <div class="text-center mb-10">
        <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-white/10 text-white/80 mb-4"><%= t("home.pricing.plans.private_deployment.badge") %></div>
        <h3 class="text-3xl font-bold mb-3"><%= t("home.pricing.plans.private_deployment.heading") %></h3>
        <p class="text-gray-300 max-w-2xl mx-auto"><%= t("home.pricing.plans.private_deployment.description") %></p>
      </div>

      <!-- Tier cards — pulled from model constants, no hardcoding -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
        <% PrivateDeploymentRequest::TIER_SPECS.each do |tier_key, specs| %>
          <% mo = PrivateDeploymentRequest::TIER_PRICES_MONTHLY[tier_key] / 100 %>
          <% yr = (PrivateDeploymentRequest::TIER_PRICES_YEARLY[tier_key] / 100.0 / 12).round %>
          <div class="bg-white/5 border border-white/10 rounded-lg p-5">
            <p class="font-bold text-white mb-1 capitalize"><%= tier_key %></p>
            <p class="text-xs text-gray-400 mb-3"><%= specs[:hetzner] %> · <%= specs[:vcpu] %> vCPU · <%= specs[:ram] %> RAM · <%= specs[:ssd] %> SSD</p>
            <p class="text-2xl font-bold text-white">$<%= mo %><span class="text-sm font-normal text-gray-400">/mo</span></p>
            <p class="text-xs text-green-400 mt-0.5"><%= t("home.pricing.plans.private_deployment.yearly_note", price: yr) %></p>
          </div>
        <% end %>
      </div>

      <!-- Feature bullets -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-10 text-sm text-gray-300">
        <% t("home.pricing.plans.private_deployment.features").each do |feat| %>
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4 text-green-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <%= feat %>
          </div>
        <% end %>
      </div>

      <div class="text-center">
        <%= link_to "#{t("home.pricing.plans.private_deployment.cta")} →",
          user_signed_in? ? new_private_deployment_path : new_user_registration_path,
          class: "inline-flex items-center px-10 py-4 bg-white text-gray-900 font-bold rounded-lg hover:bg-gray-100 transition-colors text-lg" %>
        <p class="mt-3 text-sm text-gray-400"><%= t("home.pricing.plans.private_deployment.checkout_note") %></p>
      </div>
    </div>

    <!-- Feature Comparison Table -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden mb-16">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t("home.pricing.table.heading") %></h2>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("home.pricing.table.feature_col") %></th>
              <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("home.pricing.plans.free.name") %></th>
              <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("home.pricing.plans.developer.name") %></th>
              <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("home.pricing.plans.business.name") %></th>
              <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"><%= t("home.pricing.plans.professional.name") %></th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <%= render "partials/pricing/pricing_table_row", feature: t("home.pricing.table.rows.monthly_requests"), values: ["500", "100k", "1M", "10M"] %>
            <%= render "partials/pricing/pricing_table_row", feature: t("home.pricing.table.rows.rate_limit"), values: ["30/min", "5k/min", "10k/min", "50k/min"] %>
            <%= render "partials/pricing/pricing_table_row", feature: t("home.pricing.table.rows.api_endpoints"), values: Array.new(4) { t("home.pricing.table.values.all") } %>
            <%= render "partials/pricing/pricing_table_row", feature: t("home.pricing.table.rows.data_centers"), values: Array.new(4) { t("home.pricing.table.values.eu") } %>
            <%= render "partials/pricing/pricing_table_row", feature: t("home.pricing.table.rows.support_response"), values: [t("home.pricing.table.values.community"), "24h", "4h", "1h"] %>
            <%= render "partials/pricing/pricing_table_row", feature: t("home.pricing.table.rows.sla"), values: [t("home.pricing.table.values.none"), t("home.pricing.table.values.none"), "99.9%", "99.95%"] %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Security & Compliance Section -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-8 mb-16">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 text-center"><%= t("home.pricing.security.heading") %></h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 mb-4">
            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.pricing.security.soc2_title") %></h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm"><%= t("home.pricing.security.soc2_desc") %></p>
        </div>

        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 dark:bg-green-900 text-green-600 dark:text-green-300 mb-4">
            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.pricing.security.eu_title") %></h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm"><%= t("home.pricing.security.eu_desc") %></p>
        </div>

        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-purple-100 dark:bg-purple-900 text-purple-600 dark:text-purple-300 mb-4">
            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= t("home.pricing.security.encryption_title") %></h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm"><%= t("home.pricing.security.encryption_desc") %></p>
        </div>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-8">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6"><%= t("home.pricing.faq.heading") %></h2>

      <div class="space-y-4" data-controller="faq-accordion">
        <%= render "partials/pricing/faq_item",
          question: t("home.pricing.faq.q1"),
          answer: t("home.pricing.faq.a1") %>

        <%= render "partials/pricing/faq_item",
          question: t("home.pricing.faq.q2"),
          answer: t("home.pricing.faq.a2") %>

        <%= render "partials/pricing/faq_item",
          question: t("home.pricing.faq.q3"),
          answer: t("home.pricing.faq.a3") %>

        <%= render "partials/pricing/faq_item",
          question: t("home.pricing.faq.q4"),
          answer: t("home.pricing.faq.a4") %>

        <%= render "partials/pricing/faq_item",
          question: t("home.pricing.faq.q5"),
          answer: t("home.pricing.faq.a5") %>
      </div>
    </div>
  </div>
</div>
