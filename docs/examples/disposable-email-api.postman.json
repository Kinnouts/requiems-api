{
  "info": {
    "name": "Disposable Email Detection API",
    "description": "Collection for testing disposable email detection endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Check Single Email (Disposable)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@tempmail.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/email/disposable/check",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "email", "disposable", "check"]
        },
        "description": "Check if a single email address is disposable (should return true for tempmail.com)"
      }
    },
    {
      "name": "Check Single Email (Legitimate)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@gmail.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/email/disposable/check",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "email", "disposable", "check"]
        },
        "description": "Check if a single email address is disposable (should return false for gmail.com)"
      }
    },
    {
      "name": "Batch Check Emails",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"emails\": [\n    \"user1@tempmail.com\",\n    \"user2@gmail.com\",\n    \"user3@10minutemail.com\",\n    \"user4@outlook.com\",\n    \"user5@guerrillamail.com\"\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/email/disposable/check-batch",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "email", "disposable", "check-batch"]
        },
        "description": "Check multiple email addresses at once (max 100)"
      }
    },
    {
      "name": "Check Domain (Disposable)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/email/disposable/domain/tempmail.com",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "email", "disposable", "domain", "tempmail.com"]
        },
        "description": "Check if a specific domain is in the disposable list"
      }
    },
    {
      "name": "Check Domain (Legitimate)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/email/disposable/domain/gmail.com",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "email", "disposable", "domain", "gmail.com"]
        },
        "description": "Check if a specific domain is in the disposable list (should return false)"
      }
    },
    {
      "name": "Get Statistics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/email/disposable/stats",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "email", "disposable", "stats"]
        },
        "description": "Get statistics about the disposable domains blocklist"
      }
    },
    {
      "name": "List Domains (Page 1)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/email/disposable/domains?page=1&per_page=10",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "email", "disposable", "domains"],
          "query": [
            {
              "key": "page",
              "value": "1",
              "description": "Page number (default: 1)"
            },
            {
              "key": "per_page",
              "value": "10",
              "description": "Results per page (1-1000, default: 100)"
            }
          ]
        },
        "description": "Get a paginated list of all disposable domains"
      }
    },
    {
      "name": "List Domains (Page 2)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/email/disposable/domains?page=2&per_page=50",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "email", "disposable", "domains"],
          "query": [
            {
              "key": "page",
              "value": "2"
            },
            {
              "key": "per_page",
              "value": "50"
            }
          ]
        },
        "description": "Get page 2 with 50 results per page"
      }
    },
    {
      "name": "Error - Missing Email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/email/disposable/check",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "email", "disposable", "check"]
        },
        "description": "Test error handling - should return 400 Bad Request"
      }
    },
    {
      "name": "Error - Empty Batch",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"emails\": []\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/email/disposable/check-batch",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "email", "disposable", "check-batch"]
        },
        "description": "Test error handling - should return 400 Bad Request"
      }
    }
  ]
}
