{
  "name": "@requiem/integration-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "description": "Local integration tests for the full request flow (Worker → Backend → DB)",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "docs:perf": "tsx scripts/inject-perf-docs.ts",
    "docs:perf:yaml": "tsx scripts/inject-perf-yaml.ts",
    "benchmark": "INTEGRATION_RUNS=50 UPDATE_PERF_BASELINE=true vitest run; pnpm run docs:perf && pnpm run docs:perf:yaml"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "js-yaml": "^4.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
}
