# ──────────────────────────────────────────────────────────
# Requiems API — Integration Test Configuration
# ──────────────────────────────────────────────────────────
#
# 1. Copy this file to .env (git-ignored)
# 2. Fill in your production API key
# 3. Run: pnpm test
# ──────────────────────────────────────────────────────────

# Your Requiems API key — get one at https://requiems.xyz
# Must be a live key (rq_live_...) for full end-to-end coverage.
REQUIEMS_API_KEY=rq_live_your_key_here

# Target URL — defaults to the production gateway.
# Change to http://localhost:4455 to test against a local wrangler dev instance.
# API_BASE_URL=https://api.requiems.xyz

# How many times each test scenario is exercised to build stable timing data.
# Higher values give better statistical significance but consume more credits.
# Default: 3
# INTEGRATION_RUNS=3
