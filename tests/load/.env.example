# ──────────────────────────────────────────────────────────
# Requiems API — Load Test Configuration (k6)
# ──────────────────────────────────────────────────────────
#
# k6 reads environment variables via the --env / -e flag or
# by setting them in your shell before running:
#
#   BASE_URL=https://api.requiems.xyz \
#   API_KEY_DEVELOPER=rq_devl_xxx \
#   k6 run tests/load/scenarios/baseline.ts
#
# When running against the local dev stack the defaults below
# work out of the box — just start the stack first:
#   docker compose -f docker-compose.dev.yml up
# ──────────────────────────────────────────────────────────

# Gateway base URL.
# Local dev stack (default): http://localhost:4455
# Production:                https://api.requiems.xyz
BASE_URL=http://localhost:4455

# Dev API keys — seeded by apps/workers/auth-gateway/scripts/seed-dev.ts.
# These defaults match the values written by seed-dev when running locally.
# Replace with real keys for production load tests.
API_KEY_FREE=rq_free_000001
API_KEY_DEVELOPER=rq_devl_000001
API_KEY_BUSINESS=rq_bizz_000001
API_KEY_PROFESSIONAL=rq_prof_000001
